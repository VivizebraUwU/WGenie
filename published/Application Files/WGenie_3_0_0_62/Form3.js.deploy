document.addEventListener("DOMContentLoaded", function () {
    var tabDragLogPrefix = "[TAB-DRAG][JS]";
    var browserLogPrefix = "[FORM3-BROWSER][JS]";
    var copyCatDebugPrefix = "[COPYCAT-DEBUG][JS]";
    var alevLocalizationDebugPrefix = "[AlevLocalizationDebug][JS]";
    var storageKey = "form3-theme";
    var toolboxStorageKey = "form3-toolbox-collapsed";
    var root = document.documentElement;
    var appShell = document.querySelector(".app-shell");
    var buttonSelector = ".theme-toggle, .tool-button, .session-button";
    var loginButton = document.getElementById("form3LoginButton");
    var themeToggle = document.getElementById("themeToggle");
    var toolboxToggle = document.getElementById("toolboxToggle");
    var toolList = document.getElementById("toolList");
    var tabsBar = document.querySelector(".tabs-bar");
    var messageText = document.querySelector(".message-text");
    var contentKicker = document.querySelector("#workspaceEmpty .content-kicker");
    var contentTitle = document.querySelector("#workspaceEmpty h2");
    var contentBody = document.querySelector("#workspaceEmpty p:last-of-type");
    var loginWorkspaceAnchor = document.getElementById("loginWorkspaceAnchor");
    var workspaceEmpty = document.getElementById("workspaceEmpty");
    var workspaceHost = document.getElementById("workspaceHost");
    var resizeObserver = null;
    var savedTheme = null;
    var toolDefinitions = new Map();
    var browserToolDefinition = {
        id: "browser",
        label: "Browser",
        workspaceType: "browser"
    };
    var mailoToolConfiguration = {
        id: "email",
        label: "EMAIL",
        workspaceType: "mailo-v2",
        available: false,
        url: "",
        missingFiles: []
    };
    var browserToolbarHeight = 42;
    var defaultBrowserUrl = "";
    var pendingBrowserNavigationUrl = null;
    var form3LoginState = {
        hasValidSessionId: false,
        sessionId: "",
        loginWorkspaceVisible: false
    };
    var currentMailoState = null;
    var currentAlevRewardState = {
        rewardTypes: [],
        outputXml: "",
        finalOutputJson: "",
        baseLevelData: null,
        translations: [],
        translationImport: null,
        statusMessage: "",
        statusIsError: false
    };
    var currentCooldownSimulatorState = null;
    var cooldownSimulatorTooltip = null;
    var cooldownSimulatorJiraDialog = null;
    var cooldownSimulatorJiraProgressDialog = null;
    var cooldownSimulatorJiraProgressRows = new Map();
    var cooldownSimulatorVisibleColumnKeys = null;
    var cooldownSimulatorDateEditErrors = Object.create(null);
    var cooldownSimulatorDateEditTimers = Object.create(null);
    var cooldownSimulatorDateEditLastCommittedValues = Object.create(null);
    var copyCatResizeState = {
        panel: null,
        previewPercent: 80
    };
    var tabState = {
        items: [],
        activeId: null,
        dragId: null,
        dragActive: false,
        sourceIndex: -1,
        hoverTabId: null,
        previewIndex: null,
        dropPreview: null,
        mouseDownCandidate: null,
        suppressClickUntil: 0
    };
    var emptyMessage = "Select a tool from the toolbox to open it.";
    var emptyContentTitle = "No tool open";
    var emptyContentBody = "Select a tool from the toolbox to open a tab and launch the matching Form2 interface.";
    var savedToolboxCollapsed = false;

    logTabDrag("INIT", {
        layer: "webview-js",
        tabsOwner: "WebView2 HTML/JS",
        forwarding: "console+webMessage",
        tabsBarFound: !!tabsBar,
        initialTabCount: document.querySelectorAll(".tab-button").length
    });

    try {
        savedTheme = window.localStorage.getItem(storageKey);
    } catch (error) {
        savedTheme = null;
    }

    try {
        savedToolboxCollapsed = window.localStorage.getItem(toolboxStorageKey) === "true";
    } catch (error) {
        savedToolboxCollapsed = false;
    }

    applyTheme(savedTheme === "light" ? "light" : "dark");
    applyToolboxCollapsed(savedToolboxCollapsed, false);
    applyForm3LoginState(form3LoginState, false);
    scheduleButtonFit();

    if (themeToggle) {
        themeToggle.addEventListener("click", function () {
            var nextTheme = root.getAttribute("data-theme") === "light" ? "dark" : "light";
            applyTheme(nextTheme);

            try {
                window.localStorage.setItem(storageKey, nextTheme);
            } catch (error) {
            }
        });
    }

    if (loginButton) {
        loginButton.addEventListener("click", function () {
            postForm3LoginAction("form3Login", getLoginWorkspaceBounds(), "session-button-click");
        });
    }

    if (toolboxToggle) {
        toolboxToggle.addEventListener("click", function () {
            var isCollapsed = !!(appShell && appShell.classList.contains("is-toolbox-collapsed"));
            applyToolboxCollapsed(!isCollapsed, true);
        });
    }

    if (toolList) {
        toolList.addEventListener("click", function (event) {
            var button = event.target.closest(".tool-button");
            if (!button) {
                return;
            }

            if (button.dataset.toolId === browserToolDefinition.id) {
                logBrowserWorkspace("TOOLBOX_CLICK", {
                    toolId: button.dataset.toolId,
                    label: button.textContent
                });
            }

            openOrActivateTool(button.dataset.toolId);
            scheduleButtonFit();
        });
    }

    if (tabsBar) {
        logTabDrag("HANDLERS_ATTACH", {
            target: ".tabs-bar",
            existingTabs: tabsBar.querySelectorAll(".tab-button").length
        });

        tabsBar.addEventListener("pointerdown", function (event) {
            logPointerInput("POINTER_DOWN", event);
        });

        tabsBar.addEventListener("mousedown", function (event) {
            logPointerInput("MOUSE_DOWN_TOP", event);
        });

        tabsBar.addEventListener("click", function (event) {
            if (Date.now() < tabState.suppressClickUntil) {
                event.preventDefault();
                event.stopPropagation();
                logTabDrag("CLICK_SUPPRESSED", {
                    reason: "drag-release",
                    targetRole: getEventTargetRole(event.target)
                });
                return;
            }

            var closeButton = event.target.closest(".tab-close");
            if (closeButton) {
                event.stopPropagation();
                logTabDrag("CLOSE_CLICK", {
                    tab: formatTabIdentity(closeButton.dataset.tabId),
                    targetRole: getEventTargetRole(event.target)
                });
                closeTab(closeButton.dataset.tabId);
                return;
            }

            var tab = event.target.closest(".tab-button");
            if (!tab) {
                return;
            }

            activateTab(tab.dataset.tabId, true);
        });

        tabsBar.addEventListener("auxclick", function (event) {
            if (event.button !== 1) {
                return;
            }

            var tab = event.target.closest(".tab-button");
            if (!tab) {
                return;
            }

            event.preventDefault();
            logTabDrag("CLOSE_MIDDLE_CLICK", {
                tab: formatTabIdentity(tab.dataset.tabId),
                targetRole: getEventTargetRole(event.target)
            });
            closeTab(tab.dataset.tabId);
        });

        tabsBar.addEventListener("mousedown", function (event) {
            var tab = event.target.closest(".tab-button");
            var isCloseButton = !!event.target.closest(".tab-close");

            if (event.button !== 0) {
                return;
            }

            if (!tab) {
                logTabDrag("MOUSEDOWN_SKIPPED", {
                    reason: "no-tab-under-pointer",
                    targetRole: getEventTargetRole(event.target),
                    x: event.clientX,
                    y: event.clientY
                });
                return;
            }

            if (isCloseButton) {
                logTabDrag("MOUSEDOWN_INTERCEPTED", {
                    reason: "close-button-hit",
                    tab: formatTabIdentity(tab.dataset.tabId)
                });
                return;
            }

            tabState.mouseDownCandidate = {
                tabId: tab.dataset.tabId,
                x: event.clientX,
                y: event.clientY,
                sourceIndex: getModelIndexById(tab.dataset.tabId)
            };

            logTabDrag("MOUSEDOWN", {
                tab: formatTabIdentity(tab.dataset.tabId),
                visualIndex: getVisualIndexById(tab.dataset.tabId),
                modelIndex: getModelIndexById(tab.dataset.tabId),
                x: event.clientX,
                y: event.clientY,
                dragAllowed: true,
                targetRole: getEventTargetRole(event.target)
            });
            event.preventDefault();
        });

        tabsBar.addEventListener("keydown", function (event) {
            var closeButton = event.target.closest(".tab-close");
            if (closeButton && (event.key === "Enter" || event.key === " ")) {
                event.preventDefault();
                closeTab(closeButton.dataset.tabId);
                return;
            }

            var tab = event.target.closest(".tab-button");
            if (!tab) {
                return;
            }

            if (event.key === "Enter" || event.key === " ") {
                event.preventDefault();
                activateTab(tab.dataset.tabId, true);
            }
        });

        tabsBar.addEventListener("wheel", function (event) {
            var delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;

            if (delta === 0) {
                return;
            }

            tabsBar.scrollLeft += delta;
            event.preventDefault();
        }, { passive: false });

        tabsBar.addEventListener("dragstart", function (event) {
            event.preventDefault();
            logTabDrag("NATIVE_DRAGSTART_IGNORED", {
                targetRole: getEventTargetRole(event.target)
            });
        });

        tabsBar.addEventListener("mouseleave", function (event) {
            if (!tabState.dragActive) {
                return;
            }

            logTabDrag("DRAG_LEAVE", {
                source: formatTabIdentity(tabState.dragId),
                reason: "left-tab-strip",
                x: event.clientX,
                y: event.clientY
            });
        });
    } else {
        logTabDrag("HANDLERS_ATTACH_SKIPPED", {
            reason: "tabsBar-selector-not-found",
            selector: ".tabs-bar"
        });
    }

    document.addEventListener("pointermove", function (event) {
        if (!tabState.mouseDownCandidate && !tabState.dragId) {
            return;
        }

        logPointerInput("POINTER_MOVE_DOC", event);
    });

    document.addEventListener("mousemove", function (event) {
        if (copyCatResizeState.panel) {
            handleCopyCatResizeMove(event);
        }

        if (!tabState.mouseDownCandidate && !tabState.dragId) {
            return;
        }

        logPointerInput("MOUSE_MOVE_DOC", event);
        handleDocumentMouseMove(event);
    });

    document.addEventListener("pointerup", function (event) {
        if (!tabState.mouseDownCandidate && !tabState.dragId) {
            return;
        }

        logPointerInput("POINTER_UP_DOC", event);
    });

    document.addEventListener("mouseup", function (event) {
        if (copyCatResizeState.panel) {
            handleCopyCatResizeEnd(event);
        }

        if (!tabState.mouseDownCandidate && !tabState.dragId) {
            return;
        }

        logPointerInput("MOUSE_UP_DOC", event);
        handleDocumentMouseUp(event);
    });

    window.addEventListener("message", function (event) {
        if (!event || !event.data) {
            return;
        }

        if (event.data.type === "mailo-preview-trace") {
            logBrowserWorkspace("MAILO_PREVIEW_TRACE", {
                message: event.data.message || ""
            });
            return;
        }

        if (event.data.type === "mailo-action") {
            logBrowserWorkspace("MAILO_ACTION_MESSAGE", {
                action: event.data.action || ""
            });
            postMailoAction(event.data.action);
            return;
        }

        if (event.data.type === "mailo-ready") {
            syncEmbeddedWorkspaceThemes(root.getAttribute("data-theme") || "dark");
            postMailoStateToFrames();
            return;
        }
    });

    window.addEventListener("resize", function () {
        scheduleButtonFit();
        hideCooldownSimulatorTooltip();
        logActiveCopyCatWorkspaceSnapshot("WINDOW_RESIZE");
        scheduleLoginWorkspaceSync("window-resize");
        scheduleCopyCatWorkspaceSync("window-resize");
        scheduleWgcWorkspaceSync("window-resize");
        scheduleBrowserWorkspaceSync("window-resize");
    });

    if (window.ResizeObserver) {
        resizeObserver = new ResizeObserver(function () {
            scheduleButtonFit();
            logActiveCopyCatWorkspaceSnapshot("RESIZE_OBSERVER");
            scheduleLoginWorkspaceSync("resize-observer");
            scheduleCopyCatWorkspaceSync("resize-observer");
            scheduleWgcWorkspaceSync("resize-observer");
            scheduleBrowserWorkspaceSync("resize-observer");
        });

        resizeObserver.observe(document.body);
    }

    function applyTheme(themeName) {
        root.setAttribute("data-theme", themeName);
        pushBrowserThemeState("apply-theme");
        syncEmbeddedWorkspaceThemes(themeName);

        if (!themeToggle) {
            scheduleButtonFit();
            return;
        }

        var isDarkTheme = themeName === "dark";
        themeToggle.textContent = isDarkTheme ? "Light theme" : "Dark theme";
        themeToggle.setAttribute("aria-pressed", isDarkTheme ? "false" : "true");
        scheduleButtonFit();
    }

    function applyToolboxCollapsed(isCollapsed, shouldPersist) {
        if (!appShell) {
            return;
        }

        appShell.classList.toggle("is-toolbox-collapsed", !!isCollapsed);
        if (toolboxToggle) {
            toolboxToggle.textContent = isCollapsed ? "\u00bb" : "\u00ab";
            toolboxToggle.title = isCollapsed ? "Expand toolbox" : "Collapse toolbox";
            toolboxToggle.setAttribute("aria-label", toolboxToggle.title);
            toolboxToggle.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
        }

        if (shouldPersist) {
            try {
                window.localStorage.setItem(toolboxStorageKey, isCollapsed ? "true" : "false");
            } catch (error) {
            }
        }

        scheduleButtonFit();
        hideCooldownSimulatorTooltip();
        scheduleLoginWorkspaceSync("toolbox-toggle");
        scheduleCopyCatWorkspaceSync("toolbox-toggle");
        scheduleWgcWorkspaceSync("toolbox-toggle");
        scheduleBrowserWorkspaceSync("toolbox-toggle");
    }

    function syncActiveToolButton(activeToolId) {
        var toolButtons = document.querySelectorAll(".tool-button");

        toolButtons.forEach(function (item) {
            item.classList.remove("is-active");
        });

        if (!activeToolId) {
            return;
        }

        var activeButton = toolList ? toolList.querySelector(".tool-button[data-tool-id='" + activeToolId + "']") : null;
        if (activeButton) {
            activeButton.classList.add("is-active");
        }
    }

    function openOrActivateTool(toolId) {
        if (!toolDefinitions.has(toolId)) {
            return;
        }

        var existingTab = findTabByToolId(toolId);
        if (existingTab) {
            if (toolId === browserToolDefinition.id) {
                logBrowserWorkspace("TAB_REUSE", {
                    tab: formatTabIdentity(existingTab.id)
                });
            }

            activateTab(existingTab.id, true);
            return;
        }

        var tool = toolDefinitions.get(toolId);
        var tab = {
            id: "tab-" + toolId,
            toolId: toolId,
            title: tool.label,
            workspaceType: tool.workspaceType || "native",
            panelId: "panel-" + toolId
        };

        tabState.items.push(tab);
        tabState.activeId = tab.id;
        if (tab.workspaceType === "browser") {
            logBrowserWorkspace("TAB_CREATE", {
                tab: formatTabIdentity(tab.id),
                url: defaultBrowserUrl
            });
        }

        createWorkspacePanel(tab);
        renderTabs();
        updateWorkspaceVisibility();
        syncActiveToolButton(toolId);
        activateWorkspace(tab);
        if (shouldNotifyHost(tab)) {
            notifyHostAboutTool(toolId);
        }
    }

    function activateTab(tabId, notifyHost) {
        var tab = findTabById(tabId);
        if (!tab) {
            return;
        }

        tabState.activeId = tabId;
        renderTabs();
        updateWorkspaceVisibility();
        activateWorkspace(tab);
        syncActiveToolButton(tab.toolId);

        if (notifyHost && shouldNotifyHost(tab)) {
            notifyHostAboutTool(tab.toolId);
        }
    }

    function closeTab(tabId) {
        var tabIndex = tabState.items.findIndex(function (item) {
            return item.id === tabId;
        });

        if (tabIndex < 0) {
            return;
        }

        disposeWorkspace(tabState.items[tabIndex]);
        var wasActive = tabState.activeId === tabId;
        tabState.items.splice(tabIndex, 1);

        if (wasActive) {
            if (tabState.items.length === 0) {
                tabState.activeId = null;
            } else {
                var nextIndex = Math.min(tabIndex, tabState.items.length - 1);
                tabState.activeId = tabState.items[nextIndex].id;
            }
        }

        renderTabs();
        updateWorkspaceVisibility();
        activateWorkspace(getActiveTab());
        syncActiveToolButton(getActiveTab() ? getActiveTab().toolId : null);
        scheduleBrowserWorkspaceSync("close-tab");
    }

    function notifyHostAboutTool(toolId) {
        if (!toolId || !window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "launchTool",
            toolId: toolId
        });
    }

    function scheduleButtonFit() {
        window.requestAnimationFrame(function () {
            fitAllButtons();
        });
    }

    function fitAllButtons() {
        var buttons = document.querySelectorAll(buttonSelector);

        buttons.forEach(function (button) {
            fitButtonText(button);
        });
    }

    function fitButtonText(button) {
        var computed = window.getComputedStyle(button);
        var minFontSize = parseFloat(getRootVariableValue("--button-font-size-min")) || 12;
        var baseFontSize = button.dataset.baseFontSize
            ? parseFloat(button.dataset.baseFontSize)
            : parseFloat(computed.fontSize);
        var fittedFontSize = baseFontSize;

        button.dataset.baseFontSize = String(baseFontSize);
        button.style.fontSize = baseFontSize + "px";
        button.style.whiteSpace = "nowrap";
        button.style.overflowWrap = "normal";
        button.style.wordBreak = "normal";

        while (isButtonOverflowing(button) && fittedFontSize > minFontSize) {
            fittedFontSize -= 0.5;
            button.style.fontSize = fittedFontSize + "px";
        }

        if (isButtonOverflowing(button)) {
            button.style.whiteSpace = "normal";
            button.style.overflowWrap = "anywhere";
            button.style.wordBreak = "break-word";

            while (isButtonOverflowing(button) && fittedFontSize > minFontSize) {
                fittedFontSize -= 0.5;
                button.style.fontSize = fittedFontSize + "px";
            }
        }
    }

    function isButtonOverflowing(button) {
        return button.scrollWidth > button.clientWidth || button.scrollHeight > button.clientHeight;
    }

    function getRootVariableValue(variableName) {
        return window.getComputedStyle(root).getPropertyValue(variableName).trim();
    }

    function normalizePlainObject(value) {
        return value && typeof value === "object" ? value : {};
    }

    window.form3SetTools = function (tools) {
        renderToolButtons(Array.isArray(tools) ? tools : []);
    };

    window.form3SetMailoState = function (state) {
        currentMailoState = state && typeof state === "object" ? state : null;
        postMailoStateToFrames();
    };

    window.form3SetAlevRewardState = function (state) {
        currentAlevRewardState = {
            rewardTypes: state && Array.isArray(state.rewardTypes) ? state.rewardTypes : [],
            outputXml: state && typeof state.outputXml === "string" ? state.outputXml : "",
            finalOutputJson: state && typeof state.finalOutputJson === "string" ? state.finalOutputJson : "",
            baseLevelData: state && state.baseLevelData && typeof state.baseLevelData === "object" ? state.baseLevelData : null,
            translations: state && Array.isArray(state.translations) ? state.translations : [],
            translationImport: state && state.translationImport && typeof state.translationImport === "object" ? state.translationImport : null,
            statusMessage: state && typeof state.statusMessage === "string" ? state.statusMessage : "",
            statusIsError: !!(state && state.statusIsError)
        };
        updateAlevRewardWorkspacePanels();
    };

    window.form3SetCooldownSimulatorState = function (state) {
        currentCooldownSimulatorState = state && typeof state === "object" ? state : null;
        clearCooldownSimulatorDateEditDebounces();
        cooldownSimulatorDateEditErrors = Object.create(null);
        hideCooldownSimulatorTooltip();
        updateCooldownSimulatorWorkspacePanels();
    };

    window.form3SetCooldownSimulatorJiraProgress = function (progress) {
        applyCooldownSimulatorJiraProgress(progress && typeof progress === "object" ? progress : {});
    };

    window.form3ClearCooldownSimulatorJiraProgress = function () {
        closeCooldownSimulatorJiraDialog();
        closeCooldownSimulatorJiraProgressDialog();
        cooldownSimulatorJiraProgressRows.clear();
    };

    window.form3LoginResult = function (state) {
        applyForm3LoginState(state && typeof state === "object" ? state : null, true);
    };

    window.form3Configure = function (configuration) {
        configuration = normalizePlainObject(configuration);

        if (configuration && configuration.browserTool) {
            browserToolDefinition = {
                id: configuration.browserTool.id || browserToolDefinition.id,
                label: configuration.browserTool.label || browserToolDefinition.label,
                workspaceType: "browser"
            };
        }

        if (configuration && configuration.mailoTool) {
            mailoToolConfiguration = {
                id: configuration.mailoTool.id || mailoToolConfiguration.id,
                label: configuration.mailoTool.label || mailoToolConfiguration.label,
                workspaceType: configuration.mailoTool.workspaceType || mailoToolConfiguration.workspaceType,
                available: configuration.mailoTool.available !== false,
                url: configuration.mailoTool.url || "",
                missingFiles: Array.isArray(configuration.mailoTool.missingFiles)
                    ? configuration.mailoTool.missingFiles.slice()
                    : []
            };
        }

        if (configuration && configuration.defaultBrowserUrl) {
            defaultBrowserUrl = configuration.defaultBrowserUrl;
        }

        if (configuration && typeof configuration.browserToolbarHeight === "number" && configuration.browserToolbarHeight > 0) {
            browserToolbarHeight = configuration.browserToolbarHeight;
        }

        logBrowserWorkspace("CONFIGURE", {
            defaultUrl: defaultBrowserUrl,
            browserToolId: browserToolDefinition.id,
            browserToolbarHeight: browserToolbarHeight
        });

        renderToolButtons(Array.from(toolDefinitions.values()));
    };

    window.form3OpenBrowserPreview = function (url) {
        pendingBrowserNavigationUrl = typeof url === "string" && url.length > 0
            ? url
            : null;

        logBrowserWorkspace("HOST_PREVIEW_REQUEST", {
            url: pendingBrowserNavigationUrl || defaultBrowserUrl
        });

        openOrActivateTool(browserToolDefinition.id);
    };

    function applyForm3LoginState(state, shouldRefreshMessageBar) {
        form3LoginState = {
            hasValidSessionId: !!(state && state.hasValidSessionId),
            sessionId: state && typeof state.sessionId === "string" ? state.sessionId : "",
            loginWorkspaceVisible: !!(state && state.loginWorkspaceVisible)
        };

        updateLoginButtonState();
        updateWorkspaceVisibility();

        if (shouldRefreshMessageBar && messageText && state && typeof state.statusMessage === "string" && state.statusMessage.length > 0) {
            messageText.textContent = state.statusMessage;
        }

        scheduleLoginWorkspaceSync("login-state");
        scheduleButtonFit();
    }

    function updateLoginButtonState() {
        if (!loginButton) {
            return;
        }

        loginButton.classList.toggle("is-valid-session", form3LoginState.hasValidSessionId);
        loginButton.classList.toggle("is-missing-session", !form3LoginState.hasValidSessionId);
        loginButton.textContent = form3LoginState.hasValidSessionId ? "Session Ready" : "Get Session";
    }

    function renderToolButtons(tools) {
        if (!toolList) {
            return;
        }

        toolDefinitions.clear();
        toolList.innerHTML = "";

        tools.forEach(function (tool) {
            var toolId = tool.Id || tool.id;
            var label = tool.Label || tool.label;
            var workspaceType = tool.workspaceType || "native";
            var button = document.createElement("button");

            toolDefinitions.set(toolId, {
                id: toolId,
                label: label,
                workspaceType: workspaceType
            });

            button.className = "tool-button";
            button.type = "button";
            button.dataset.toolId = toolId;
            button.textContent = label;

            toolList.appendChild(button);
        });

        appendBrowserToolButton();

        syncTabTitles();
        syncActiveToolButton(getActiveTab() ? getActiveTab().toolId : null);
        updateWorkspaceVisibility();
        activateWorkspace(getActiveTab());
        renderTabs();
        scheduleButtonFit();
    }

    function appendBrowserToolButton() {
        if (!toolList || !browserToolDefinition) {
            return;
        }

        toolDefinitions.set(browserToolDefinition.id, {
            id: browserToolDefinition.id,
            label: browserToolDefinition.label,
            workspaceType: browserToolDefinition.workspaceType
        });

        var button = document.createElement("button");
        button.className = "tool-button";
        button.type = "button";
        button.dataset.toolId = browserToolDefinition.id;
        button.textContent = browserToolDefinition.label;
        toolList.appendChild(button);
    }

    function renderTabs() {
        if (!tabsBar) {
            logTabDrag("RENDER_SKIPPED", {
                reason: "tabsBar-selector-not-found"
            });
            return;
        }

        tabsBar.innerHTML = "";
        tabsBar.setAttribute("role", "tablist");
        logTabDrag("RENDER", {
            tabCount: tabState.items.length,
            order: formatTabOrder()
        });

        if (tabState.items.length === 0) {
            var emptyState = document.createElement("div");
            emptyState.className = "tabs-empty";
            emptyState.textContent = "No open tabs";
            tabsBar.appendChild(emptyState);
            logTabDrag("RENDER_EMPTY", {
                reason: "zero-tabs"
            });
            return;
        }

        tabState.items.forEach(function (tab) {
            var tabElement = document.createElement("div");
            var tabLabel = document.createElement("span");
            var closeButton = document.createElement("button");
            var isActive = tab.id === tabState.activeId;

            tabElement.className = "tab-button" + (isActive ? " is-active" : "");
            tabElement.dataset.tabId = tab.id;
            tabElement.setAttribute("role", "tab");
            tabElement.setAttribute("aria-selected", isActive ? "true" : "false");
            tabElement.tabIndex = isActive ? 0 : -1;

            tabLabel.className = "tab-label";
            tabLabel.textContent = tab.title;

            closeButton.className = "tab-close";
            closeButton.type = "button";
            closeButton.dataset.tabId = tab.id;
            closeButton.draggable = false;
            closeButton.setAttribute("aria-label", "Close " + tab.title);
            closeButton.textContent = "\u00D7";

            tabElement.appendChild(tabLabel);
            tabElement.appendChild(closeButton);
            tabsBar.appendChild(tabElement);
        });
    }

    function handleDocumentMouseMove(event) {
        if (!tabState.mouseDownCandidate && !tabState.dragActive) {
            return;
        }

        if (!tabState.dragActive && tabState.mouseDownCandidate) {
            if (!hasPrimaryButtonPressed(event)) {
                logTabDrag("DRAG_CANCEL", {
                    reason: "primary-button-released-before-threshold",
                    tab: formatTabIdentity(tabState.mouseDownCandidate.tabId),
                    x: event.clientX,
                    y: event.clientY
                });
                tabState.mouseDownCandidate = null;
                return;
            }

            if (!hasExceededDragThreshold(event)) {
                return;
            }

            beginTabDrag(event);
        }

        if (!tabState.dragActive) {
            return;
        }

        event.preventDefault();
        updateDropPreview(event.clientX, event.clientY);
        logHoverState(event);
    }

    function handleDocumentMouseUp(event) {
        if (tabState.dragActive) {
            logTabDrag("DROP", {
                source: formatTabIdentity(tabState.dragId),
                fromIndex: tabState.sourceIndex,
                hover: formatHoverIdentity(tabState.dropPreview),
                finalIndex: tabState.previewIndex !== null ? tabState.previewIndex : "n/a",
                valid: tabState.previewIndex !== null,
                insideStrip: isPointInsideExpandedTabsBar(event.clientX, event.clientY),
                x: event.clientX,
                y: event.clientY,
                targetRole: getEventTargetRole(event.target)
            });

            commitTabReorder();
            tabState.suppressClickUntil = Date.now() + 200;
            logTabDrag("DRAG_END", {
                source: formatTabIdentity(tabState.dragId),
                preview: formatHoverIdentity(tabState.dropPreview),
                order: formatTabOrder()
            });
            clearDragState();
            return;
        }

        if (tabState.mouseDownCandidate) {
            logTabDrag("DRAG_CANCEL", {
                reason: "drag-threshold-not-reached",
                tab: formatTabIdentity(tabState.mouseDownCandidate.tabId),
                x: event.clientX,
                y: event.clientY,
                targetRole: getEventTargetRole(event.target)
            });
            tabState.mouseDownCandidate = null;
        }
    }

    function beginTabDrag(event) {
        var candidate = tabState.mouseDownCandidate;
        var tabElement = candidate ? findTabElement(candidate.tabId) : null;

        if (!candidate || !tabElement) {
            logTabDrag("DRAG_START_BLOCKED", {
                reason: !candidate ? "missing-candidate" : "tab-element-not-found",
                targetRole: getEventTargetRole(event.target)
            });
            tabState.mouseDownCandidate = null;
            return;
        }

        tabState.dragId = candidate.tabId;
        tabState.dragActive = true;
        tabState.sourceIndex = candidate.sourceIndex;
        tabState.hoverTabId = candidate.tabId;
        tabState.previewIndex = candidate.sourceIndex;
        tabState.dropPreview = {
            targetId: candidate.tabId,
            hoverTabId: candidate.tabId,
            position: "self",
            insertIndex: candidate.sourceIndex
        };
        tabState.mouseDownCandidate = null;
        tabElement.classList.add("is-dragging");
        setDragVisualState(true);

        logTabDrag("DRAG_START", {
            tab: formatTabIdentity(tabState.dragId),
            sourceIndex: tabState.sourceIndex,
            visualIndex: getVisualIndexById(tabState.dragId),
            scrollLeft: tabsBar ? tabsBar.scrollLeft : 0,
            containerWidth: tabsBar ? tabsBar.clientWidth : 0,
            bounds: formatRect(tabElement.getBoundingClientRect()),
            x: event.clientX,
            y: event.clientY,
            targetRole: getEventTargetRole(event.target)
        });

        updateDropPreview(event.clientX, event.clientY);
        logHoverState(event);
    }

    function updateDropPreview(clientX, clientY) {
        var preview = getDropPreview(clientX, clientY);

        tabState.dropPreview = preview;
        tabState.previewIndex = preview ? preview.insertIndex : null;
        tabState.hoverTabId = preview ? preview.hoverTabId : null;
        clearDropIndicators();

        if (!preview || !preview.targetId || preview.targetId === tabState.dragId) {
            return;
        }

        var targetTab = findTabElement(preview.targetId);
        if (!targetTab) {
            return;
        }

        targetTab.classList.add(preview.position === "before" ? "drop-before" : "drop-after");
    }

    function hasExceededDragThreshold(event) {
        if (!tabState.mouseDownCandidate) {
            return false;
        }

        var deltaX = Math.abs(event.clientX - tabState.mouseDownCandidate.x);
        var deltaY = Math.abs(event.clientY - tabState.mouseDownCandidate.y);
        return deltaX >= 6 || deltaY >= 6;
    }

    function hasPrimaryButtonPressed(event) {
        if (typeof event.buttons === "number") {
            return (event.buttons & 1) === 1;
        }

        return true;
    }

    function commitTabReorder() {
        if (!tabState.dragId || tabState.previewIndex === null || tabState.previewIndex === undefined) {
            logTabDrag("REORDER_SKIPPED", {
                reason: !tabState.dragId ? "missing-drag-id" : "missing-preview-index",
                source: formatTabIdentity(tabState.dragId),
                preview: formatHoverIdentity(tabState.dropPreview)
            });
            return false;
        }

        var draggedTabId = tabState.dragId;
        var draggedTab = findTabById(draggedTabId);
        if (!draggedTab) {
            logTabDrag("REORDER_SKIPPED", {
                reason: "dragged-tab-not-found",
                source: formatTabIdentity(draggedTabId)
            });
            return false;
        }

        var activeTabBefore = getActiveTab();
        var modelBefore = formatTabOrder();
        var sourceIndex = tabState.sourceIndex >= 0 ? tabState.sourceIndex : getModelIndexById(draggedTabId);
        var reorderedItems = tabState.items.filter(function (item) {
            return item.id !== draggedTabId;
        });
        var insertIndex = tabState.previewIndex;

        if (insertIndex < 0) {
            insertIndex = 0;
        }

        if (insertIndex > reorderedItems.length) {
            insertIndex = reorderedItems.length;
        }

        logTabDrag("MODEL_BEFORE", {
            order: modelBefore
        });

        reorderedItems.splice(insertIndex, 0, draggedTab);
        var changed = !isSameOrder(tabState.items, reorderedItems);

        if (!changed) {
            logTabDrag("REORDER_SKIPPED", {
                reason: "same-position-drop",
                source: formatTabIdentity(draggedTabId),
                sourceIndex: sourceIndex,
                finalIndex: insertIndex,
                preview: formatHoverIdentity(tabState.dropPreview)
            });
        }

        tabState.items = reorderedItems;
        logTabDrag("MODEL_AFTER", {
            order: formatTabOrderFromItems(tabState.items),
            changed: changed,
            finalIndex: insertIndex
        });
        renderTabs();
        updateWorkspaceVisibility();
        activateWorkspace(getActiveTab());
        logTabDrag("ACTIVE_MAPPING", {
            mappingMode: "stable-id",
            activeBefore: activeTabBefore ? formatTabIdentity(activeTabBefore.id) : "none",
            activeAfter: getActiveTab() ? formatTabIdentity(getActiveTab().id) : "none",
            contentBefore: activeTabBefore ? activeTabBefore.panelId : "none",
            contentAfter: getActiveTab() ? getActiveTab().panelId : "none",
            rerendered: true
        });
        scheduleButtonFit();
        return changed;
    }

    function getDropPreview(clientX, clientY) {
        if (!tabsBar) {
            return null;
        }

        if (!isPointInsideExpandedTabsBar(clientX, clientY)) {
            return null;
        }

        var candidateTabs = Array.from(tabsBar.querySelectorAll(".tab-button")).filter(function (tab) {
            return tab.dataset.tabId !== tabState.dragId;
        });

        if (candidateTabs.length === 0) {
            return {
                targetId: null,
                hoverTabId: null,
                position: "after",
                insertIndex: 0
            };
        }

        for (var i = 0; i < candidateTabs.length; i += 1) {
            var tab = candidateTabs[i];
            var bounds = tab.getBoundingClientRect();
            var midpoint = bounds.left + (bounds.width / 2);

            if (clientX < midpoint) {
                return {
                    targetId: tab.dataset.tabId,
                    hoverTabId: tab.dataset.tabId,
                    position: "before",
                    insertIndex: i
                };
            }
        }

        return {
            targetId: candidateTabs[candidateTabs.length - 1].dataset.tabId,
            hoverTabId: candidateTabs[candidateTabs.length - 1].dataset.tabId,
            position: "after",
            insertIndex: candidateTabs.length
        };
    }

    function clearDropIndicators() {
        if (!tabsBar) {
            return;
        }

        tabsBar.querySelectorAll(".tab-button").forEach(function (tab) {
            tab.classList.remove("drop-before", "drop-after");
        });
    }

    function clearDragState() {
        if (tabState.mouseDownCandidate && !tabState.dragActive) {
            logTabDrag("DRAG_CANCEL", {
                reason: "state-cleared-before-dragstart",
                tab: formatTabIdentity(tabState.mouseDownCandidate.tabId)
            });
        }

        tabState.dragId = null;
        tabState.dragActive = false;
        tabState.sourceIndex = -1;
        tabState.hoverTabId = null;
        tabState.previewIndex = null;
        tabState.dropPreview = null;
        tabState.mouseDownCandidate = null;
        clearDropIndicators();
        setDragVisualState(false);

        if (!tabsBar) {
            return;
        }

        tabsBar.querySelectorAll(".tab-button").forEach(function (tab) {
            tab.classList.remove("is-dragging");
        });
    }

    function findTabByToolId(toolId) {
        return tabState.items.find(function (item) {
            return item.toolId === toolId;
        }) || null;
    }

    function findTabById(tabId) {
        return tabState.items.find(function (item) {
            return item.id === tabId;
        }) || null;
    }

    function findTabElement(tabId) {
        return tabsBar ? tabsBar.querySelector(".tab-button[data-tab-id='" + tabId + "']") : null;
    }

    function getActiveTab() {
        return findTabById(tabState.activeId);
    }

    function syncTabTitles() {
        tabState.items.forEach(function (tab) {
            if (toolDefinitions.has(tab.toolId)) {
                tab.title = toolDefinitions.get(tab.toolId).label;
            }
        });
    }

    function updateWorkspaceVisibility() {
        var hasActiveTab = !!getActiveTab();
        var loginWorkspaceVisible = !!form3LoginState.loginWorkspaceVisible;

        if (loginWorkspaceAnchor) {
            loginWorkspaceAnchor.classList.toggle("is-visible", loginWorkspaceVisible);
        }

        if (workspaceEmpty) {
            workspaceEmpty.style.display = !loginWorkspaceVisible && !hasActiveTab ? "flex" : "none";
        }

        if (workspaceHost) {
            workspaceHost.classList.toggle("has-workspace", !loginWorkspaceVisible && hasActiveTab);
        }

        if (!loginWorkspaceVisible && !hasActiveTab) {
            if (messageText) {
                messageText.textContent = emptyMessage;
            }

            if (contentKicker) {
                contentKicker.textContent = "Active Tab";
            }

            if (contentTitle) {
                contentTitle.textContent = emptyContentTitle;
            }

            if (contentBody) {
                contentBody.textContent = emptyContentBody;
            }
        }

        scheduleLoginWorkspaceSync("update-workspace-visibility");
        scheduleCopyCatWorkspaceSync("update-workspace-visibility");
        scheduleWgcWorkspaceSync("update-workspace-visibility");
        scheduleBrowserWorkspaceSync("update-workspace-visibility");
    }

    function createWorkspacePanel(tab) {
        if (!workspaceHost || findWorkspacePanel(tab.panelId)) {
            return;
        }

        var panel = document.createElement("section");
        panel.className = "workspace-panel";
        panel.dataset.tabId = tab.id;
        panel.id = tab.panelId;

        if (tab.workspaceType === "browser") {
            panel.classList.add("browser-workspace");
            panel.appendChild(createBrowserNativeLayout("Browser Workspace", "The native WebView2 browser is attached here and loads " + defaultBrowserUrl + ".", "browser"));
            logBrowserWorkspace("VIEW_CREATE", {
                tab: formatTabIdentity(tab.id),
                panelId: tab.panelId
            });
        } else if (tab.toolId === "copycat") {
            createCopyCatWorkspacePanel(panel, tab);
        } else if (tab.workspaceType === "wgc-placeholder") {
            createWgcWorkspacePanel(panel, tab);
        } else if (tab.workspaceType === "mailo-v2") {
            createMailoWorkspacePanel(panel, tab);
        } else if (tab.workspaceType === "alev-reward-json") {
            createAlevRewardWorkspacePanel(panel, tab);
        } else if (tab.workspaceType === "cooldown-simulator") {
            createCooldownSimulatorWorkspacePanel(panel, tab);
        } else {
            var body = document.createElement("div");
            var heading = document.createElement("h3");
            var text = document.createElement("p");

            body.className = "workspace-native-body";
            heading.textContent = tab.title + " Workspace";
            text.textContent = "This tab is linked to the matching Form2 interface. Selecting the tab will activate the tool while keeping the tab order independent from workspace content ordering.";

            body.appendChild(heading);
            body.appendChild(text);
            panel.classList.add("workspace-native");
            panel.appendChild(body);
        }

        workspaceHost.appendChild(panel);
        scheduleCopyCatWorkspaceSync("create-workspace-panel");
        scheduleWgcWorkspaceSync("create-workspace-panel");
        scheduleBrowserWorkspaceSync("create-workspace-panel");
    }

    function activateWorkspace(tab) {
        if (!workspaceHost) {
            return;
        }

        var panels = workspaceHost.querySelectorAll(".workspace-panel");

        panels.forEach(function (panel) {
            panel.classList.remove("is-active");
        });

        if (!tab) {
            return;
        }

        var panel = findWorkspacePanel(tab.panelId);
        if (!panel) {
            createWorkspacePanel(tab);
            panel = findWorkspacePanel(tab.panelId);
        }

        if (panel) {
            panel.classList.add("is-active");
            if (tab.workspaceType === "mailo-v2") {
                syncEmbeddedWorkspaceThemes(root.getAttribute("data-theme") || "dark");
            } else if (tab.workspaceType === "alev-reward-json") {
                updateAlevRewardWorkspacePanel(panel);
            } else if (tab.workspaceType === "cooldown-simulator") {
                updateCooldownSimulatorWorkspacePanel(panel);
            }
        }

        logBrowserWorkspace("ACTIVATE", {
            tab: tab ? formatTabIdentity(tab.id) : "none",
            workspaceType: tab ? tab.workspaceType : "none",
            panelId: tab ? tab.panelId : "none"
        });
        scheduleLoginWorkspaceSync("activate-workspace");
        scheduleCopyCatWorkspaceSync("activate-workspace");
        scheduleWgcWorkspaceSync("activate-workspace");
        scheduleBrowserWorkspaceSync("activate-workspace");

        if (messageText) {
            if (tab.workspaceType === "browser") {
                messageText.textContent = tab.title + " is active. Reorder or close the tab without breaking its browser workspace.";
            } else if (tab.toolId === "copycat") {
                messageText.textContent = tab.title + " is active in a native Form3 workspace with a WinForms splitter-managed browser and Preset Window.";
            } else if (tab.workspaceType === "wgc-placeholder") {
                messageText.textContent = tab.title + " is active in a docked native Form3 workspace. The original Form2 WGC implementation remains unchanged.";
            } else if (tab.workspaceType === "mailo-v2") {
                messageText.textContent = tab.title + " is active in the Form3 HTML workspace. The native Mailo tool in Form2 remains unchanged.";
            } else if (tab.workspaceType === "alev-reward-json") {
                messageText.textContent = tab.title + " is active in a focused Form3 workspace for reward JSON generation.";
            } else if (tab.workspaceType === "cooldown-simulator") {
                messageText.textContent = tab.title + " is active in the Form3 HTML workspace. CSV selection currently round-trips through the native host.";
            } else {
                messageText.textContent = tab.title + " is active. Drag tabs to reorder them or use the close button to dismiss one.";
            }
        }
    }

    function disposeWorkspace(tab) {
        if (!tab) {
            return;
        }

        if (tab.workspaceType === "browser") {
            logBrowserWorkspace("VIEW_CLOSE", {
                tab: formatTabIdentity(tab.id),
                panelId: tab.panelId
            });
            postBrowserWorkspaceState("close", tab, null, "dispose-workspace");
        } else if (tab.toolId === "copycat") {
            postCopyCatWorkspaceState("close", tab, null, "dispose-workspace");
        } else if (tab.workspaceType === "wgc-placeholder") {
            postWgcWorkspaceState("close", tab, null, "dispose-workspace");
        } else if (tab.workspaceType === "mailo-v2") {
            postMailoWorkspaceState("close", tab, null, "dispose-workspace");
        }

        var panel = findWorkspacePanel(tab.panelId);
        if (!panel) {
            return;
        }

        panel.remove();
    }

    function findWorkspacePanel(panelId) {
        return workspaceHost ? workspaceHost.querySelector("#" + panelId) : null;
    }

    function createMailoWorkspacePanel(panel, tab) {
        var config = getMailoWorkspaceConfiguration(tab.toolId);

        panel.classList.add("workspace-html", "workspace-mailo");

        if (!config || !config.available || !config.url) {
            panel.appendChild(createHtmlWorkspaceError(tab, config));
            return;
        }

        var frame = document.createElement("iframe");
        frame.className = "workspace-html-frame";
        frame.dataset.toolId = tab.toolId;
        frame.dataset.workspaceType = tab.workspaceType;
        frame.setAttribute("title", tab.title + " workspace");
        frame.setAttribute("loading", "eager");
        frame.src = config.url;
        frame.addEventListener("load", function () {
            syncEmbeddedWorkspaceFrameTheme(frame, root.getAttribute("data-theme") || "dark");
            postMailoStateToFrames();
        });
        panel.appendChild(frame);
    }

    function createCopyCatWorkspacePanel(panel, tab) {
        var body = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");

        panel.classList.add("workspace-copycat");
        body.className = "workspace-native-body workspace-copycat-native";
        body.setAttribute("data-role", "copycat-native-anchor");
        heading.textContent = tab.title + " Workspace";
        text.textContent = "This CopyCat workflow now opens in a separate native window. Form3 stays visible while the CopyCat browser and Preset Window run outside the HTML workspace.";
        body.appendChild(heading);
        body.appendChild(text);
        panel.appendChild(body);

        logCopyCatWorkspaceSnapshot("WORKSPACE_CREATED", panel, {
            panelId: panel.id || ""
        });
        scheduleCopyCatWorkspaceSync("create-copycat-workspace");
    }

    function createWgcWorkspacePanel(panel, tab) {
        var body = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");

        panel.classList.add("workspace-native");
        body.className = "workspace-native-body";
        heading.textContent = tab.title + " Workspace";
        text.textContent = "Loading the docked native WGC workspace.";

        body.appendChild(heading);
        body.appendChild(text);
        panel.appendChild(body);
    }

    function scheduleWgcWorkspaceSync(reason) {
        window.requestAnimationFrame(function () {
            syncWgcWorkspace(reason);
        });
    }

    function syncWgcWorkspace(reason) {
        var activeTab = getActiveTab();
        var panel = activeTab ? findWorkspacePanel(activeTab.panelId) : null;

        if (form3LoginState.loginWorkspaceVisible || !activeTab || activeTab.workspaceType !== "wgc-placeholder" || !panel) {
            postWgcWorkspaceState("hide", activeTab, null, reason);
            return;
        }

        postWgcWorkspaceState("show", activeTab, getWgcWorkspaceBounds(panel), reason);
    }

    function getWgcWorkspaceBounds(panel) {
        if (!panel) {
            return null;
        }

        var rect = panel.getBoundingClientRect();
        var viewportMetrics = getHostViewportMetrics(panel);
        return {
            left: Math.round(rect.left),
            top: Math.round(rect.top),
            width: Math.round(rect.width),
            height: Math.round(rect.height),
            devicePixelRatio: window.devicePixelRatio || 1,
            viewportWidth: viewportMetrics.width,
            viewportHeight: viewportMetrics.height
        };
    }

    function postWgcWorkspaceState(action, tab, bounds, reason) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "wgcWorkspaceState",
            action: action,
            reason: reason,
            tabId: tab ? tab.id : null,
            toolId: tab ? tab.toolId : null,
            bounds: bounds
        });
    }

    function createBrowserNativeLayout(title, description, variant) {
        var layout = document.createElement("div");
        var toolbarHost = document.createElement("div");
        var contentHost = document.createElement("div");
        var placeholder = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");

        layout.className = "browser-native-layout";
        toolbarHost.className = "browser-native-toolbar-host";
        toolbarHost.setAttribute("data-role", "browser-toolbar-host");
        toolbarHost.style.height = browserToolbarHeight + "px";

        contentHost.className = "browser-native-content-host";
        contentHost.setAttribute("data-role", variant === "copycat" ? "copycat-browser-anchor" : "browser-content-host");

        placeholder.className = "browser-workspace-placeholder";
        heading.textContent = title;
        text.textContent = description;
        placeholder.appendChild(heading);
        placeholder.appendChild(text);
        contentHost.appendChild(placeholder);

        layout.appendChild(toolbarHost);
        layout.appendChild(contentHost);
        return layout;
    }

    function createAlevRewardWorkspacePanel(panel, tab) {
        var body = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");
        var toolbar = document.createElement("div");
        var addButton = document.createElement("button");
        var generateButton = document.createElement("button");
        var saveButton = document.createElement("button");
        var loadBaseButton = document.createElement("button");
        var loadTranslationsButton = document.createElement("button");
        var generateFinalButton = document.createElement("button");
        var saveFinalButton = document.createElement("button");
        var entriesContainer = document.createElement("div");
        var baseStatusDisplay = document.createElement("div");
        var translationStatusDisplay = document.createElement("div");
        var statusDisplay = document.createElement("div");
        var outputLabel = document.createElement("label");
        var outputArea = document.createElement("textarea");
        var finalOutputLabel = document.createElement("label");
        var finalOutputArea = document.createElement("textarea");

        panel.classList.add("workspace-native", "workspace-alev-reward");
        body.className = "workspace-native-body workspace-alev-reward-xml";
        panel._alevRewardEntries = [createDefaultAlevRewardEntry()];

        heading.textContent = tab.title;
        text.textContent = "Generate reward XML for the web tool, then load the web-tool LevelData JSON and replace only its translations.";

        toolbar.className = "alev-reward-toolbar";
        addButton.className = "tool-button";
        addButton.type = "button";
        addButton.textContent = "Add reward";
        addButton.addEventListener("click", function () {
            panel._alevRewardEntries.push(createDefaultAlevRewardEntry());
            renderAlevRewardEntries(panel);
            scheduleButtonFit();
        });

        generateButton.className = "tool-button";
        generateButton.type = "button";
        generateButton.textContent = "Generate XML";
        generateButton.addEventListener("click", function () {
            postAlevRewardAction("generate-xml", {
                entries: collectAlevRewardEntries(panel),
                outputXml: outputArea.value || ""
            });
        });

        saveButton.className = "tool-button";
        saveButton.type = "button";
        saveButton.textContent = "Save XML";
        saveButton.addEventListener("click", function () {
            postAlevRewardAction("save-xml", {
                outputXml: outputArea.value || ""
            });
        });

        loadTranslationsButton.className = "tool-button";
        loadTranslationsButton.type = "button";
        loadTranslationsButton.textContent = "Load Translations XLSX";
        loadTranslationsButton.addEventListener("click", function () {
            logAlevLocalizationDebug("JS load-translations clicked", {
                hasOutputXml: !!(outputArea.value || "")
            });
            postAlevRewardAction("load-translations", {
                outputXml: outputArea.value || ""
            });
        });

        loadBaseButton.className = "tool-button";
        loadBaseButton.type = "button";
        loadBaseButton.textContent = "Load Base LevelData JSON";
        loadBaseButton.addEventListener("click", function () {
            logAlevLocalizationDebug("JS load-base-leveldata clicked");
            postAlevRewardAction("load-base-leveldata");
        });

        generateFinalButton.className = "tool-button";
        generateFinalButton.type = "button";
        generateFinalButton.textContent = "Generate Export JSON";
        generateFinalButton.addEventListener("click", function () {
            postAlevRewardAction("generate-final-json");
        });

        saveFinalButton.className = "tool-button";
        saveFinalButton.type = "button";
        saveFinalButton.textContent = "Save Export JSON";
        saveFinalButton.addEventListener("click", function () {
            postAlevRewardAction("save-final-json", {
                finalOutputJson: finalOutputArea.value || ""
            });
        });

        toolbar.appendChild(addButton);
        toolbar.appendChild(generateButton);
        toolbar.appendChild(saveButton);
        toolbar.appendChild(loadBaseButton);
        toolbar.appendChild(loadTranslationsButton);
        toolbar.appendChild(generateFinalButton);
        toolbar.appendChild(saveFinalButton);

        entriesContainer.className = "alev-reward-entries";
        entriesContainer.setAttribute("data-role", "alev-reward-entries");

        baseStatusDisplay.className = "alev-reward-status";
        baseStatusDisplay.setAttribute("data-role", "alev-reward-base-status");

        translationStatusDisplay.className = "alev-reward-status";
        translationStatusDisplay.setAttribute("data-role", "alev-reward-translation-status");

        statusDisplay.className = "alev-reward-status";
        statusDisplay.setAttribute("data-role", "alev-reward-status");

        outputLabel.className = "alev-reward-output-label";
        outputLabel.textContent = "Generated reward XML";
        outputLabel.htmlFor = panel.id + "-output";

        outputArea.id = panel.id + "-output";
        outputArea.className = "alev-reward-output";
        outputArea.spellcheck = false;
        outputArea.setAttribute("data-role", "alev-reward-output");

        finalOutputLabel.className = "alev-reward-output-label";
        finalOutputLabel.textContent = "Final export JSON";
        finalOutputLabel.htmlFor = panel.id + "-final-output";

        finalOutputArea.id = panel.id + "-final-output";
        finalOutputArea.className = "alev-reward-output alev-reward-final-output";
        finalOutputArea.spellcheck = false;
        finalOutputArea.setAttribute("data-role", "alev-reward-final-output");

        body.appendChild(heading);
        body.appendChild(text);
        body.appendChild(toolbar);
        body.appendChild(entriesContainer);
        body.appendChild(baseStatusDisplay);
        body.appendChild(translationStatusDisplay);
        body.appendChild(statusDisplay);
        body.appendChild(outputLabel);
        body.appendChild(outputArea);
        body.appendChild(finalOutputLabel);
        body.appendChild(finalOutputArea);
        panel.appendChild(body);

        postAlevRewardAction("request-state");
        updateAlevRewardWorkspacePanel(panel);
    }

    function updateAlevRewardWorkspacePanels() {
        if (!workspaceHost) {
            return;
        }

        workspaceHost.querySelectorAll(".workspace-panel").forEach(function (panel) {
            var tab = findTabById(panel.dataset.tabId);
            if (tab && tab.workspaceType === "alev-reward-json") {
                updateAlevRewardWorkspacePanel(panel);
            }
        });
    }

    function updateAlevRewardWorkspacePanel(panel) {
        if (!panel) {
            return;
        }

        if (!Array.isArray(panel._alevRewardEntries) || panel._alevRewardEntries.length === 0) {
            panel._alevRewardEntries = [createDefaultAlevRewardEntry()];
        }

        renderAlevRewardEntries(panel);

        var outputArea = panel.querySelector("[data-role='alev-reward-output']");
        if (outputArea && document.activeElement !== outputArea) {
            outputArea.value = currentAlevRewardState.outputXml || "";
        }

        var finalOutputArea = panel.querySelector("[data-role='alev-reward-final-output']");
        if (finalOutputArea && document.activeElement !== finalOutputArea) {
            finalOutputArea.value = currentAlevRewardState.finalOutputJson || "";
        }

        var baseStatusDisplay = panel.querySelector("[data-role='alev-reward-base-status']");
        if (baseStatusDisplay) {
            var baseState = currentAlevRewardState.baseLevelData || {};
            var baseMessage = formatAlevRewardBaseStatus(baseState);
            baseStatusDisplay.textContent = baseMessage;
            baseStatusDisplay.style.display = baseMessage.length > 0 ? "block" : "none";
            baseStatusDisplay.classList.toggle("is-error", !!baseState.statusIsError);
        }

        var translationStatusDisplay = panel.querySelector("[data-role='alev-reward-translation-status']");
        if (translationStatusDisplay) {
            var importState = currentAlevRewardState.translationImport || {};
            var translationMessage = formatAlevRewardTranslationStatus(importState);
            translationStatusDisplay.textContent = translationMessage;
            translationStatusDisplay.style.display = translationMessage.length > 0 ? "block" : "none";
            translationStatusDisplay.classList.toggle("is-error", !!importState.statusIsError);
        }

        var statusDisplay = panel.querySelector("[data-role='alev-reward-status']");
        if (statusDisplay) {
            var statusMessage = currentAlevRewardState.statusMessage || "";
            statusDisplay.textContent = statusMessage;
            statusDisplay.style.display = statusMessage.length > 0 ? "block" : "none";
            statusDisplay.classList.toggle("is-error", !!currentAlevRewardState.statusIsError);
        }
    }

    function formatAlevRewardBaseStatus(baseState) {
        if (!baseState) {
            return "";
        }

        var parts = [];
        if (baseState.statusMessage) {
            parts.push(baseState.statusMessage);
        }

        if (baseState.fileName) {
            parts.push("File: " + baseState.fileName);
        }

        if (typeof baseState.entryCount === "number" && baseState.entryCount > 0) {
            parts.push("Entries: " + baseState.entryCount);
        }

        if (Array.isArray(baseState.entries) && baseState.entries.length > 0) {
            parts.push("Tokens: " + baseState.entries.map(function (entry) {
                return entry.displayName || entry.token || ("Entry " + ((entry.index || 0) + 1));
            }).join(", "));
        }

        if (typeof baseState.translationCount === "number") {
            parts.push("Existing translations: " + baseState.translationCount);
        }

        if (baseState.rewardFile) {
            parts.push("reward_file: " + baseState.rewardFile);
        }

        if (baseState.rewardPayloadType) {
            parts.push("Reward: " + baseState.rewardPayloadType);
        }

        return parts.join(" | ");
    }

    function formatAlevRewardTranslationStatus(importState) {
        if (!importState) {
            return "";
        }

        var parts = [];
        if (importState.statusMessage) {
            parts.push(importState.statusMessage);
        }

        if (importState.fileName) {
            parts.push("File: " + importState.fileName);
        }

        if (importState.worksheetName) {
            parts.push("Worksheet: " + importState.worksheetName);
        }

        if (importState.startRow) {
            parts.push("Start row: " + importState.startRow);
        }

        if (typeof importState.languageCount === "number") {
            parts.push("Languages: " + importState.languageCount);
        }

        if (Array.isArray(importState.entries) && importState.entries.length > 1) {
            parts.push("Mapped: " + importState.entries.map(function (entry) {
                var label = entry.displayName || entry.token || ("Entry " + ((entry.index || 0) + 1));
                var row = entry.startRow ? "row " + entry.startRow : "row ?";
                var count = typeof entry.languageCount === "number" ? entry.languageCount : 0;
                return label + " (" + row + ", " + count + " languages)";
            }).join("; "));
        }

        return parts.join(" | ");
    }

    function renderAlevRewardEntries(panel) {
        var container = panel ? panel.querySelector("[data-role='alev-reward-entries']") : null;
        if (!container) {
            return;
        }

        container.innerHTML = "";
        panel._alevRewardEntries.forEach(function (entry, index) {
            var card = document.createElement("div");
            var header = document.createElement("div");
            var title = document.createElement("div");
            var typeSelect = document.createElement("select");
            var removeButton = document.createElement("button");
            var fieldsContainer = document.createElement("div");
            var definition = getAlevRewardTypeDefinition(entry.type);
            var fields = getAlevRewardFields(definition);

            card.className = "alev-reward-card";
            header.className = "alev-reward-card-header";
            title.className = "alev-reward-card-title";
            title.textContent = "Reward " + (index + 1);

            typeSelect.className = "alev-reward-type";
            getAlevRewardTypeDefinitions().forEach(function (typeDefinition) {
                var option = document.createElement("option");
                var typeName = getAlevRewardTypeName(typeDefinition);
                option.value = typeName;
                option.textContent = typeName;
                typeSelect.appendChild(option);
            });
            typeSelect.value = entry.type || getDefaultAlevRewardTypeName();
            typeSelect.addEventListener("change", function () {
                panel._alevRewardEntries[index] = createDefaultAlevRewardEntry(typeSelect.value);
                renderAlevRewardEntries(panel);
            });

            removeButton.className = "alev-reward-remove";
            removeButton.type = "button";
            removeButton.textContent = "\u00D7";
            removeButton.title = "Remove reward";
            removeButton.setAttribute("aria-label", "Remove reward " + (index + 1));
            removeButton.disabled = panel._alevRewardEntries.length <= 1;
            removeButton.addEventListener("click", function () {
                if (panel._alevRewardEntries.length <= 1) {
                    return;
                }

                panel._alevRewardEntries.splice(index, 1);
                renderAlevRewardEntries(panel);
            });

            header.appendChild(title);
            header.appendChild(typeSelect);
            header.appendChild(removeButton);
            card.appendChild(header);

            fieldsContainer.className = "alev-reward-fields";
            if (fields.length === 0) {
                var emptyFields = document.createElement("div");
                emptyFields.className = "alev-reward-empty-fields";
                emptyFields.textContent = "This reward type has no parameters in the legacy ALEV reward editor.";
                fieldsContainer.appendChild(emptyFields);
            } else {
                fields.forEach(function (field) {
                    fieldsContainer.appendChild(createAlevRewardField(panel, entry, field));
                });
            }

            card.appendChild(fieldsContainer);
            container.appendChild(card);
        });
    }

    function createAlevRewardField(panel, entry, field) {
        var row = document.createElement("label");
        var caption = document.createElement("span");
        var input = null;
        var fieldName = getAlevRewardFieldName(field);
        var fieldType = getAlevRewardFieldInputType(field);
        var value = entry.params && Object.prototype.hasOwnProperty.call(entry.params, fieldName)
            ? entry.params[fieldName]
            : getAlevRewardDefaultFieldValue(field);

        if (!entry.params) {
            entry.params = {};
        }

        if (fieldName && !Object.prototype.hasOwnProperty.call(entry.params, fieldName)) {
            entry.params[fieldName] = value;
        }

        row.className = "alev-reward-field";
        caption.textContent = fieldName;

        if (fieldType === "combo") {
            input = document.createElement("select");
            getAlevRewardFieldOptions(field).forEach(function (optionValue) {
                var option = document.createElement("option");
                option.value = optionValue;
                option.textContent = optionValue;
                input.appendChild(option);
            });
            input.value = value || getAlevRewardDefaultFieldValue(field);
        } else {
            input = document.createElement("input");
            input.type = fieldType === "numeric" ? "number" : fieldType === "datetime" ? "datetime-local" : "text";
            input.value = fieldType === "datetime" ? toDateTimeLocalValue(value) : value;
            if (fieldType === "numeric") {
                input.step = "1";
            } else if (fieldType === "datetime") {
                input.title = "Saved as UTC yyyy-MM-dd HH:mm:ss, matching the legacy reward editor output.";
            }
        }

        input.addEventListener("input", function () {
            entry.params[fieldName] = fieldType === "datetime"
                ? fromDateTimeLocalValue(input.value)
                : input.value;
        });
        input.addEventListener("change", function () {
            entry.params[fieldName] = fieldType === "datetime"
                ? fromDateTimeLocalValue(input.value)
                : input.value;
        });

        row.appendChild(caption);
        row.appendChild(input);
        return row;
    }

    function collectAlevRewardEntries(panel) {
        if (!panel || !Array.isArray(panel._alevRewardEntries)) {
            return [];
        }

        return panel._alevRewardEntries.map(function (entry) {
            return {
                type: entry.type || getDefaultAlevRewardTypeName(),
                params: Object.assign({}, entry.params || {})
            };
        });
    }

    function createDefaultAlevRewardEntry(typeName) {
        var selectedType = typeName || getDefaultAlevRewardTypeName();
        var definition = getAlevRewardTypeDefinition(selectedType);
        var params = {};

        getAlevRewardFields(definition).forEach(function (field) {
            params[getAlevRewardFieldName(field)] = getAlevRewardDefaultFieldValue(field);
        });

        return {
            type: selectedType,
            params: params
        };
    }

    function getAlevRewardTypeDefinitions() {
        return currentAlevRewardState && Array.isArray(currentAlevRewardState.rewardTypes)
            ? currentAlevRewardState.rewardTypes
            : [];
    }

    function getAlevRewardTypeDefinition(typeName) {
        return getAlevRewardTypeDefinitions().find(function (definition) {
            return getAlevRewardTypeName(definition).toLowerCase() === String(typeName || "").toLowerCase();
        }) || null;
    }

    function getDefaultAlevRewardTypeName() {
        var addDefinition = getAlevRewardTypeDefinition("Add");
        if (addDefinition) {
            return getAlevRewardTypeName(addDefinition);
        }

        var definitions = getAlevRewardTypeDefinitions();
        return definitions.length > 0 ? getAlevRewardTypeName(definitions[0]) : "Add";
    }

    function getAlevRewardTypeName(definition) {
        return definition && (definition.Name || definition.name)
            ? String(definition.Name || definition.name)
            : "";
    }

    function getAlevRewardFields(definition) {
        if (!definition) {
            return [];
        }

        if (Array.isArray(definition.Fields)) {
            return definition.Fields;
        }

        return Array.isArray(definition.fields) ? definition.fields : [];
    }

    function getAlevRewardFieldName(field) {
        return field && (field.Name || field.name)
            ? String(field.Name || field.name)
            : "";
    }

    function getAlevRewardFieldInputType(field) {
        return field && (field.InputType || field.inputType)
            ? String(field.InputType || field.inputType)
            : "text";
    }

    function getAlevRewardFieldOptions(field) {
        if (!field) {
            return [];
        }

        if (Array.isArray(field.Options)) {
            return field.Options;
        }

        return Array.isArray(field.options) ? field.options : [];
    }

    function getAlevRewardDefaultFieldValue(field) {
        var fieldType = getAlevRewardFieldInputType(field);
        var options = getAlevRewardFieldOptions(field);

        if (fieldType === "combo") {
            return options.length > 0 ? options[0] : "";
        }

        if (fieldType === "numeric") {
            return "0";
        }

        return "";
    }

    function toDateTimeLocalValue(value) {
        if (!value || typeof value !== "string") {
            return "";
        }

        var normalized = value.trim().replace(" ", "T");
        return normalized.length >= 16 ? normalized.substring(0, 16) : "";
    }

    function fromDateTimeLocalValue(value) {
        if (!value || typeof value !== "string") {
            return "";
        }

        var date = new Date(value);
        if (Number.isNaN(date.getTime())) {
            return value;
        }

        return date.getUTCFullYear() + "-" +
            padAlevRewardDatePart(date.getUTCMonth() + 1) + "-" +
            padAlevRewardDatePart(date.getUTCDate()) + " " +
            padAlevRewardDatePart(date.getUTCHours()) + ":" +
            padAlevRewardDatePart(date.getUTCMinutes()) + ":" +
            padAlevRewardDatePart(date.getUTCSeconds());
    }

    function padAlevRewardDatePart(value) {
        return String(value).padStart(2, "0");
    }

    function postAlevRewardAction(action, extra) {
        try {
            logAlevLocalizationDebug("JS postAlevRewardAction started", {
                action: action || "",
                hasExtra: !!extra
            });
            if (!window.chrome || !window.chrome.webview) {
                logAlevLocalizationDebug("JS postAlevRewardAction skipped: webview bridge missing", {
                    action: action || ""
                });
                return;
            }

            window.chrome.webview.postMessage(Object.assign({
                type: "alevRewardAction",
                action: action
            }, extra || {}));
            logAlevLocalizationDebug("JS postAlevRewardAction completed", {
                action: action || ""
            });
        } catch (error) {
            logAlevLocalizationDebug("JS postAlevRewardAction failed", {
                action: action || "",
                error: error && error.message ? error.message : String(error || "")
            });
        }
    }

    function logAlevLocalizationDebug(stage, detail) {
        var detailText = "";
        try {
            detailText = detail === undefined ? "" : JSON.stringify(detail);
        } catch (error) {
            detailText = String(detail || "");
        }

        try {
            if (window.console && typeof window.console.log === "function") {
                window.console.log(alevLocalizationDebugPrefix + " " + stage + (detailText ? " " + detailText : ""));
            }
        } catch (error) {
        }

        try {
            if (window.chrome && window.chrome.webview) {
                window.chrome.webview.postMessage({
                    type: "alevLocalizationDebug",
                    stage: stage || "",
                    detail: detailText
                });
            }
        } catch (error) {
        }
    }

    function createCooldownSimulatorWorkspacePanel(panel, tab) {
        var body = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");
        var selectButton = document.createElement("button");
        var saveStateButton = document.createElement("button");
        var resetStateButton = document.createElement("button");
        var analyzeButton = document.createElement("button");
        var analyzeSuggestedButton = document.createElement("button");
        var analyzeNoExpiredButton = document.createElement("button");
        var improveDelaysButton = document.createElement("button");
        var priorityProcessButton = document.createElement("button");
        var exportButton = document.createElement("button");
        var ganttButton = document.createElement("button");
        var sendToJiraButton = document.createElement("button");
        var actionToolbar = document.createElement("div");
        var selectionDisplay = document.createElement("div");
        var errorDisplay = document.createElement("div");
        var controlsContainer = document.createElement("div");
        var channelsContainer = document.createElement("div");
        var visibleColumnsContainer = document.createElement("div");
        var validationSummaryContainer = document.createElement("div");
        var validationTableContainer = document.createElement("div");
        var optimizationSummaryContainer = document.createElement("div");
        var analysisModeDisplay = document.createElement("div");
        var resultsErrorDisplay = document.createElement("div");
        var resultsWarningDisplay = document.createElement("div");
        var exportStatusDisplay = document.createElement("div");
        var resultsContainer = document.createElement("div");

        body.className = "workspace-native-body workspace-cooldown-simulator";
        heading.textContent = tab.title;
        text.textContent = "Select a CSV file or saved Cooldown Simulator state to start.";
        selectButton.className = "tool-button";
        selectButton.type = "button";
        selectButton.textContent = "Select CSV / Load state";
        selectButton.addEventListener("click", function () {
            postCooldownSimulatorAction("select-csv");
        });
        saveStateButton.className = "tool-button";
        saveStateButton.type = "button";
        saveStateButton.textContent = "Save state";
        saveStateButton.setAttribute("data-role", "cooldown-simulator-save-state");
        saveStateButton.addEventListener("click", function () {
            postCooldownSimulatorAction("save-working-state", collectSelectedCooldownSimulatorChannels(panel));
        });
        resetStateButton.className = "tool-button";
        resetStateButton.type = "button";
        resetStateButton.textContent = "Reset";
        resetStateButton.setAttribute("data-role", "cooldown-simulator-reset-state");
        resetStateButton.addEventListener("click", function () {
            if (!window.confirm("Reset current Cooldown Simulator work to imported state?")) {
                return;
            }

            postCooldownSimulatorAction("reset-working-state", collectSelectedCooldownSimulatorChannels(panel));
        });
        analyzeButton.className = "tool-button";
        analyzeButton.type = "button";
        analyzeButton.textContent = "Analyze provided severities";
        analyzeButton.addEventListener("click", function () {
            postCooldownSimulatorAction("analyze-selected-channels", collectSelectedCooldownSimulatorChannels(panel));
        });
        analyzeSuggestedButton.className = "tool-button";
        analyzeSuggestedButton.type = "button";
        analyzeSuggestedButton.textContent = "Analyze with suggested severities";
        analyzeSuggestedButton.addEventListener("click", function () {
            postCooldownSimulatorAction("analyze-with-suggested-severities", collectSelectedCooldownSimulatorChannels(panel));
        });
        analyzeNoExpiredButton.className = "tool-button";
        analyzeNoExpiredButton.type = "button";
        analyzeNoExpiredButton.textContent = "Analyze with no expirations";
        analyzeNoExpiredButton.addEventListener("click", function () {
            postCooldownSimulatorAction("analyze-with-no-expirations", collectSelectedCooldownSimulatorChannels(panel));
        });
        improveDelaysButton.className = "tool-button";
        improveDelaysButton.type = "button";
        improveDelaysButton.textContent = "Improve delays";
        improveDelaysButton.style.display = "none";
        improveDelaysButton.setAttribute("data-role", "cooldown-simulator-improve-delays");
        improveDelaysButton.addEventListener("click", function () {
            postCooldownSimulatorAction("improve-delays");
        });
        priorityProcessButton.className = "tool-button";
        priorityProcessButton.type = "button";
        priorityProcessButton.textContent = "Show priority process";
        priorityProcessButton.disabled = true;
        priorityProcessButton.setAttribute("data-role", "cooldown-simulator-priority-process");
        priorityProcessButton.addEventListener("click", function () {
            openCooldownSimulatorPriorityProcessDialog();
        });
        exportButton.className = "tool-button";
        exportButton.type = "button";
        exportButton.textContent = "Export simple file";
        exportButton.addEventListener("click", function () {
            postCooldownSimulatorAction("export-simple-file");
        });
        ganttButton.className = "tool-button";
        ganttButton.type = "button";
        ganttButton.textContent = "Open Gantt View";
        ganttButton.addEventListener("click", function () {
            postCooldownSimulatorAction("open-gantt-view");
        });
        sendToJiraButton.className = "tool-button";
        sendToJiraButton.type = "button";
        sendToJiraButton.textContent = "Send to Jira";
        sendToJiraButton.addEventListener("click", function () {
            openCooldownSimulatorJiraRequestDialog(panel);
        });

        actionToolbar.className = "cooldown-simulator-actions";
        actionToolbar.appendChild(selectButton);
        actionToolbar.appendChild(saveStateButton);
        actionToolbar.appendChild(resetStateButton);
        actionToolbar.appendChild(analyzeButton);
        actionToolbar.appendChild(analyzeSuggestedButton);
        actionToolbar.appendChild(analyzeNoExpiredButton);
        actionToolbar.appendChild(improveDelaysButton);
        actionToolbar.appendChild(priorityProcessButton);
        actionToolbar.appendChild(exportButton);
        actionToolbar.appendChild(ganttButton);
        actionToolbar.appendChild(sendToJiraButton);

        selectionDisplay.className = "cooldown-simulator-selection";
        selectionDisplay.setAttribute("data-role", "cooldown-simulator-selection");
        errorDisplay.className = "cooldown-simulator-error";
        errorDisplay.setAttribute("data-role", "cooldown-simulator-error");
        controlsContainer.className = "cooldown-simulator-control-groups";
        controlsContainer.setAttribute("data-role", "cooldown-simulator-control-groups");
        channelsContainer.className = "cooldown-simulator-channels";
        channelsContainer.setAttribute("data-role", "cooldown-simulator-channels");
        visibleColumnsContainer.className = "cooldown-simulator-visible-columns";
        visibleColumnsContainer.setAttribute("data-role", "cooldown-simulator-visible-columns");
        validationSummaryContainer.className = "cooldown-simulator-validation-summary";
        validationSummaryContainer.setAttribute("data-role", "cooldown-simulator-validation-summary");
        validationTableContainer.className = "cooldown-simulator-validation-table";
        validationTableContainer.setAttribute("data-role", "cooldown-simulator-validation-table");
        optimizationSummaryContainer.className = "cooldown-simulator-optimization-summary";
        optimizationSummaryContainer.setAttribute("data-role", "cooldown-simulator-optimization-summary");
        analysisModeDisplay.className = "cooldown-simulator-analysis-mode";
        analysisModeDisplay.setAttribute("data-role", "cooldown-simulator-analysis-mode");
        resultsErrorDisplay.className = "cooldown-simulator-results-error";
        resultsErrorDisplay.setAttribute("data-role", "cooldown-simulator-results-error");
        resultsWarningDisplay.className = "cooldown-simulator-results-warning";
        resultsWarningDisplay.setAttribute("data-role", "cooldown-simulator-results-warning");
        exportStatusDisplay.className = "cooldown-simulator-export-status";
        exportStatusDisplay.setAttribute("data-role", "cooldown-simulator-export-status");
        resultsContainer.className = "cooldown-simulator-results";
        resultsContainer.setAttribute("data-role", "cooldown-simulator-results");
        resultsContainer.addEventListener("click", function (event) {
            handleCooldownSimulatorResultsClick(panel, event);
        });

        body.appendChild(heading);
        body.appendChild(text);
        body.appendChild(actionToolbar);
        body.appendChild(selectionDisplay);
        body.appendChild(errorDisplay);
        controlsContainer.appendChild(channelsContainer);
        controlsContainer.appendChild(visibleColumnsContainer);
        body.appendChild(controlsContainer);
        body.appendChild(validationSummaryContainer);
        body.appendChild(validationTableContainer);
        body.appendChild(optimizationSummaryContainer);
        body.appendChild(analysisModeDisplay);
        body.appendChild(resultsErrorDisplay);
        body.appendChild(resultsWarningDisplay);
        body.appendChild(exportStatusDisplay);
        body.appendChild(resultsContainer);
        panel.appendChild(body);
        updateCooldownSimulatorWorkspacePanel(panel);
    }

    function createHtmlWorkspaceError(tab, config) {
        var body = document.createElement("div");
        var heading = document.createElement("h3");
        var text = document.createElement("p");

        body.className = "workspace-html-error";
        heading.textContent = tab.title + " workspace could not load";
        text.textContent = config && Array.isArray(config.missingFiles) && config.missingFiles.length > 0
            ? "Missing local files: " + config.missingFiles.join(", ") + "."
            : "The local HTML workspace files are unavailable.";

        body.appendChild(heading);
        body.appendChild(text);
        return body;
    }

    function getMailoWorkspaceConfiguration(toolId) {
        if (toolId !== mailoToolConfiguration.id) {
            return null;
        }

        return mailoToolConfiguration;
    }

    function shouldNotifyHost(tab) {
        return !!tab && (tab.workspaceType || "native") === "native" && tab.toolId !== "copycat";
    }

    function isBrowserHostedWorkspace(tab) {
        return !!tab && (tab.workspaceType || "native") === "browser";
    }

    function getBrowserWorkspaceLayoutBounds(tab, panel) {
        if (!tab || !panel) {
            return null;
        }

        var outer = tab.toolId === "copycat"
            ? panel.querySelector(".copycat-browser-pane > .browser-native-layout")
            : panel.querySelector(".browser-native-layout");
        var toolbar = panel.querySelector("[data-role='browser-toolbar-host']");
        var content = tab.toolId === "copycat"
            ? panel.querySelector("[data-role='copycat-browser-anchor']")
            : panel.querySelector("[data-role='browser-content-host']");

        if (!outer || !toolbar || !content) {
            return null;
        }

        return {
            outerRect: outer.getBoundingClientRect(),
            toolbarRect: toolbar.getBoundingClientRect(),
            contentRect: content.getBoundingClientRect()
        };
    }

    function getHostViewportMetrics(element) {
        var docElement = document.documentElement;
        var body = document.body;
        var rect = element && typeof element.getBoundingClientRect === "function"
            ? element.getBoundingClientRect()
            : null;
        var width = Math.max(
            Math.round(window.innerWidth || 0),
            docElement ? Math.round(docElement.clientWidth || 0) : 0,
            body ? Math.round(body.clientWidth || 0) : 0,
            rect ? Math.round(rect.width || 0) : 0);
        var height = Math.max(
            Math.round(window.innerHeight || 0),
            docElement ? Math.round(docElement.clientHeight || 0) : 0,
            body ? Math.round(body.clientHeight || 0) : 0,
            rect ? Math.round(rect.height || 0) : 0);

        return {
            width: width,
            height: height
        };
    }

    function getCopyCatWorkspaceBounds(tab, panel) {
        if (!tab || !panel || tab.toolId !== "copycat") {
            return null;
        }

        return panel.getBoundingClientRect();
    }

    function beginCopyCatResize(event, panel) {
        if (!panel) {
            return;
        }

        var currentPercent = parseFloat(panel.dataset.copycatSplitPercent || "80");
        var shell = panel.querySelector(".copycat-workspace-shell");
        copyCatResizeState.panel = panel;
        copyCatResizeState.previewPercent = isFinite(currentPercent) ? currentPercent : 80;

        if (shell) {
            shell.classList.add("is-drag-preview");
            shell.style.setProperty("--copycat-drag-preview-basis", copyCatResizeState.previewPercent + "%");
        }

        if (document.body) {
            document.body.classList.add("resizing-copycat");
        }

        event.preventDefault();
        event.stopPropagation();
    }

    function handleCopyCatResizeMove(event) {
        var panel = copyCatResizeState.panel;
        var shell = panel ? panel.querySelector(".copycat-workspace-shell") : null;
        if (!panel || !shell) {
            return;
        }

        var rect = shell.getBoundingClientRect();
        copyCatResizeState.previewPercent = calculateCopyCatSplitPercent(rect, event.clientX);
        shell.style.setProperty("--copycat-drag-preview-basis", copyCatResizeState.previewPercent + "%");
        event.preventDefault();
    }

    function handleCopyCatResizeEnd(event) {
        var panel = copyCatResizeState.panel;
        var shell = panel ? panel.querySelector(".copycat-workspace-shell") : null;
        if (!panel) {
            return;
        }

        var rect = shell ? shell.getBoundingClientRect() : null;
        var finalPercent = rect && event
            ? calculateCopyCatSplitPercent(rect, event.clientX)
            : copyCatResizeState.previewPercent;

        panel.dataset.copycatSplitPercent = String(finalPercent);
        updateCopyCatWorkspaceLayout(panel);

        if (shell) {
            shell.classList.remove("is-drag-preview");
            shell.style.removeProperty("--copycat-drag-preview-basis");
        }

        if (document.body) {
            document.body.classList.remove("resizing-copycat");
        }

        scheduleCopyCatWorkspaceSync("copycat-divider-release");
        scheduleBrowserWorkspaceSync("copycat-divider-release");
        logCopyCatWorkspaceSnapshot("DIVIDER_COMMIT", panel, {
            splitPercent: panel.dataset.copycatSplitPercent || String(finalPercent)
        });
        copyCatResizeState.panel = null;
        copyCatResizeState.previewPercent = 80;

        if (event) {
            event.preventDefault();
        }
    }

    function calculateCopyCatSplitPercent(rect, clientX) {
        var dividerWidth = 12;
        var minLeft = 320;
        var minRight = 180;
        var width = rect ? rect.width : 0;
        if (width <= 0) {
            return 80;
        }

        var relativeX = clientX - rect.left;
        var minPercent = Math.min(100, (Math.min(minLeft, width) / width) * 100);
        var maxPercent = Math.max(0, ((width - dividerWidth - Math.min(minRight, Math.max(0, width - dividerWidth))) / width) * 100);

        if (maxPercent <= minPercent) {
            return Math.max(0, Math.min(100, (relativeX / width) * 100));
        }

        return Math.max(minPercent, Math.min(maxPercent, (relativeX / width) * 100));
    }

    function updateCopyCatWorkspaceLayouts() {
        if (!workspaceHost) {
            return;
        }

        var panels = workspaceHost.querySelectorAll(".workspace-copycat");
        panels.forEach(function (panel) {
            updateCopyCatWorkspaceLayout(panel);
        });
    }

    function updateCopyCatWorkspaceLayout(panel) {
        if (!panel) {
            return;
        }

        var shell = panel.querySelector(".copycat-workspace-shell");
        if (!shell) {
            return;
        }

        var percent = parseFloat(panel.dataset.copycatSplitPercent || "80");
        if (!isFinite(percent)) {
            percent = 80;
        }

        percent = Math.max(0, Math.min(100, percent));
        shell.style.setProperty("--copycat-browser-basis", percent + "%");
    }

    function scheduleCopyCatWorkspaceSync(reason) {
        if (reason === "window-resize" || reason === "resize-observer" || reason === "copycat-divider-release") {
            return;
        }

        window.requestAnimationFrame(function () {
            syncCopyCatWorkspace(reason);
        });
    }

    function syncCopyCatWorkspace(reason) {
        var activeTab = getActiveTab();
        var panel = activeTab ? findWorkspacePanel(activeTab.panelId) : null;

        if (!activeTab || activeTab.toolId !== "copycat" || !panel) {
            postCopyCatWorkspaceState("hide", activeTab, null, reason);
            return;
        }

        postCopyCatWorkspaceState("show", activeTab, null, reason);
    }

    function postCopyCatWorkspaceState(action, tab, bounds, reason) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "copycatWorkspaceState",
            action: action,
            reason: reason,
            tabId: tab ? tab.id : null,
            toolId: tab ? tab.toolId : null,
            bounds: bounds
        });
    }

    function logHoverState(event) {
        logTabDrag("HOVER", {
            source: formatTabIdentity(tabState.dragId),
            sourceIndex: tabState.sourceIndex,
            hover: formatHoverIdentity(tabState.dropPreview),
            previewIndex: tabState.previewIndex,
            mouseX: event.clientX,
            mouseY: event.clientY,
            adjustedX: getAdjustedClientX(event.clientX),
            scrollLeft: tabsBar ? tabsBar.scrollLeft : 0,
            targetRole: getEventTargetRole(event.target),
            coordsAdjustedForScroll: true
        });
    }

    function formatTabOrder() {
        return formatTabOrderFromItems(tabState.items);
    }

    function formatTabOrderFromItems(items) {
        return "[" + items.map(function (item) {
            return item.title + ":" + item.id;
        }).join(", ") + "]";
    }

    function formatTabIdentity(tabId) {
        if (!tabId) {
            return "none";
        }

        var tab = findTabById(tabId);
        if (!tab) {
            return "id=\"" + tabId + "\" title=\"unknown\"";
        }

        return "id=\"" + tab.id + "\" title=\"" + sanitizeLogValue(tab.title) + "\"";
    }

    function formatHoverIdentity(preview) {
        if (!preview) {
            return "none";
        }

        var targetId = preview.targetId || "none";
        var targetIndex = targetId === "none" ? "n/a" : getModelIndexById(targetId);
        var visualIndex = targetId === "none" ? "n/a" : getVisualIndexById(targetId);
        return "target=" + formatTabIdentity(targetId) + " hoverIndex=" + visualIndex + " modelIndex=" + targetIndex + " insertionIndex=" + preview.insertIndex + " position=" + preview.position;
    }

    function getVisualIndexById(tabId) {
        if (!tabsBar || !tabId) {
            return -1;
        }

        var tabs = Array.from(tabsBar.querySelectorAll(".tab-button"));
        return tabs.findIndex(function (tab) {
            return tab.dataset.tabId === tabId;
        });
    }

    function getModelIndexById(tabId) {
        return tabState.items.findIndex(function (item) {
            return item.id === tabId;
        });
    }

    function getAdjustedClientX(clientX) {
        if (!tabsBar) {
            return clientX;
        }

        return Math.round(clientX - tabsBar.getBoundingClientRect().left + tabsBar.scrollLeft);
    }

    function getEventTargetRole(target) {
        if (!target) {
            return "unknown";
        }

        if (target.closest && target.closest(".tab-close")) {
            return "close-button";
        }

        if (target.classList && target.classList.contains("tab-label")) {
            return "tab-label";
        }

        if (target.closest && target.closest(".tab-button")) {
            return "tab-body";
        }

        if (target.closest && target.closest(".tabs-bar")) {
            return "tab-strip";
        }

        return target.tagName ? target.tagName.toLowerCase() : "unknown";
    }

    function isPointInsideTabsBar(clientX, clientY) {
        if (!tabsBar) {
            return false;
        }

        var rect = tabsBar.getBoundingClientRect();
        return clientX >= rect.left && clientX <= rect.right && clientY >= rect.top && clientY <= rect.bottom;
    }

    function isPointInsideExpandedTabsBar(clientX, clientY) {
        if (!tabsBar) {
            return false;
        }

        var rect = tabsBar.getBoundingClientRect();
        var verticalPadding = 28;
        var horizontalPadding = 16;

        return clientX >= rect.left - horizontalPadding &&
            clientX <= rect.right + horizontalPadding &&
            clientY >= rect.top - verticalPadding &&
            clientY <= rect.bottom + verticalPadding;
    }

    function isSameOrder(currentItems, nextItems) {
        if (currentItems.length !== nextItems.length) {
            return false;
        }

        for (var i = 0; i < currentItems.length; i += 1) {
            if (currentItems[i].id !== nextItems[i].id) {
                return false;
            }
        }

        return true;
    }

    function formatRect(rect) {
        return "left=" + Math.round(rect.left) + ",top=" + Math.round(rect.top) + ",width=" + Math.round(rect.width) + ",height=" + Math.round(rect.height);
    }

    function setDragVisualState(isActive) {
        if (tabsBar) {
            tabsBar.classList.toggle("is-drag-active", isActive);
        }

        if (document.body) {
            document.body.classList.toggle("dragging-tabs", isActive);
        }
    }

    function scheduleLoginWorkspaceSync(reason) {
        window.requestAnimationFrame(function () {
            syncLoginWorkspace(reason);
        });
    }

    function syncLoginWorkspace(reason) {
        if (!form3LoginState.loginWorkspaceVisible) {
            postForm3LoginAction("syncBounds", null, reason);
            return;
        }

        postForm3LoginAction("syncBounds", getLoginWorkspaceBounds(), reason);
    }

    function getLoginWorkspaceBounds() {
        if (!loginWorkspaceAnchor) {
            return null;
        }

        var target = loginWorkspaceAnchor.classList.contains("is-visible") && loginWorkspaceAnchor.offsetWidth > 0 && loginWorkspaceAnchor.offsetHeight > 0
            ? loginWorkspaceAnchor
            : loginWorkspaceAnchor.parentElement;
        if (!target) {
            return null;
        }

        var rect = target.getBoundingClientRect();
        return {
            left: Math.round(rect.left),
            top: Math.round(rect.top),
            width: Math.round(rect.width),
            height: Math.round(rect.height),
            devicePixelRatio: window.devicePixelRatio || 1,
            viewportWidth: Math.round(window.innerWidth || 0),
            viewportHeight: Math.round(window.innerHeight || 0)
        };
    }

    function postForm3LoginAction(action, bounds, reason) {
        if (!action || !window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "form3Login",
            action: action,
            reason: reason,
            bounds: bounds
        });
    }

    function scheduleBrowserWorkspaceSync(reason) {
        window.requestAnimationFrame(function () {
            syncBrowserWorkspace(reason);
        });
    }

    function syncBrowserWorkspace(reason) {
        var activeTab = getActiveTab();
        var panel = activeTab ? findWorkspacePanel(activeTab.panelId) : null;

        if (activeTab && activeTab.toolId === "copycat") {
            return;
        }

        if (!isBrowserHostedWorkspace(activeTab) || !panel) {
            logBrowserWorkspace("SYNC_HIDE", {
                reason: reason,
                activeTab: activeTab ? formatTabIdentity(activeTab.id) : "none",
                panelFound: !!panel
            });
            postBrowserWorkspaceState("hide", activeTab, null, reason);
            return;
        }

        var layoutBounds = getBrowserWorkspaceLayoutBounds(activeTab, panel);
        if (!layoutBounds) {
            postBrowserWorkspaceState("hide", activeTab, null, reason);
            return;
        }

        var outerRect = layoutBounds.outerRect;
        var toolbarRect = layoutBounds.toolbarRect;
        var rect = layoutBounds.contentRect;
        var viewportMetrics = getHostViewportMetrics(panel);
        var bounds = {
            left: Math.round(outerRect.left),
            top: Math.round(outerRect.top),
            width: Math.round(outerRect.width),
            height: Math.round(outerRect.height),
            devicePixelRatio: window.devicePixelRatio || 1,
            viewportWidth: viewportMetrics.width,
            viewportHeight: viewportMetrics.height
        };
        var outerBounds = {
            left: Math.round(outerRect.left),
            top: Math.round(outerRect.top),
            width: Math.round(outerRect.width),
            height: Math.round(outerRect.height)
        };
        var toolbarBounds = {
            left: Math.round(toolbarRect.left),
            top: Math.round(toolbarRect.top),
            width: Math.round(toolbarRect.width),
            height: Math.round(toolbarRect.height)
        };

        logBrowserWorkspace("SYNC_SHOW", {
            reason: reason,
            tab: formatTabIdentity(activeTab.id),
            panelId: activeTab.panelId,
            outerLeft: outerBounds.left,
            outerTop: outerBounds.top,
            outerWidth: outerBounds.width,
            outerHeight: outerBounds.height,
            toolbarLeft: toolbarBounds.left,
            toolbarTop: toolbarBounds.top,
            toolbarWidth: toolbarBounds.width,
            toolbarHeight: toolbarBounds.height,
            left: bounds.left,
            top: bounds.top,
            width: bounds.width,
            height: bounds.height,
            viewportWidth: bounds.viewportWidth,
            viewportHeight: bounds.viewportHeight,
            url: pendingBrowserNavigationUrl || defaultBrowserUrl
        });
        if (activeTab.toolId === "copycat") {
            logCopyCatWorkspaceSnapshot("BROWSER_SYNC_SHOW", panel, {
                reason: reason,
                outerBounds: formatRectForCopyCatDebug(outerRect),
                toolbarBounds: formatRectForCopyCatDebug(toolbarRect),
                contentBounds: formatRectForCopyCatDebug(rect)
            });
        }
        postBrowserWorkspaceState("show", activeTab, bounds, reason, pendingBrowserNavigationUrl, !!pendingBrowserNavigationUrl, outerBounds, toolbarBounds);
        pendingBrowserNavigationUrl = null;
    }

    function postMailoWorkspaceState(action, tab, bounds, reason) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "mailoWorkspaceState",
            action: action,
            reason: reason,
            tabId: tab ? tab.id : null,
            toolId: tab ? tab.toolId : null,
            bounds: bounds
        });
    }

    function postMailoAction(action) {
        if (!action || !window.chrome || !window.chrome.webview) {
            return;
        }

        logBrowserWorkspace("MAILO_ACTION_BRIDGE", {
            action: action
        });

        window.chrome.webview.postMessage({
            type: "mailoAction",
            action: action,
            toolId: mailoToolConfiguration.id
        });
    }

    function postCooldownSimulatorAction(action, selectedChannels, payload) {
        if (!action || !window.chrome || !window.chrome.webview) {
            return;
        }

        payload = payload || {};

        window.chrome.webview.postMessage({
            type: "cooldownSimulatorAction",
            action: action,
            toolId: "cooldown-simulator",
            selectedChannels: Array.isArray(selectedChannels) ? selectedChannels : [],
            sourceRowIndex: typeof payload.sourceRowIndex === "number" ? payload.sourceRowIndex : null,
            delta: typeof payload.delta === "number" ? payload.delta : 0,
            regionSelection: typeof payload.regionSelection === "string" ? payload.regionSelection : "",
            audienceSelectionMode: typeof payload.audienceSelectionMode === "string" ? payload.audienceSelectionMode : "",
            issueUrl: typeof payload.issueUrl === "string" ? payload.issueUrl : "",
            dateValue: typeof payload.dateValue === "string" ? payload.dateValue : "",
            isImportantLaunch: !!payload.isImportantLaunch,
            isMauAudience: !!payload.isMauAudience,
            isNauAudience: !!payload.isNauAudience,
            visibleColumnKeys: collectCooldownSimulatorVisibleColumnKeys(),
            jSessionId: typeof payload.jSessionId === "string" ? payload.jSessionId : "",
            prioritySource: typeof payload.prioritySource === "string" ? payload.prioritySource : "",
            dryRun: !!payload.dryRun
        });
    }

    function openCooldownSimulatorJiraRequestDialog(panel) {
        closeCooldownSimulatorJiraDialog();

        var channels = getCooldownSimulatorJiraAvailableChannels();
        var hasAnalysisResults = currentCooldownSimulatorState &&
            Array.isArray(currentCooldownSimulatorState.analysisResults) &&
            currentCooldownSimulatorState.analysisResults.length > 0;
        var overlay = document.createElement("div");
        var dialog = document.createElement("div");
        var heading = document.createElement("h3");
        var sessionLabel = document.createElement("label");
        var sessionInput = document.createElement("input");
        var channelGroup = document.createElement("div");
        var channelHeading = document.createElement("div");
        var sourceGroup = document.createElement("div");
        var sourceHeading = document.createElement("div");
        var dryRunLabel = document.createElement("label");
        var dryRunCheckbox = document.createElement("input");
        var actions = document.createElement("div");
        var confirmButton = document.createElement("button");
        var cancelButton = document.createElement("button");
        var note = document.createElement("div");

        overlay.className = "cooldown-simulator-jira-overlay";
        dialog.className = "cooldown-simulator-jira-dialog";
        heading.textContent = "Send to Jira";
        sessionLabel.className = "cooldown-simulator-jira-field";
        sessionLabel.textContent = "JSESSIONID";
        sessionInput.type = "password";
        sessionInput.autocomplete = "off";
        sessionInput.spellcheck = false;
        sessionInput.placeholder = "Paste JSESSIONID value";
        sessionLabel.appendChild(sessionInput);

        channelGroup.className = "cooldown-simulator-jira-channel-list";
        channelHeading.className = "cooldown-simulator-jira-section-title";
        channelHeading.textContent = "Channels";
        channelGroup.appendChild(channelHeading);
        if (channels.length === 0) {
            var emptyChannelText = document.createElement("div");
            emptyChannelText.className = "cooldown-simulator-jira-note";
            emptyChannelText.textContent = "No channels are available. Run analysis before sending priorities.";
            channelGroup.appendChild(emptyChannelText);
        } else {
            channels.forEach(function (channelName, index) {
                var label = document.createElement("label");
                var checkbox = document.createElement("input");
                var text = document.createElement("span");
                var normalizedChannel = normalizeCooldownSimulatorChannelName(channelName);
                var isSimulated = isCooldownSimulatorSimulatedChannelName(normalizedChannel);

                label.className = "cooldown-simulator-jira-checkbox";
                checkbox.type = "checkbox";
                checkbox.name = "cooldown-simulator-jira-channel-" + index;
                checkbox.value = normalizedChannel;
                checkbox.checked = isSimulated;
                text.textContent = isSimulated ? normalizedChannel : normalizedChannel + " (not simulated)";
                label.appendChild(checkbox);
                label.appendChild(text);
                channelGroup.appendChild(label);
            });
        }

        sourceGroup.className = "cooldown-simulator-jira-source-list";
        sourceHeading.className = "cooldown-simulator-jira-section-title";
        sourceHeading.textContent = "Priority source";
        sourceGroup.appendChild(sourceHeading);
        [
            { value: "provided", label: "Provided Severity" },
            { value: "suggested", label: "Suggested Severity" },
            { value: "effective", label: "Effective Severity" }
        ].forEach(function (source) {
            var label = document.createElement("label");
            var radio = document.createElement("input");
            var text = document.createElement("span");

            label.className = "cooldown-simulator-jira-radio";
            radio.type = "radio";
            radio.name = "cooldown-simulator-jira-priority-source";
            radio.value = source.value;
            radio.checked = source.value === "effective";
            text.textContent = source.label;
            label.appendChild(radio);
            label.appendChild(text);
            sourceGroup.appendChild(label);
        });

        dryRunLabel.className = "cooldown-simulator-jira-checkbox";
        dryRunCheckbox.type = "checkbox";
        dryRunCheckbox.checked = false;
        dryRunLabel.appendChild(dryRunCheckbox);
        dryRunLabel.appendChild(document.createTextNode(" Dry run"));

        note.className = "cooldown-simulator-jira-note";
        note.textContent = hasAnalysisResults
            ? "Rows with missing issue keys, EXCLUDE audience, duplicate conflicts, or missing numeric priority values will be skipped."
            : "Run a Cooldown Simulator analysis first so selected priority values are available.";

        actions.className = "cooldown-simulator-jira-actions";
        confirmButton.className = "tool-button";
        confirmButton.type = "button";
        confirmButton.textContent = "Send";
        confirmButton.disabled = !hasAnalysisResults;
        cancelButton.className = "tool-button";
        cancelButton.type = "button";
        cancelButton.textContent = "Cancel";

        cancelButton.addEventListener("click", closeCooldownSimulatorJiraDialog);
        confirmButton.addEventListener("click", function () {
            var selectedChannels = [];
            var selectedSourceInput = dialog.querySelector("input[name='cooldown-simulator-jira-priority-source']:checked");
            var jSessionId = sessionInput.value || "";

            dialog.querySelectorAll(".cooldown-simulator-jira-channel-list input[type='checkbox']").forEach(function (checkbox) {
                if (checkbox.checked && checkbox.value) {
                    selectedChannels.push(checkbox.value);
                }
            });

            if (!jSessionId.trim()) {
                note.textContent = "JSESSIONID is required.";
                sessionInput.focus();
                return;
            }

            if (selectedChannels.length === 0) {
                note.textContent = "Select at least one channel.";
                return;
            }

            var prioritySource = selectedSourceInput ? selectedSourceInput.value : "effective";
            closeCooldownSimulatorJiraDialog();
            openCooldownSimulatorJiraProgressDialog(
                buildCooldownSimulatorJiraPreviewRows(selectedChannels, prioritySource),
                "Preparing Jira updates...");
            postCooldownSimulatorAction("send-priorities-to-jira", selectedChannels, {
                jSessionId: jSessionId,
                prioritySource: prioritySource,
                dryRun: dryRunCheckbox.checked
            });
            sessionInput.value = "";
            jSessionId = "";
        });

        actions.appendChild(confirmButton);
        actions.appendChild(cancelButton);
        dialog.appendChild(heading);
        dialog.appendChild(sessionLabel);
        dialog.appendChild(channelGroup);
        dialog.appendChild(sourceGroup);
        dialog.appendChild(dryRunLabel);
        dialog.appendChild(note);
        dialog.appendChild(actions);
        overlay.appendChild(dialog);
        overlay.addEventListener("click", function (event) {
            if (event.target === overlay) {
                closeCooldownSimulatorJiraDialog();
            }
        });

        document.body.appendChild(overlay);
        cooldownSimulatorJiraDialog = overlay;
        sessionInput.focus();
    }

    function closeCooldownSimulatorJiraDialog() {
        if (cooldownSimulatorJiraDialog && cooldownSimulatorJiraDialog.parentNode) {
            cooldownSimulatorJiraDialog.parentNode.removeChild(cooldownSimulatorJiraDialog);
        }

        cooldownSimulatorJiraDialog = null;
    }

    function getCooldownSimulatorJiraAvailableChannels() {
        var seen = new Set();
        var channels = [];
        var analysisResults = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.analysisResults)
            ? currentCooldownSimulatorState.analysisResults
            : [];
        if (analysisResults.length > 0) {
            analysisResults.forEach(function (result) {
                var resultChannel = normalizeCooldownSimulatorChannelName(result && (result.channel || result.Channel || ""));
                if (resultChannel && !seen.has(resultChannel)) {
                    seen.add(resultChannel);
                    channels.push(resultChannel);
                }
            });
        } else if (currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.channels)) {
            currentCooldownSimulatorState.channels.forEach(function (channelName) {
                var normalizedChannel = normalizeCooldownSimulatorChannelName(channelName);
                if (normalizedChannel && !seen.has(normalizedChannel)) {
                    seen.add(normalizedChannel);
                    channels.push(normalizedChannel);
                }
            });
        }

        channels.sort(function (left, right) {
            var leftSimulated = isCooldownSimulatorSimulatedChannelName(left) ? 0 : 1;
            var rightSimulated = isCooldownSimulatorSimulatedChannelName(right) ? 0 : 1;
            if (leftSimulated !== rightSimulated) {
                return leftSimulated - rightSimulated;
            }

            return left.localeCompare(right);
        });
        return channels;
    }

    function buildCooldownSimulatorJiraPreviewRows(selectedChannels, prioritySource) {
        var selectedSet = new Set((selectedChannels || []).map(function (channelName) {
            return normalizeCooldownSimulatorChannelName(channelName);
        }));
        var rows = [];
        var seenIssues = new Set();
        var analysisResults = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.analysisResults)
            ? currentCooldownSimulatorState.analysisResults
            : [];

        analysisResults.forEach(function (result) {
            var items = Array.isArray(result && result.items)
                ? result.items
                : (Array.isArray(result && result.Items) ? result.Items : []);
            items.forEach(function (item) {
                var channel = normalizeCooldownSimulatorChannelName(item && (item.channel || item.Channel || ""));
                var issueKey = String(item && (item.issueKey || item.IssueKey || "") || "").trim();
                if (!selectedSet.has(channel) || !issueKey || seenIssues.has(issueKey.toUpperCase())) {
                    return;
                }

                seenIssues.add(issueKey.toUpperCase());
                rows.push({
                    rowId: issueKey,
                    issueKey: issueKey,
                    title: item.title || item.Title || "",
                    channel: channel,
                    region: normalizeCooldownSimulatorRegionGroup(item.regionGroup || item.RegionGroup || ""),
                    audience: formatCooldownSimulatorItemAudience(item),
                    priorityValue: getCooldownSimulatorJiraPriorityValue(item, prioritySource)
                });
            });
        });

        return rows;
    }

    function getCooldownSimulatorJiraPriorityValue(item, prioritySource) {
        var rawValue = "";
        if (isCooldownSimulatorItemTokenPriorityLocked(item)) {
            return "0";
        }

        if (prioritySource === "provided") {
            rawValue = item && (item.providedSeverity || item.ProvidedSeverity || "");
        } else if (prioritySource === "suggested") {
            rawValue = item && (item.suggestedSeverity || item.SuggestedSeverity || "");
        } else {
            rawValue = item && (item.effectiveSeverity || item.EffectiveSeverity || "");
        }

        return String(rawValue === null || rawValue === undefined ? "" : rawValue).trim();
    }

    function openCooldownSimulatorJiraProgressDialog(rows, summaryText) {
        closeCooldownSimulatorJiraProgressDialog();

        var overlay = document.createElement("div");
        var dialog = document.createElement("div");
        var heading = document.createElement("h3");
        var summary = document.createElement("div");
        var details = document.createElement("div");
        var table = document.createElement("table");
        var thead = document.createElement("thead");
        var headRow = document.createElement("tr");
        var tbody = document.createElement("tbody");
        var actions = document.createElement("div");
        var closeButton = document.createElement("button");

        overlay.className = "cooldown-simulator-jira-overlay";
        dialog.className = "cooldown-simulator-jira-dialog cooldown-simulator-jira-progress-dialog";
        heading.textContent = "Jira priority update";
        summary.className = "cooldown-simulator-jira-summary";
        summary.setAttribute("data-role", "cooldown-simulator-jira-summary");
        summary.textContent = summaryText || "Pending...";
        details.className = "cooldown-simulator-result-details cooldown-simulator-jira-progress-details";
        table.className = "cooldown-simulator-jira-progress-table";
        ["Issue", "Title", "Channel", "Region", "Audience", "Priority", "Task found", "Sent", "Confirmed"].forEach(function (label) {
            var header = document.createElement("th");
            header.textContent = label;
            headRow.appendChild(header);
        });

        thead.appendChild(headRow);
        table.appendChild(thead);
        table.appendChild(tbody);
        details.appendChild(table);

        actions.className = "cooldown-simulator-jira-actions";
        closeButton.className = "tool-button";
        closeButton.type = "button";
        closeButton.textContent = "Close";
        closeButton.addEventListener("click", closeCooldownSimulatorJiraProgressDialog);
        actions.appendChild(closeButton);

        dialog.appendChild(heading);
        dialog.appendChild(summary);
        dialog.appendChild(details);
        dialog.appendChild(actions);
        overlay.appendChild(dialog);
        document.body.appendChild(overlay);

        cooldownSimulatorJiraProgressDialog = overlay;
        cooldownSimulatorJiraProgressRows = new Map();
        renderCooldownSimulatorJiraProgressRows(Array.isArray(rows) ? rows : []);
    }

    function closeCooldownSimulatorJiraProgressDialog() {
        if (cooldownSimulatorJiraProgressDialog && cooldownSimulatorJiraProgressDialog.parentNode) {
            cooldownSimulatorJiraProgressDialog.parentNode.removeChild(cooldownSimulatorJiraProgressDialog);
        }

        cooldownSimulatorJiraProgressDialog = null;
        cooldownSimulatorJiraProgressRows = new Map();
    }

    function openCooldownSimulatorPriorityProcessDialog() {
        var trace = currentCooldownSimulatorState && currentCooldownSimulatorState.lastPriorityProcessTrace
            ? currentCooldownSimulatorState.lastPriorityProcessTrace
            : null;
        if (!trace) {
            window.alert("No priority process trace is available yet.");
            return;
        }

        var overlay = document.createElement("div");
        var dialog = document.createElement("div");
        var title = document.createElement("h3");
        var summary = document.createElement("div");
        var body = document.createElement("div");
        var actions = document.createElement("div");
        var copyButton = document.createElement("button");
        var closeButton = document.createElement("button");

        overlay.className = "cooldown-simulator-jira-overlay";
        dialog.className = "cooldown-simulator-jira-dialog cooldown-simulator-priority-process-dialog";
        title.textContent = "Last priority process";
        summary.className = "cooldown-simulator-jira-summary";
        summary.textContent = [
            "Mode: " + formatCooldownSimulatorCellText(trace.actionMode || trace.ActionMode || ""),
            "UTC: " + formatCooldownSimulatorCellText(trace.timestampUtc || trace.TimestampUtc || ""),
            "Channels: " + formatCooldownSimulatorCellText((trace.selectedChannels || trace.SelectedChannels || []).join(", "))
        ].join(" | ");
        body.className = "cooldown-simulator-priority-process-body";

        appendPriorityProcessSection(body, "Overview", [
            ["Rows considered", trace.rowsConsidered || trace.RowsConsidered || 0],
            ["Mutable rows", trace.mutableRows || trace.MutableRows || 0],
            ["Locked rows", trace.lockedRows || trace.LockedRows || 0],
            ["Candidate combinations tried", trace.candidateCombinationsTried || trace.CandidateCombinationsTried || 0],
            ["Search strategy", trace.searchStrategy || trace.SearchStrategy || ""],
            ["Zero-expiration achieved", trace.zeroExpirationAchieved || trace.ZeroExpirationAchieved ? "Yes" : "No"],
            ["Zero-expiration infeasible", trace.zeroExpirationInfeasible || trace.ZeroExpirationInfeasible ? "Yes" : "No"],
            ["Emergency priority 0 used", trace.usedEmergencyPriorityZero || trace.UsedEmergencyPriorityZero ? "Yes" : "No"]
        ]);
        appendPriorityProcessList(body, "Locks and constraints", trace.locksAndConstraints || trace.LocksAndConstraints || []);
        appendPriorityProcessList(body, "Candidate/search strategy", trace.searchNotes || trace.SearchNotes || []);
        appendPriorityProcessDecisionTable(body, trace.decisions || trace.Decisions || []);
        appendPriorityProcessList(body, "Remaining delayed/expired rows", trace.remainingIssues || trace.RemainingIssues || []);
        appendPriorityProcessList(body, "Warnings", trace.warnings || trace.Warnings || []);

        copyButton.type = "button";
        copyButton.className = "tool-button";
        copyButton.textContent = "Copy to clipboard";
        copyButton.addEventListener("click", function () {
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(JSON.stringify(trace, null, 2));
            }
        });
        closeButton.type = "button";
        closeButton.className = "tool-button";
        closeButton.textContent = "Close";
        closeButton.addEventListener("click", function () {
            if (overlay.parentNode) {
                overlay.parentNode.removeChild(overlay);
            }
        });
        actions.className = "cooldown-simulator-jira-actions";
        actions.appendChild(copyButton);
        actions.appendChild(closeButton);

        dialog.appendChild(title);
        dialog.appendChild(summary);
        dialog.appendChild(body);
        dialog.appendChild(actions);
        overlay.appendChild(dialog);
        overlay.addEventListener("click", function (event) {
            if (event.target === overlay) {
                if (overlay.parentNode) {
                    overlay.parentNode.removeChild(overlay);
                }
            }
        });
        document.body.appendChild(overlay);
    }

    function appendPriorityProcessSection(container, title, rows) {
        var section = document.createElement("section");
        var heading = document.createElement("h4");
        var table = document.createElement("table");
        var body = document.createElement("tbody");
        heading.textContent = title;
        (rows || []).forEach(function (row) {
            var tr = document.createElement("tr");
            appendCooldownSimulatorDetailCell(tr, row[0]);
            appendCooldownSimulatorDetailCell(tr, row[1]);
            body.appendChild(tr);
        });
        table.appendChild(body);
        section.appendChild(heading);
        section.appendChild(table);
        container.appendChild(section);
    }

    function appendPriorityProcessList(container, title, items) {
        var section = document.createElement("section");
        var heading = document.createElement("h4");
        var list = document.createElement("ul");
        heading.textContent = title;
        if (!items || !items.length) {
            var empty = document.createElement("li");
            empty.textContent = "None";
            list.appendChild(empty);
        } else {
            items.forEach(function (item) {
                var li = document.createElement("li");
                li.textContent = String(item || "");
                list.appendChild(li);
            });
        }
        section.appendChild(heading);
        section.appendChild(list);
        container.appendChild(section);
    }

    function appendPriorityProcessDecisionTable(container, decisions) {
        var section = document.createElement("section");
        var heading = document.createElement("h4");
        var wrapper = document.createElement("div");
        var table = document.createElement("table");
        var thead = document.createElement("thead");
        var headRow = document.createElement("tr");
        var tbody = document.createElement("tbody");
        heading.textContent = "Priority changes";
        ["Issue", "Title", "Channel", "Region", "Before priority", "After priority", "Before status", "After status", "Reason"].forEach(function (label) {
            var th = document.createElement("th");
            th.textContent = label;
            headRow.appendChild(th);
        });
        thead.appendChild(headRow);
        table.appendChild(thead);
        if (!decisions || !decisions.length) {
            var emptyRow = document.createElement("tr");
            var emptyCell = document.createElement("td");
            emptyCell.colSpan = 9;
            emptyCell.textContent = "No priority changes recorded.";
            emptyRow.appendChild(emptyCell);
            tbody.appendChild(emptyRow);
        } else {
            decisions.forEach(function (decision) {
                var row = document.createElement("tr");
                appendCooldownSimulatorDetailCell(row, decision.issueKey || decision.IssueKey || "");
                appendCooldownSimulatorDetailCell(row, decision.title || decision.Title || "");
                appendCooldownSimulatorDetailCell(row, decision.channel || decision.Channel || "");
                appendCooldownSimulatorDetailCell(row, decision.regionGroup || decision.RegionGroup || "");
                appendCooldownSimulatorDetailCell(row, decision.beforePriority || decision.BeforePriority || "");
                appendCooldownSimulatorDetailCell(row, decision.afterPriority || decision.AfterPriority || "");
                appendCooldownSimulatorDetailCell(row, decision.beforeStatus || decision.BeforeStatus || "");
                appendCooldownSimulatorDetailCell(row, decision.afterStatus || decision.AfterStatus || "");
                appendCooldownSimulatorDetailCell(row, decision.reason || decision.Reason || "");
                tbody.appendChild(row);
            });
        }
        table.appendChild(tbody);
        wrapper.className = "cooldown-simulator-priority-process-table-wrap";
        wrapper.appendChild(table);
        section.appendChild(heading);
        section.appendChild(wrapper);
        container.appendChild(section);
    }

    function renderCooldownSimulatorJiraProgressRows(rows) {
        if (!cooldownSimulatorJiraProgressDialog) {
            openCooldownSimulatorJiraProgressDialog([], "Preparing Jira updates...");
        }

        var tbody = cooldownSimulatorJiraProgressDialog.querySelector(".cooldown-simulator-jira-progress-table tbody");
        if (!tbody) {
            return;
        }

        tbody.innerHTML = "";
        cooldownSimulatorJiraProgressRows = new Map();
        rows.forEach(function (rowItem) {
            var row = document.createElement("tr");
            var rowId = String(rowItem.rowId || rowItem.issueKey || rowItem.IssueKey || "").trim();
            appendCooldownSimulatorDetailCell(row, rowItem.issueKey || rowItem.IssueKey || "");
            appendCooldownSimulatorDetailCell(row, rowItem.title || rowItem.Title || "");
            appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorChannelName(rowItem.channel || rowItem.Channel || ""));
            appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorRegionGroup(rowItem.region || rowItem.regionGroup || rowItem.RegionGroup || ""));
            appendCooldownSimulatorDetailCell(row, rowItem.audience || rowItem.Audience || "");
            appendCooldownSimulatorDetailCell(row, rowItem.priorityValue || rowItem.PriorityValue || "");
            appendCooldownSimulatorJiraStepCell(row, "found", "pending", "Pending");
            appendCooldownSimulatorJiraStepCell(row, "sent", "pending", "Pending");
            appendCooldownSimulatorJiraStepCell(row, "confirmed", "pending", "Pending");
            tbody.appendChild(row);
            if (rowId) {
                cooldownSimulatorJiraProgressRows.set(rowId, row);
            }
        });
    }

    function appendCooldownSimulatorJiraStepCell(row, step, state, message) {
        var cell = document.createElement("td");
        var content = document.createElement("span");
        var circle = document.createElement("span");
        var messageText = document.createElement("span");
        content.className = "cooldown-simulator-jira-status-content";
        circle.className = "cooldown-simulator-jira-status-dot is-" + normalizeCooldownSimulatorJiraStepState(state);
        circle.title = message || "";
        circle.setAttribute("data-step", step);
        circle.setAttribute("aria-label", message || step);
        messageText.className = "cooldown-simulator-jira-status-message";
        messageText.setAttribute("data-step", step);
        messageText.textContent = message || "";
        content.appendChild(circle);
        content.appendChild(messageText);
        cell.appendChild(content);
        row.appendChild(cell);
    }

    function applyCooldownSimulatorJiraProgress(progress) {
        if (progress.reset || !cooldownSimulatorJiraProgressDialog) {
            openCooldownSimulatorJiraProgressDialog(
                Array.isArray(progress.rows) ? progress.rows : [],
                progress.summary || "Preparing Jira updates...");
        } else if (Array.isArray(progress.rows)) {
            renderCooldownSimulatorJiraProgressRows(progress.rows);
        }

        if (!cooldownSimulatorJiraProgressDialog) {
            return;
        }

        if (progress.summary) {
            var summary = cooldownSimulatorJiraProgressDialog.querySelector("[data-role='cooldown-simulator-jira-summary']");
            if (summary) {
                summary.textContent = progress.summary;
            }
        }

        if (Array.isArray(progress.updates)) {
            progress.updates.forEach(function (update) {
                updateCooldownSimulatorJiraProgressStep(update);
            });
        }
    }

    function updateCooldownSimulatorJiraProgressStep(update) {
        if (!update) {
            return;
        }

        var rowId = String(update.rowId || update.issueKey || "").trim();
        var step = String(update.step || "").trim();
        var row = rowId ? cooldownSimulatorJiraProgressRows.get(rowId) : null;
        if (!row || !step) {
            return;
        }

        var dot = row.querySelector(".cooldown-simulator-jira-status-dot[data-step='" + step + "']");
        if (!dot) {
            return;
        }

        dot.className = "cooldown-simulator-jira-status-dot is-" + normalizeCooldownSimulatorJiraStepState(update.state);
        dot.title = update.message || "";
        dot.setAttribute("aria-label", update.message || step);
        var messageElement = row.querySelector(".cooldown-simulator-jira-status-message[data-step='" + step + "']");
        if (messageElement) {
            messageElement.textContent = update.message || "";
        }
    }

    function normalizeCooldownSimulatorJiraStepState(state) {
        var normalized = String(state || "").trim().toLowerCase();
        if (normalized === "success" || normalized === "warning" || normalized === "failed") {
            return normalized;
        }

        return "pending";
    }

    function postMailoStateToFrames() {
        if (!workspaceHost) {
            return;
        }

        var frames = workspaceHost.querySelectorAll(".workspace-html-frame[data-workspace-type='mailo-v2']");
        frames.forEach(function (frame) {
            if (!frame.contentWindow) {
                return;
            }

            try {
                frame.contentWindow.postMessage({
                    type: "mailo-state",
                    state: currentMailoState
                }, "*");
            } catch (error) {
            }
        });
    }

    function syncEmbeddedWorkspaceThemes(themeName) {
        if (!workspaceHost) {
            return;
        }

        var frames = workspaceHost.querySelectorAll(".workspace-html-frame");
        frames.forEach(function (frame) {
            syncEmbeddedWorkspaceFrameTheme(frame, themeName);
        });
    }

    function syncEmbeddedWorkspaceFrameTheme(frame, themeName) {
        if (!frame || !frame.contentWindow) {
            return;
        }

        try {
            frame.contentWindow.postMessage({
                type: "form3-theme",
                themeName: themeName || "dark"
            }, "*");
        } catch (error) {
        }
    }

    function updateCooldownSimulatorWorkspacePanels() {
        if (!workspaceHost) {
            return;
        }

        var panels = workspaceHost.querySelectorAll(".workspace-panel");
        panels.forEach(function (panel) {
            updateCooldownSimulatorWorkspacePanel(panel);
        });
    }

    function updateCooldownSimulatorWorkspacePanel(panel) {
        if (!panel || !panel.querySelector(".workspace-cooldown-simulator")) {
            return;
        }

        var selectionDisplay = panel.querySelector("[data-role='cooldown-simulator-selection']");
        var errorDisplay = panel.querySelector("[data-role='cooldown-simulator-error']");
        var channelsContainer = panel.querySelector("[data-role='cooldown-simulator-channels']");
        var visibleColumnsContainer = panel.querySelector("[data-role='cooldown-simulator-visible-columns']");
        var validationSummaryContainer = panel.querySelector("[data-role='cooldown-simulator-validation-summary']");
        var validationTableContainer = panel.querySelector("[data-role='cooldown-simulator-validation-table']");
        var optimizationSummaryContainer = panel.querySelector("[data-role='cooldown-simulator-optimization-summary']");
        var analysisModeDisplay = panel.querySelector("[data-role='cooldown-simulator-analysis-mode']");
        var saveStateButton = panel.querySelector("[data-role='cooldown-simulator-save-state']");
        var resetStateButton = panel.querySelector("[data-role='cooldown-simulator-reset-state']");
        var improveDelaysButton = panel.querySelector("[data-role='cooldown-simulator-improve-delays']");
        var priorityProcessButton = panel.querySelector("[data-role='cooldown-simulator-priority-process']");
        var resultsErrorDisplay = panel.querySelector("[data-role='cooldown-simulator-results-error']");
        var resultsWarningDisplay = panel.querySelector("[data-role='cooldown-simulator-results-warning']");
        var exportStatusDisplay = panel.querySelector("[data-role='cooldown-simulator-export-status']");
        var resultsContainer = panel.querySelector("[data-role='cooldown-simulator-results']");
        if (!selectionDisplay || !errorDisplay || !channelsContainer || !visibleColumnsContainer || !validationSummaryContainer || !validationTableContainer || !optimizationSummaryContainer || !analysisModeDisplay || !saveStateButton || !resetStateButton || !improveDelaysButton || !priorityProcessButton || !resultsErrorDisplay || !resultsWarningDisplay || !exportStatusDisplay || !resultsContainer) {
            return;
        }

        var selectedPath = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.selectedCsvPath === "string"
            ? currentCooldownSimulatorState.selectedCsvPath
            : "";
        var stateRevision = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.stateRevision === "number"
            ? currentCooldownSimulatorState.stateRevision
            : 0;
        var errorMessage = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.errorMessage === "string"
            ? currentCooldownSimulatorState.errorMessage
            : "";
        var channels = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.channels)
            ? currentCooldownSimulatorState.channels
            : [];
        var savedSelectedChannels = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.selectedChannels)
            ? currentCooldownSimulatorState.selectedChannels
            : [];
        var hasSavedSelectedChannels = !!(currentCooldownSimulatorState &&
            Array.isArray(currentCooldownSimulatorState.selectedChannels));
        var savedVisibleColumnKeys = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.visibleColumnKeys)
            ? currentCooldownSimulatorState.visibleColumnKeys
            : [];
        var hasImportBaseline = !!(currentCooldownSimulatorState && currentCooldownSimulatorState.hasImportBaseline);
        var validationIssueCount = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.validationIssueCount === "number"
            ? currentCooldownSimulatorState.validationIssueCount
            : 0;
        var autoExcludedPrmMissingAudienceCount = currentCooldownSimulatorState &&
            typeof currentCooldownSimulatorState.autoExcludedPrmMissingAudienceCount === "number"
            ? currentCooldownSimulatorState.autoExcludedPrmMissingAudienceCount
            : 0;
        var hasBlockingImportIssues = !!(currentCooldownSimulatorState && currentCooldownSimulatorState.hasBlockingImportIssues);
        var invalidRows = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.invalidRows)
            ? currentCooldownSimulatorState.invalidRows
            : [];
        var validationRows = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.validationRows)
            ? currentCooldownSimulatorState.validationRows
            : invalidRows;
        var analysisModeLabel = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.analysisModeLabel === "string"
            ? currentCooldownSimulatorState.analysisModeLabel
            : "";
        var analysisErrorMessage = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.analysisErrorMessage === "string"
            ? currentCooldownSimulatorState.analysisErrorMessage
            : "";
        var analysisWarningMessage = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.analysisWarningMessage === "string"
            ? currentCooldownSimulatorState.analysisWarningMessage
            : "";
        var exportMessage = currentCooldownSimulatorState && typeof currentCooldownSimulatorState.exportMessage === "string"
            ? currentCooldownSimulatorState.exportMessage
            : "";
        var exportMessageIsError = !!(currentCooldownSimulatorState && currentCooldownSimulatorState.exportMessageIsError);
        var canImproveDelays = !!(currentCooldownSimulatorState && currentCooldownSimulatorState.canImproveDelays);
        var lastPriorityProcessTrace = currentCooldownSimulatorState && currentCooldownSimulatorState.lastPriorityProcessTrace
            ? currentCooldownSimulatorState.lastPriorityProcessTrace
            : null;
        var optimizationSummary = currentCooldownSimulatorState && currentCooldownSimulatorState.optimizationSummary
            ? currentCooldownSimulatorState.optimizationSummary
            : null;
        var analysisResults = currentCooldownSimulatorState && Array.isArray(currentCooldownSimulatorState.analysisResults)
            ? currentCooldownSimulatorState.analysisResults
            : [];
        var previousStateRevision = parseInt(panel.getAttribute("data-cooldown-state-revision") || "", 10);
        var preserveChannelSelection = previousStateRevision === stateRevision;
        var previouslyCheckedChannels = new Set();

        if (!preserveChannelSelection) {
            if (savedVisibleColumnKeys.length > 0) {
                setCooldownSimulatorVisibleColumns(savedVisibleColumnKeys);
            } else {
                resetCooldownSimulatorVisibleColumns();
            }
        }

        if (preserveChannelSelection) {
            panel.querySelectorAll(".cooldown-simulator-channel-item input[type='checkbox']").forEach(function (checkbox) {
                if (checkbox.checked && typeof checkbox.value === "string" && checkbox.value.length > 0) {
                    previouslyCheckedChannels.add(checkbox.value.toLowerCase());
                }
            });
        }

        panel.setAttribute("data-cooldown-state-revision", String(stateRevision));

        selectionDisplay.textContent = selectedPath && selectedPath.length > 0
            ? selectedPath
            : "No CSV or saved state selected.";
        errorDisplay.textContent = errorMessage;
        errorDisplay.style.display = errorMessage && errorMessage.length > 0 ? "block" : "none";
        analysisModeDisplay.textContent = analysisModeLabel;
        analysisModeDisplay.style.display = analysisModeLabel && analysisModeLabel.length > 0 ? "block" : "none";
        resultsErrorDisplay.textContent = analysisErrorMessage;
        resultsErrorDisplay.style.display = analysisErrorMessage && analysisErrorMessage.length > 0 ? "block" : "none";
        resultsWarningDisplay.textContent = analysisWarningMessage;
        resultsWarningDisplay.style.display = analysisWarningMessage && analysisWarningMessage.length > 0 ? "block" : "none";
        exportStatusDisplay.textContent = exportMessage;
        exportStatusDisplay.style.display = exportMessage && exportMessage.length > 0 ? "block" : "none";
        exportStatusDisplay.classList.toggle("is-error", exportMessageIsError);
        exportStatusDisplay.classList.toggle("is-success", !!exportMessage && !exportMessageIsError);
        saveStateButton.disabled = !hasImportBaseline;
        resetStateButton.disabled = !hasImportBaseline;
        improveDelaysButton.style.display = canImproveDelays ? "inline-block" : "none";
        priorityProcessButton.disabled = !lastPriorityProcessTrace;
        renderCooldownSimulatorValidation(
            validationSummaryContainer,
            validationTableContainer,
            validationIssueCount,
            autoExcludedPrmMissingAudienceCount,
            validationRows,
            hasBlockingImportIssues);
        renderCooldownSimulatorOptimizationSummary(optimizationSummaryContainer, optimizationSummary);
        resultsContainer.innerHTML = "";

        channelsContainer.innerHTML = "";
        var channelTitle = document.createElement("div");
        channelTitle.className = "cooldown-simulator-control-title";
        channelTitle.textContent = "Analysis channels";
        channelsContainer.appendChild(channelTitle);
        renderCooldownSimulatorVisibleColumnControls(visibleColumnsContainer);
        if (errorMessage && errorMessage.length > 0) {
            return;
        }

        if (!channels.length) {
            return;
        }

        channels.forEach(function (channelName, index) {
            var item = document.createElement("label");
            var checkbox = document.createElement("input");
            var textNode = document.createElement("span");
            var displayChannelName = normalizeCooldownSimulatorChannelName(channelName);
            var isSimulatedChannel = isCooldownSimulatorSimulatedChannelName(displayChannelName);

            item.className = "cooldown-simulator-channel-item";
            item.style.display = "block";
            item.style.marginTop = "6px";
            if (!isSimulatedChannel) {
                item.style.opacity = "0.85";
            }

            checkbox.type = "checkbox";
            checkbox.checked = !preserveChannelSelection && hasSavedSelectedChannels
                ? savedSelectedChannels.some(function (selectedChannel) {
                    return String(selectedChannel).toLowerCase() === String(displayChannelName).toLowerCase();
                })
                : preserveChannelSelection
                ? previouslyCheckedChannels.has(String(channelName).toLowerCase())
                : true;
            checkbox.value = displayChannelName;
            checkbox.name = "cooldown-simulator-channel-" + index;

            textNode.textContent = isSimulatedChannel
                ? " " + displayChannelName
                : " " + displayChannelName + " (not simulated)";

            item.appendChild(checkbox);
            item.appendChild(textNode);
            channelsContainer.appendChild(item);
        });
        if (analysisErrorMessage && analysisErrorMessage.length > 0) {
            return;
        }

        if (!analysisResults.length) {
            return;
        }

        analysisResults.forEach(function (result) {
            var card = document.createElement("div");
            var heading = document.createElement("h4");
            var total = document.createElement("div");
            var delayed = document.createElement("div");
            var expired = document.createElement("div");
            var maxDelayDays = document.createElement("div");
            var missingProvidedSeverity = document.createElement("div");
            var summaryNote = document.createElement("div");
            var detailsContainer = document.createElement("div");
            var detailItems = Array.isArray(result.items)
                ? result.items
                : (Array.isArray(result.Items) ? result.Items : []);
            var isSimulatedResult = isCooldownSimulatorAnalysisItemSimulated(result);
            var resultSummaryNote = result.summaryNote || result.SummaryNote || "";
            var prioritySearchStatus = result.prioritySearchStatus || result.PrioritySearchStatus || "";
            var prioritySearchMessage = result.prioritySearchMessage || result.PrioritySearchMessage || "";

            card.className = "cooldown-simulator-result-card";
            card.style.marginTop = "12px";
            card.style.padding = "12px";
            card.style.border = isSimulatedResult
                ? "1px solid rgba(255,255,255,0.15)"
                : "1px solid rgba(138, 180, 248, 0.35)";
            card.style.borderRadius = "10px";

            heading.textContent = formatCooldownSimulatorChannelRegionLabel(
                result.channel || result.Channel || "Unknown channel",
                result.regionGroup || result.RegionGroup || "");
            total.textContent = "Total: " + formatCooldownSimulatorMetric(result.total, result.Total);
            delayed.textContent = "Delayed: " + formatCooldownSimulatorMetric(result.delayed, result.Delayed);
            expired.textContent = "Expired: " + formatCooldownSimulatorMetric(result.expired, result.Expired);
            maxDelayDays.textContent = "Max delay days: " + formatCooldownSimulatorMetric(result.maxDelayDays, result.MaxDelayDays);
            missingProvidedSeverity.textContent = "Launches without provided severity: " +
                formatCooldownSimulatorMetric(result.missingProvidedSeverityCount, result.MissingProvidedSeverityCount);
            delayed.style.color = formatCooldownSimulatorMetric(result.delayed, result.Delayed) === "0" ? "" : "#ffd57d";
            expired.style.color = formatCooldownSimulatorMetric(result.expired, result.Expired) === "0" ? "" : "#ff9fb2";
            delayed.style.fontWeight = formatCooldownSimulatorMetric(result.delayed, result.Delayed) === "0" ? "" : "700";
            expired.style.fontWeight = formatCooldownSimulatorMetric(result.expired, result.Expired) === "0" ? "" : "700";
            summaryNote.textContent = prioritySearchMessage || resultSummaryNote || "Not simulated (PRM channel)";
            summaryNote.style.marginTop = "6px";
            summaryNote.style.opacity = "0.85";

            card.appendChild(heading);
            if (isSimulatedResult) {
                card.appendChild(total);
                card.appendChild(delayed);
                card.appendChild(expired);
                card.appendChild(maxDelayDays);
                card.appendChild(missingProvidedSeverity);
                if (prioritySearchStatus || prioritySearchMessage) {
                    summaryNote.style.color = (result.zeroExpirationGuaranteed || result.ZeroExpirationGuaranteed)
                        ? "#a7f3d0"
                        : "#ffd57d";
                    card.appendChild(summaryNote);
                }
            } else {
                card.appendChild(summaryNote);
            }
            detailsContainer.className = "cooldown-simulator-result-details";

            if (detailItems.length) {
                var resultRows = detailItems;
                var detailsTable = document.createElement("table");
                var detailsHead = document.createElement("thead");
                var detailsHeadRow = document.createElement("tr");
                var detailsBody = document.createElement("tbody");
                var fullColumns = getCooldownSimulatorAnalysisColumns();
                var visibleColumns = getCooldownSimulatorVisibleAnalysisColumns(fullColumns);
                var detailsColGroup = document.createElement("colgroup");

                detailsContainer.classList.add("cooldown-simulator-analysis-details");
                detailsTable.className = "cooldown-simulator-analysis-table";
                detailsTable.style.setProperty("--cooldown-analysis-visible-column-count", String(Math.max(1, visibleColumns.length)));
                visibleColumns.forEach(function (column) {
                    var col = document.createElement("col");
                    var headerCell = document.createElement("th");

                    col.className = "cooldown-simulator-analysis-col cooldown-simulator-analysis-col-" + column.key;
                    headerCell.className = "cooldown-simulator-analysis-cell cooldown-simulator-analysis-cell-" + column.key;
                    headerCell.textContent = column.label;
                    detailsColGroup.appendChild(col);
                    detailsHeadRow.appendChild(headerCell);
                });

                detailsTable.appendChild(detailsColGroup);
                detailsHead.appendChild(detailsHeadRow);
                detailsTable.appendChild(detailsHead);

                resultRows.forEach(function (item) {
                    var row = document.createElement("tr");
                    var isEditableRow = canImproveDelays && isCooldownSimulatorAnalysisItemSimulated(item);
                    applyCooldownSimulatorRowStatusStyling(row, item);
                    visibleColumns.forEach(function (column) {
                        appendCooldownSimulatorAnalysisColumnCell(row, column.key, item, isEditableRow);
                    });
                    if (row.cells.length === 0) {
                        appendCooldownSimulatorAnalysisColumnCell(row, "issue", item, isEditableRow);
                    }
                    detailsBody.appendChild(row);
                });

                detailsTable.appendChild(detailsBody);
                detailsContainer.appendChild(detailsTable);
            }

            card.appendChild(detailsContainer);
            resultsContainer.appendChild(card);
        });
    }

    function appendCooldownSimulatorDetailCell(row, value) {
        var cell = document.createElement("td");
        cell.textContent = formatCooldownSimulatorCellText(value);
        row.appendChild(cell);
    }

    function formatCooldownSimulatorCellText(value) {
        var text = String(value === null || value === undefined ? "" : value).trim();
        return text || "\u2014";
    }

    function getCooldownSimulatorAnalysisColumns() {
        return [
            { key: "issue", label: "Issue" },
            { key: "title", label: "Title" },
            { key: "channel", label: "Channel" },
            { key: "region", label: "Region" },
            { key: "audience", label: "Audience" },
            { key: "provided-severity", label: "Provided Severity" },
            { key: "suggested-severity", label: "Suggested Severity" },
            { key: "effective-severity", label: "Effective Severity" },
            { key: "important-launch", label: "Important Launch" },
            { key: "start-date", label: "Start Date" },
            { key: "end-date", label: "End Date" },
            { key: "status", label: "Status" },
            { key: "planned-date", label: "Planned Date" },
            { key: "actual-date", label: "Actual Date" }
        ];
    }

    function resetCooldownSimulatorVisibleColumns() {
        cooldownSimulatorVisibleColumnKeys = new Set(getCooldownSimulatorAnalysisColumns().map(function (column) {
            return column.key;
        }));
    }

    function setCooldownSimulatorVisibleColumns(columnKeys) {
        var knownColumnKeys = new Set(getCooldownSimulatorAnalysisColumns().map(function (column) {
            return column.key;
        }));
        var nextColumnKeys = new Set();
        (Array.isArray(columnKeys) ? columnKeys : []).forEach(function (columnKey) {
            var normalizedKey = String(columnKey || "").trim();
            if (knownColumnKeys.has(normalizedKey)) {
                nextColumnKeys.add(normalizedKey);
            }
        });

        cooldownSimulatorVisibleColumnKeys = nextColumnKeys.size > 0
            ? nextColumnKeys
            : new Set(["issue"]);
    }

    function collectCooldownSimulatorVisibleColumnKeys() {
        return Array.from(ensureCooldownSimulatorVisibleColumnKeys());
    }

    function ensureCooldownSimulatorVisibleColumnKeys() {
        var analysisColumns = getCooldownSimulatorAnalysisColumns();
        var knownColumnKeys = new Set(analysisColumns.map(function (column) {
            return column.key;
        }));
        if (!(cooldownSimulatorVisibleColumnKeys instanceof Set)) {
            resetCooldownSimulatorVisibleColumns();
        } else {
            cooldownSimulatorVisibleColumnKeys.forEach(function (columnKey) {
                if (!knownColumnKeys.has(columnKey)) {
                    cooldownSimulatorVisibleColumnKeys.delete(columnKey);
                }
            });
        }

        if (!cooldownSimulatorVisibleColumnKeys || cooldownSimulatorVisibleColumnKeys.size === 0) {
            cooldownSimulatorVisibleColumnKeys = new Set(["issue"]);
        }

        return cooldownSimulatorVisibleColumnKeys;
    }

    function getCooldownSimulatorVisibleAnalysisColumns(fullColumns) {
        var analysisColumns = Array.isArray(fullColumns)
            ? fullColumns
            : getCooldownSimulatorAnalysisColumns();
        var visibleColumnKeys = ensureCooldownSimulatorVisibleColumnKeys();
        var visibleColumns = analysisColumns.filter(function (column) {
            return visibleColumnKeys.has(column.key);
        });
        if (!visibleColumns.length) {
            visibleColumnKeys.add("issue");
            visibleColumns = analysisColumns.filter(function (column) {
                return visibleColumnKeys.has(column.key);
            });
        }

        return visibleColumns;
    }

    function renderCooldownSimulatorVisibleColumnControls(container) {
        if (!container) {
            return;
        }

        var columns = getCooldownSimulatorAnalysisColumns();
        var visibleColumnKeys = ensureCooldownSimulatorVisibleColumnKeys();
        var header = document.createElement("div");
        var title = document.createElement("div");
        var actions = document.createElement("div");
        var selectAllButton = document.createElement("button");
        var resetButton = document.createElement("button");
        var list = document.createElement("div");
        var note = document.createElement("div");

        container.innerHTML = "";
        header.className = "cooldown-simulator-visible-columns-header";
        title.className = "cooldown-simulator-control-title";
        title.textContent = "Visible columns";
        actions.className = "cooldown-simulator-visible-columns-actions";
        selectAllButton.type = "button";
        selectAllButton.className = "cooldown-simulator-inline-action";
        selectAllButton.textContent = "Select all";
        resetButton.type = "button";
        resetButton.className = "cooldown-simulator-inline-action";
        resetButton.textContent = "Reset columns";
        actions.appendChild(selectAllButton);
        actions.appendChild(resetButton);
        header.appendChild(title);
        header.appendChild(actions);

        list.className = "cooldown-simulator-visible-columns-list";
        columns.forEach(function (column) {
            var label = document.createElement("label");
            var checkbox = document.createElement("input");
            var text = document.createElement("span");

            label.className = "cooldown-simulator-column-item";
            checkbox.type = "checkbox";
            checkbox.value = column.key;
            checkbox.checked = visibleColumnKeys.has(column.key);
            text.textContent = column.label;
            label.appendChild(checkbox);
            label.appendChild(text);
            list.appendChild(label);
        });

        note.className = "cooldown-simulator-visible-columns-note";
        note.textContent = "At least one result column stays visible.";

        selectAllButton.addEventListener("click", function () {
            resetCooldownSimulatorVisibleColumns();
            updateCooldownSimulatorWorkspacePanels();
        });
        resetButton.addEventListener("click", function () {
            resetCooldownSimulatorVisibleColumns();
            updateCooldownSimulatorWorkspacePanels();
        });
        list.addEventListener("change", function () {
            var nextVisibleKeys = new Set();
            list.querySelectorAll("input[type='checkbox']").forEach(function (checkbox) {
                if (checkbox.checked && checkbox.value) {
                    nextVisibleKeys.add(checkbox.value);
                }
            });

            if (nextVisibleKeys.size === 0) {
                nextVisibleKeys.add("issue");
            }

            cooldownSimulatorVisibleColumnKeys = nextVisibleKeys;
            updateCooldownSimulatorWorkspacePanels();
        });

        container.appendChild(header);
        container.appendChild(list);
        container.appendChild(note);
    }

    function appendCooldownSimulatorAnalysisColumnCell(row, columnKey, item, isEditableRow) {
        item = item || {};
        var cellCountBefore = row.cells.length;
        try {
            switch (columnKey) {
                case "issue":
                    appendCooldownSimulatorIssueCell(
                        row,
                        item.issueKey || item.IssueKey || "",
                        item.issueUrl || item.IssueUrl || "");
                    break;
                case "title":
                    appendCooldownSimulatorTitleCell(
                        row,
                        item.title || item.Title || "",
                        item.issueKey || item.IssueKey || "",
                        item.issueUrl || item.IssueUrl || "");
                    break;
                case "channel":
                    appendCooldownSimulatorDetailCell(row, formatCooldownSimulatorItemChannel(item));
                    break;
                case "region":
                    appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorRegionGroup(item.regionGroup || item.RegionGroup || ""));
                    break;
                case "audience":
                    appendCooldownSimulatorAudienceSelectionCell(row, item, true);
                    break;
                case "provided-severity":
                    appendCooldownSimulatorDetailCell(row, item.providedSeverity || item.ProvidedSeverity || "");
                    break;
                case "suggested-severity":
                    appendCooldownSimulatorDetailCell(row, item.suggestedSeverity || item.SuggestedSeverity || "");
                    break;
                case "effective-severity":
                    appendCooldownSimulatorEffectiveSeverityCell(row, item, isEditableRow);
                    break;
                case "important-launch":
                    appendCooldownSimulatorImportantLaunchCell(row, item, isEditableRow);
                    break;
                case "start-date":
                    appendCooldownSimulatorDateEditorCell(row, item, "start");
                    break;
                case "end-date":
                    appendCooldownSimulatorDateEditorCell(row, item, "end");
                    break;
                case "status":
                    appendCooldownSimulatorStatusCell(row, item);
                    break;
                case "planned-date":
                    appendCooldownSimulatorDetailCell(row, item.plannedDate || item.PlannedDate || "");
                    break;
                case "actual-date":
                    appendCooldownSimulatorDetailCell(row, item.actualDate || item.ActualDate || "");
                    break;
                default:
                    appendCooldownSimulatorDetailCell(row, "");
                    break;
            }
        } catch (error) {
            logCooldownSimulatorCellRenderError(columnKey, item, error);
            appendCooldownSimulatorCellErrorPlaceholder(row, columnKey);
        }

        if (row.cells.length <= cellCountBefore) {
            appendCooldownSimulatorDetailCell(row, "");
        }

        row.cells[row.cells.length - 1].classList.add(
            "cooldown-simulator-analysis-cell",
            "cooldown-simulator-analysis-cell-" + columnKey);
    }

    function appendCooldownSimulatorCellErrorPlaceholder(row, columnKey) {
        var cell = document.createElement("td");
        cell.className = "cooldown-simulator-cell-error";
        cell.textContent = "\u2014";
        cell.title = "This " + String(columnKey || "column") + " cell could not be rendered.";
        row.appendChild(cell);
    }

    function logCooldownSimulatorCellRenderError(columnKey, item, error) {
        if (!window.console || typeof window.console.warn !== "function") {
            return;
        }

        window.console.warn("[FORM3-COOLDOWN][JS] result cell render failed", {
            columnKey: columnKey || "",
            sourceRowIndex: getCooldownSimulatorItemSourceRowIndex(item),
            issueKey: item && (item.issueKey || item.IssueKey || ""),
            title: item && (item.title || item.Title || ""),
            message: error && error.message ? error.message : String(error || "")
        });
    }

    function appendCooldownSimulatorInfoButton(container, tooltipText, ariaLabel, accentColor) {
        if (!container || !tooltipText) {
            return;
        }

        var resolvedAccent = accentColor || getCooldownSimulatorStatusAccent("");
        var infoButton = document.createElement("button");
        infoButton.type = "button";
        infoButton.textContent = "i";
        infoButton.setAttribute("aria-label", ariaLabel || "Show more information");
        infoButton.style.width = "18px";
        infoButton.style.height = "18px";
        infoButton.style.padding = "0";
        infoButton.style.borderRadius = "999px";
        infoButton.style.border = "1px solid " + resolvedAccent.border;
        infoButton.style.background = resolvedAccent.background;
        infoButton.style.color = resolvedAccent.icon;
        infoButton.style.fontSize = "11px";
        infoButton.style.fontWeight = "700";
        infoButton.style.lineHeight = "1";
        infoButton.style.cursor = "help";

        infoButton.addEventListener("mouseenter", function () {
            showCooldownSimulatorTooltip(infoButton, tooltipText);
        });
        infoButton.addEventListener("mouseleave", hideCooldownSimulatorTooltip);
        infoButton.addEventListener("focus", function () {
            showCooldownSimulatorTooltip(infoButton, tooltipText);
        });
        infoButton.addEventListener("blur", hideCooldownSimulatorTooltip);

        container.appendChild(infoButton);
    }

    function appendCooldownSimulatorStatusCell(row, item) {
        var cell = document.createElement("td");
        var statusText = formatCooldownSimulatorCellText(formatCooldownSimulatorItemStatus(item));
        var delayDisplay = item && (item.delayDisplay || item.DelayDisplay || "");
        var status = item && (item.status || item.Status || "");
        var explanationText = getCooldownSimulatorStatusExplanationText(item);
        var accentColor = getCooldownSimulatorStatusAccent(status);

        cell.textContent = statusText;
        cell.style.color = accentColor.text;
        cell.style.fontWeight = accentColor.text ? "700" : "";
        if (!shouldShowCooldownSimulatorStatusExplanationIcon(status, delayDisplay, explanationText)) {
            row.appendChild(cell);
            return;
        }

        cell.textContent = "";
        var content = document.createElement("span");
        var textNode = document.createElement("span");

        content.style.display = "inline-flex";
        content.style.alignItems = "center";
        content.style.gap = "6px";

        textNode.textContent = statusText;

        content.appendChild(textNode);
        appendCooldownSimulatorInfoButton(
            content,
            explanationText,
            status === "expired" ? "Show expiration explanation" : "Show delay explanation",
            accentColor);
        cell.appendChild(content);
        row.appendChild(cell);
    }

    function appendCooldownSimulatorIssueCell(row, issueKey, issueUrl) {
        var cell = document.createElement("td");
        var normalizedIssueKey = String(issueKey || "").trim();
        if (!normalizedIssueKey) {
            cell.textContent = "";
            row.appendChild(cell);
            return;
        }

        appendCooldownSimulatorIssueLink(cell, normalizedIssueKey, issueUrl);
        row.appendChild(cell);
    }

    function appendCooldownSimulatorTitleCell(row, title, issueKey, issueUrl) {
        var cell = document.createElement("td");
        var normalizedTitle = String(title || "").trim();
        var normalizedIssueKey = String(issueKey || "").trim();

        if (!normalizedTitle && !normalizedIssueKey) {
            cell.textContent = "";
            row.appendChild(cell);
            return;
        }

        if (normalizedTitle) {
            cell.appendChild(document.createTextNode(normalizedTitle));
        }

        if (normalizedIssueKey) {
            if (normalizedTitle) {
                cell.appendChild(document.createTextNode(" ("));
                appendCooldownSimulatorIssueLink(cell, normalizedIssueKey, issueUrl);
                cell.appendChild(document.createTextNode(")"));
            } else {
                appendCooldownSimulatorIssueLink(cell, normalizedIssueKey, issueUrl);
            }
        }

        row.appendChild(cell);
    }

    function appendCooldownSimulatorIssueLink(container, issueKey, issueUrl) {
        var link = document.createElement("a");
        var normalizedIssueKey = String(issueKey || "").trim();
        var normalizedIssueUrl = String(issueUrl || "").trim();

        link.href = normalizedIssueUrl || "#";
        link.textContent = normalizedIssueKey;
        styleCooldownSimulatorLink(link);
        link.addEventListener("click", function (event) {
            event.preventDefault();
            if (!normalizedIssueUrl) {
                return;
            }

            postCooldownSimulatorAction("open-issue-link", [], {
                issueUrl: normalizedIssueUrl
            });
        });

        container.appendChild(link);
    }

    function applyCooldownSimulatorRowStatusStyling(row, item) {
        if (!row) {
            return;
        }

        var status = item && (item.status || item.Status || "");
        if (status === "expired") {
            row.style.background = "rgba(120, 22, 38, 0.30)";
            row.style.boxShadow = "inset 3px 0 0 rgba(255, 125, 153, 0.90)";
            return;
        }

        if (status === "delayed") {
            row.style.background = "rgba(255, 205, 120, 0.12)";
            row.style.boxShadow = "inset 3px 0 0 rgba(255, 205, 120, 0.72)";
            return;
        }

        if (status === "not_simulated") {
            row.style.background = "rgba(112, 162, 212, 0.08)";
            row.style.boxShadow = "inset 3px 0 0 rgba(138, 180, 248, 0.50)";
            return;
        }

        if (status === "excluded") {
            row.style.background = "rgba(148, 163, 184, 0.08)";
            row.style.boxShadow = "inset 3px 0 0 rgba(148, 163, 184, 0.38)";
            return;
        }

        row.style.background = "";
        row.style.boxShadow = "";
    }

    function styleCooldownSimulatorLink(link) {
        if (!link) {
            return;
        }

        link.style.color = "#8AB4F8";
        link.style.textDecoration = "underline";
        link.style.textUnderlineOffset = "2px";
        link.style.textDecorationColor = "rgba(138, 180, 248, 0.55)";
        link.addEventListener("mouseenter", function () {
            link.style.color = "#CDE3FF";
            link.style.textDecorationColor = "rgba(205, 227, 255, 0.85)";
        });
        link.addEventListener("mouseleave", function () {
            link.style.color = "#8AB4F8";
            link.style.textDecorationColor = "rgba(138, 180, 248, 0.55)";
        });
        link.addEventListener("focus", function () {
            link.style.color = "#CDE3FF";
            link.style.textDecorationColor = "rgba(205, 227, 255, 0.85)";
        });
        link.addEventListener("blur", function () {
            link.style.color = "#8AB4F8";
            link.style.textDecorationColor = "rgba(138, 180, 248, 0.55)";
        });
    }

    function getCooldownSimulatorDelayExplanation(item) {
        return item && typeof item === "object"
            ? (item.delayExplanation || item.DelayExplanation || null)
            : null;
    }

    function getCooldownSimulatorExpirationExplanation(item) {
        return item && typeof item === "object"
            ? (item.expirationExplanation || item.ExpirationExplanation || null)
            : null;
    }

    function getCooldownSimulatorStatusExplanation(item) {
        var status = item && (item.status || item.Status || "");
        if (status === "expired") {
            return getCooldownSimulatorExpirationExplanation(item);
        }

        if (status === "delayed") {
            return getCooldownSimulatorDelayExplanation(item);
        }

        return null;
    }

    function getCooldownSimulatorStatusExplanationText(item) {
        var status = item && (item.status || item.Status || "");
        var explanation = getCooldownSimulatorStatusExplanation(item);
        var explanationText = explanation && (explanation.explanationText || explanation.ExplanationText || "");
        if (explanationText) {
            return explanationText;
        }

        var delayDisplay = item && (item.delayDisplay || item.DelayDisplay || "");
        if (status === "delayed" && delayDisplay) {
            return "Delayed by cooldown rules in this channel/region/audience partition.";
        }

        if (status === "expired") {
            return "Expired because cooldown rules left no valid send time before the end date.";
        }

        return "";
    }

    function shouldShowCooldownSimulatorStatusExplanationIcon(status, delayDisplay, explanationText) {
        if (!explanationText) {
            return false;
        }

        if (status === "delayed") {
            return !!delayDisplay;
        }

        return status === "expired";
    }

    function getCooldownSimulatorStatusAccent(status) {
        if (status === "expired") {
            return {
                text: "#ffb3c2",
                border: "rgba(255, 125, 153, 0.55)",
                background: "rgba(255, 125, 153, 0.16)",
                icon: "#ffe4ea"
            };
        }

        if (status === "delayed") {
            return {
                text: "#ffd57d",
                border: "rgba(255, 205, 120, 0.45)",
                background: "rgba(255, 205, 120, 0.14)",
                icon: "#fff1c4"
            };
        }

        return {
            text: "",
            border: "rgba(138, 180, 248, 0.45)",
            background: "rgba(138, 180, 248, 0.14)",
            icon: "#CDE3FF"
        };
    }

    function ensureCooldownSimulatorTooltip() {
        if (cooldownSimulatorTooltip) {
            return cooldownSimulatorTooltip;
        }

        cooldownSimulatorTooltip = document.createElement("div");
        cooldownSimulatorTooltip.style.position = "fixed";
        cooldownSimulatorTooltip.style.zIndex = "9999";
        cooldownSimulatorTooltip.style.maxWidth = "360px";
        cooldownSimulatorTooltip.style.padding = "10px 12px";
        cooldownSimulatorTooltip.style.borderRadius = "10px";
        cooldownSimulatorTooltip.style.background = "rgba(15, 22, 34, 0.96)";
        cooldownSimulatorTooltip.style.border = "1px solid rgba(138, 180, 248, 0.35)";
        cooldownSimulatorTooltip.style.boxShadow = "0 12px 32px rgba(0, 0, 0, 0.38)";
        cooldownSimulatorTooltip.style.color = "#EAF2FF";
        cooldownSimulatorTooltip.style.fontSize = "12px";
        cooldownSimulatorTooltip.style.lineHeight = "1.45";
        cooldownSimulatorTooltip.style.pointerEvents = "none";
        cooldownSimulatorTooltip.style.whiteSpace = "normal";
        cooldownSimulatorTooltip.style.display = "none";
        document.body.appendChild(cooldownSimulatorTooltip);
        return cooldownSimulatorTooltip;
    }

    function showCooldownSimulatorTooltip(anchor, text) {
        if (!anchor || !text) {
            return;
        }

        var tooltip = ensureCooldownSimulatorTooltip();
        tooltip.textContent = text;
        tooltip.style.display = "block";
        positionCooldownSimulatorTooltip(anchor, tooltip);
    }

    function positionCooldownSimulatorTooltip(anchor, tooltip) {
        if (!anchor || !tooltip) {
            return;
        }

        var rect = anchor.getBoundingClientRect();
        var tooltipWidth = tooltip.offsetWidth || 320;
        var tooltipHeight = tooltip.offsetHeight || 80;
        var left = rect.left + (rect.width / 2) - (tooltipWidth / 2);
        var top = rect.bottom + 10;

        if (left < 12) {
            left = 12;
        }

        if (left + tooltipWidth > window.innerWidth - 12) {
            left = Math.max(12, window.innerWidth - tooltipWidth - 12);
        }

        if (top + tooltipHeight > window.innerHeight - 12) {
            top = rect.top - tooltipHeight - 10;
        }

        tooltip.style.left = Math.round(left) + "px";
        tooltip.style.top = Math.round(Math.max(12, top)) + "px";
    }

    function hideCooldownSimulatorTooltip() {
        if (!cooldownSimulatorTooltip) {
            return;
        }

        cooldownSimulatorTooltip.style.display = "none";
    }

    function appendCooldownSimulatorRegionCorrectionCell(row, rowItem) {
        var cell = document.createElement("td");
        var sourceRowIndex = rowItem && typeof rowItem.sourceRowIndex === "number"
            ? rowItem.sourceRowIndex
            : (rowItem && typeof rowItem.SourceRowIndex === "number" ? rowItem.SourceRowIndex : -1);
        var normalizedRegionGroup = normalizeCooldownSimulatorRegionGroup(rowItem && (rowItem.regionGroup || rowItem.RegionGroup || ""));
        var needsRegionCorrection = !!(rowItem && (rowItem.needsRegionCorrection || rowItem.NeedsRegionCorrection));
        var availableRegionCorrections = rowItem && Array.isArray(rowItem.availableRegionCorrections)
            ? rowItem.availableRegionCorrections
            : (rowItem && Array.isArray(rowItem.AvailableRegionCorrections) ? rowItem.AvailableRegionCorrections : []);

        if (!needsRegionCorrection || sourceRowIndex < 0 || !availableRegionCorrections.length) {
            cell.textContent = normalizedRegionGroup;
            row.appendChild(cell);
            return;
        }

        var select = document.createElement("select");
        var placeholderOption = document.createElement("option");
        placeholderOption.value = "";
        placeholderOption.textContent = "Choose...";
        placeholderOption.selected = true;
        placeholderOption.disabled = true;
        select.appendChild(placeholderOption);
        availableRegionCorrections.forEach(function (optionValue) {
            var option = document.createElement("option");
            option.value = String(optionValue || "");
            option.textContent = normalizeCooldownSimulatorRegionGroup(optionValue);
            select.appendChild(option);
        });
        select.addEventListener("change", function () {
            postCooldownSimulatorAction("set-launch-region", [], {
                sourceRowIndex: sourceRowIndex,
                regionSelection: select.value
            });
        });

        cell.appendChild(select);
        row.appendChild(cell);
    }

    function appendCooldownSimulatorAudienceSelectionCell(row, item, isEditable) {
        var cell = document.createElement("td");
        var container = document.createElement("span");
        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var audienceSelectionMode = formatCooldownSimulatorAudienceSelectionMode(item);
        var rawLocation = String(item && (item.rawLocation || item.RawLocation || "") || "").trim();
        var availableAudienceCorrections = item && Array.isArray(item.availableAudienceCorrections)
            ? item.availableAudienceCorrections
            : (item && Array.isArray(item.AvailableAudienceCorrections) ? item.AvailableAudienceCorrections : []);
        var options = availableAudienceCorrections.length
            ? availableAudienceCorrections
            : ["MAU", "NAU", "BOTH", "EXCLUDE"];
        var needsAudienceCorrection = !!(item && (item.needsAudienceCorrection || item.NeedsAudienceCorrection));

        container.style.display = "inline-flex";
        container.style.alignItems = "center";
        container.style.gap = "6px";

        if (!isEditable || sourceRowIndex < 0) {
            container.appendChild(document.createTextNode(audienceSelectionMode || formatCooldownSimulatorItemAudience(item)));
            if (rawLocation) {
                appendCooldownSimulatorInfoButton(
                    container,
                    "Raw location: " + rawLocation,
                    "Show raw location");
            }
            cell.appendChild(container);
            row.appendChild(cell);
            return;
        }

        var select = document.createElement("select");
        if (!audienceSelectionMode && needsAudienceCorrection) {
            var placeholderOption = document.createElement("option");
            placeholderOption.value = "";
            placeholderOption.textContent = "Choose...";
            placeholderOption.selected = true;
            placeholderOption.disabled = true;
            select.appendChild(placeholderOption);
        }

        options.forEach(function (optionValue) {
            var option = document.createElement("option");
            option.value = String(optionValue || "");
            option.textContent = String(optionValue || "");
            option.selected = option.value === audienceSelectionMode;
            select.appendChild(option);
        });

        select.addEventListener("change", function () {
            postCooldownSimulatorAction("set-launch-audience", [], {
                sourceRowIndex: sourceRowIndex,
                audienceSelectionMode: select.value
            });
        });

        container.appendChild(select);
        if (rawLocation) {
            appendCooldownSimulatorInfoButton(
                container,
                "Raw location: " + rawLocation,
                "Show raw location");
        }
        cell.appendChild(container);
        row.appendChild(cell);
    }

    function appendCooldownSimulatorDateEditorCell(row, item, fieldName) {
        var cell = document.createElement("td");
        var container = document.createElement("div");
        var inputRow = document.createElement("div");
        var input = document.createElement("input");
        var error = document.createElement("div");
        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var value = fieldName === "end"
            ? String(item && (item.endDate || item.EndDate || "") || "")
            : String(item && (item.plannedDate || item.PlannedDate || "") || "");
        var errorKey = buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName);
        var existingError = cooldownSimulatorDateEditErrors[errorKey] || "";
        var suggestionText = getCooldownSimulatorDateFixSuggestionText(item, fieldName);
        var hasUserEdited = false;

        container.style.display = "flex";
        container.style.flexDirection = "column";
        container.style.gap = "4px";

        inputRow.style.display = "flex";
        inputRow.style.alignItems = "center";
        inputRow.style.gap = "6px";
        inputRow.style.minWidth = "0";

        if (sourceRowIndex < 0) {
            cell.textContent = formatCooldownSimulatorCellText(value);
            row.appendChild(cell);
            return;
        }

        input.type = "text";
        input.value = value;
        input.placeholder = "yyyy-MM-dd HH:mm";
        input.style.flex = "1 1 156px";
        input.style.width = "0";
        input.style.minWidth = "156px";
        input.style.boxSizing = "border-box";
        input.style.padding = "4px 6px";
        input.style.borderRadius = "6px";
        input.style.border = existingError
            ? "1px solid rgba(255, 125, 153, 0.80)"
            : "1px solid rgba(255, 255, 255, 0.16)";
        input.style.background = "rgba(255, 255, 255, 0.04)";
        input.style.color = "#EAF2FF";

        error.style.fontSize = "11px";
        error.style.lineHeight = "1.35";
        error.style.color = "#ffb3c2";
        error.style.display = existingError ? "block" : "none";
        error.textContent = existingError;

        input.addEventListener("input", function () {
            hasUserEdited = true;
            clearCooldownSimulatorDateEditError(sourceRowIndex, fieldName);
            input.style.border = "1px solid rgba(255, 255, 255, 0.16)";
            error.style.display = "none";
            error.textContent = "";
            scheduleCooldownSimulatorDateEditCommit(input, error, item, fieldName, function () {
                hasUserEdited = false;
            });
        });

        input.addEventListener("keydown", function (event) {
            if (event.key !== "Enter") {
                return;
            }

            event.preventDefault();
            cancelCooldownSimulatorDateEditDebounce(sourceRowIndex, fieldName);
            commitCooldownSimulatorDateEdit(input, error, item, fieldName);
            hasUserEdited = false;
        });

        input.addEventListener("blur", function () {
            if (!hasUserEdited) {
                return;
            }

            cancelCooldownSimulatorDateEditDebounce(sourceRowIndex, fieldName);
            commitCooldownSimulatorDateEdit(input, error, item, fieldName);
            hasUserEdited = false;
        });

        inputRow.appendChild(input);
        appendCooldownSimulatorInfoButton(
            inputRow,
            suggestionText,
            fieldName === "end" ? "Show End Date fix suggestion" : "Show Start Date fix suggestion",
            getCooldownSimulatorStatusAccent(item && (item.status || item.Status || "")));
        container.appendChild(inputRow);
        container.appendChild(error);
        cell.appendChild(container);
        row.appendChild(cell);
    }

    function commitCooldownSimulatorDateEdit(input, errorElement, item, fieldName) {
        if (!input) {
            return;
        }

        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var normalizedValue = String(input.value || "").trim();
        var commitKey = buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName);
        var existingValue = fieldName === "end"
            ? String(item && (item.endDate || item.EndDate || "") || "").trim()
            : String(item && (item.plannedDate || item.PlannedDate || "") || "").trim();
        var validationError = validateCooldownSimulatorDateEdit(item, fieldName, input.value);
        if (validationError) {
            setCooldownSimulatorDateEditError(sourceRowIndex, fieldName, validationError);
            input.style.border = "1px solid rgba(255, 125, 153, 0.80)";
            if (errorElement) {
                errorElement.style.display = "block";
                errorElement.textContent = validationError;
            }
            return;
        }

        clearCooldownSimulatorDateEditError(sourceRowIndex, fieldName);
        if (normalizedValue === existingValue) {
            delete cooldownSimulatorDateEditLastCommittedValues[commitKey];
            return;
        }

        if (cooldownSimulatorDateEditLastCommittedValues[commitKey] === normalizedValue) {
            return;
        }

        input.style.border = "1px solid rgba(255, 255, 255, 0.16)";
        if (errorElement) {
            errorElement.style.display = "none";
            errorElement.textContent = "";
        }

        postCooldownSimulatorAction(
            fieldName === "end" ? "set-launch-end-date" : "set-launch-start-date",
            [],
            {
                sourceRowIndex: sourceRowIndex,
                dateValue: normalizedValue
            });
        cooldownSimulatorDateEditLastCommittedValues[commitKey] = normalizedValue;
    }

    function scheduleCooldownSimulatorDateEditCommit(input, errorElement, item, fieldName, onCommitted) {
        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var timerKey = buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName);
        cancelCooldownSimulatorDateEditDebounce(sourceRowIndex, fieldName);
        cooldownSimulatorDateEditTimers[timerKey] = window.setTimeout(function () {
            delete cooldownSimulatorDateEditTimers[timerKey];
            commitCooldownSimulatorDateEdit(input, errorElement, item, fieldName);
            if (typeof onCommitted === "function") {
                onCommitted();
            }
        }, 800);
    }

    function cancelCooldownSimulatorDateEditDebounce(sourceRowIndex, fieldName) {
        var timerKey = buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName);
        if (!cooldownSimulatorDateEditTimers[timerKey]) {
            return;
        }

        window.clearTimeout(cooldownSimulatorDateEditTimers[timerKey]);
        delete cooldownSimulatorDateEditTimers[timerKey];
    }

    function clearCooldownSimulatorDateEditDebounces() {
        Object.keys(cooldownSimulatorDateEditTimers).forEach(function (timerKey) {
            window.clearTimeout(cooldownSimulatorDateEditTimers[timerKey]);
        });
        cooldownSimulatorDateEditTimers = Object.create(null);
        cooldownSimulatorDateEditLastCommittedValues = Object.create(null);
    }

    function validateCooldownSimulatorDateEdit(item, fieldName, rawValue) {
        var normalizedValue = String(rawValue || "").trim();
        var parsedDate = parseCooldownSimulatorEditableDateText(normalizedValue);
        if (!parsedDate) {
            return (fieldName === "end" ? "End Date" : "Start Date") + " is invalid.";
        }

        var currentStartDate = parseCooldownSimulatorEditableDateText(String(item && (item.plannedDate || item.PlannedDate || "") || "").trim());
        var currentEndDate = parseCooldownSimulatorEditableDateText(String(item && (item.endDate || item.EndDate || "") || "").trim());
        var startDate = fieldName === "start" ? parsedDate : currentStartDate;
        var endDate = fieldName === "end" ? parsedDate : currentEndDate;
        if (startDate && endDate && endDate.getTime() < startDate.getTime()) {
            return "End Date cannot be earlier than Start Date.";
        }

        return "";
    }

    function parseCooldownSimulatorEditableDateText(rawValue) {
        var normalizedValue = String(rawValue || "").trim();
        if (!normalizedValue) {
            return null;
        }

        var match = normalizedValue.match(/^(\d{4})-(\d{2})-(\d{2})(?:[ T](\d{1,2}):(\d{2}))?$/);
        if (match) {
            var year = parseInt(match[1], 10);
            var month = parseInt(match[2], 10) - 1;
            var day = parseInt(match[3], 10);
            var hour = parseInt(match[4] || "0", 10);
            var minute = parseInt(match[5] || "0", 10);
            var fallbackDate = new Date(year, month, day, hour, minute, 0, 0);
            if (isNaN(fallbackDate.getTime()) ||
                fallbackDate.getFullYear() !== year ||
                fallbackDate.getMonth() !== month ||
                fallbackDate.getDate() !== day ||
                fallbackDate.getHours() !== hour ||
                fallbackDate.getMinutes() !== minute) {
                return null;
            }

            return fallbackDate;
        }

        var normalizedIsoValue = normalizedValue.replace(" ", "T");
        var parsedDate = new Date(normalizedIsoValue);
        return isNaN(parsedDate.getTime()) ? null : parsedDate;
    }

    function buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName) {
        return String(sourceRowIndex) + ":" + String(fieldName || "");
    }

    function setCooldownSimulatorDateEditError(sourceRowIndex, fieldName, message) {
        cooldownSimulatorDateEditErrors[buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName)] = String(message || "");
    }

    function clearCooldownSimulatorDateEditError(sourceRowIndex, fieldName) {
        delete cooldownSimulatorDateEditErrors[buildCooldownSimulatorDateEditKey(sourceRowIndex, fieldName)];
    }

    function getCooldownSimulatorDateFixSuggestionText(item, fieldName) {
        if (!shouldShowCooldownSimulatorDateFixSuggestion(item)) {
            return "";
        }

        if (fieldName === "end") {
            return item.endDateSuggestionText || item.EndDateSuggestionText || "";
        }

        return item.startDateSuggestionText || item.StartDateSuggestionText || "";
    }

    function shouldShowCooldownSimulatorDateFixSuggestion(item) {
        if (!isCooldownSimulatorAnalysisItemSimulated(item)) {
            return false;
        }

        var status = item && (item.status || item.Status || "");
        if (status !== "delayed" && status !== "expired") {
            return false;
        }

        var audienceSelection = item && (item.audienceSelectionMode || item.AudienceSelectionMode || "");
        return audienceSelection !== "EXCLUDE";
    }

    function isCooldownSimulatorItemTokenPriorityLocked(item) {
        return !!(item && (item.isTokenPriorityLocked || item.IsTokenPriorityLocked));
    }

    function getCooldownSimulatorItemPriorityLockReason(item) {
        var reason = String(item && (item.priorityLockReason || item.PriorityLockReason || "") || "").trim();
        return reason || "Priority locked to 0 because Location contains Token.";
    }

    function appendCooldownSimulatorPolicyBadge(container, text, tooltipText) {
        if (!container || !text) {
            return;
        }

        var badge = document.createElement("span");
        badge.className = "cooldown-simulator-policy-badge";
        badge.textContent = text;
        if (tooltipText) {
            badge.title = tooltipText;
        }
        container.appendChild(badge);
    }

    function appendCooldownSimulatorEffectiveSeverityCell(row, item, isEditable) {
        var cell = document.createElement("td");
        var value = getCooldownSimulatorItemEffectiveSeverityValue(item);
        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var isManual = isCooldownSimulatorItemManualSeverityModified(item);
        var isTokenLocked = isCooldownSimulatorItemTokenPriorityLocked(item);
        var rawLockReason = String(item && (item.priorityLockReason || item.PriorityLockReason || "") || "").trim();
        var priorityLockSource = String(item && (item.priorityLockSource || item.PriorityLockSource || "") || "").trim();
        var priorityLockReason = isTokenLocked ? getCooldownSimulatorItemPriorityLockReason(item) : rawLockReason;
        var hasWgncPriorityReset = !!(item && (item.hasWgncPriorityReset || item.HasWgncPriorityReset));
        var usesBothSharedPriority = !!(item && (item.usesBothSharedPriority || item.UsesBothSharedPriority));
        var container = document.createElement("div");
        var valueSpan = document.createElement("span");

        cell.className = "cooldown-simulator-effective-severity-cell";
        container.className = "cooldown-simulator-effective-severity";
        if (isManual) {
            container.classList.add("is-manual");
            valueSpan.title = priorityLockReason || "Manually adjusted and locked for optimizer changes";
        }
        if (isTokenLocked) {
            container.classList.add("is-locked");
            valueSpan.title = priorityLockReason;
        }

        valueSpan.className = "cooldown-simulator-effective-severity-value";
        valueSpan.textContent = value === null ? (item && (item.effectiveSeverity || item.EffectiveSeverity || "")) : String(value);
        container.appendChild(valueSpan);

        if (isEditable && sourceRowIndex >= 0 && value !== null) {
            var controls = document.createElement("span");
            var upButton = document.createElement("button");
            var downButton = document.createElement("button");

            controls.className = "cooldown-simulator-effective-severity-controls";

            upButton.type = "button";
            upButton.className = "cooldown-simulator-severity-stepper";
            upButton.innerHTML = "&uarr;";
            upButton.disabled = isTokenLocked || value <= 0;
            upButton.setAttribute("data-action", "severity-up");
            upButton.setAttribute("data-row-id", String(sourceRowIndex));
            upButton.setAttribute("aria-label", "Increase launch urgency");
            if (isTokenLocked) {
                upButton.title = priorityLockReason;
            }

            downButton.type = "button";
            downButton.className = "cooldown-simulator-severity-stepper";
            downButton.innerHTML = "&darr;";
            downButton.disabled = isTokenLocked || value >= 4;
            downButton.setAttribute("data-action", "severity-down");
            downButton.setAttribute("data-row-id", String(sourceRowIndex));
            downButton.setAttribute("aria-label", "Decrease launch urgency");
            if (isTokenLocked) {
                downButton.title = priorityLockReason;
            }

            controls.appendChild(upButton);
            controls.appendChild(downButton);
            container.appendChild(controls);
        }

        if (isTokenLocked) {
            appendCooldownSimulatorInfoButton(
                container,
                priorityLockReason,
                "Show priority lock reason",
                getCooldownSimulatorStatusAccent("delayed"));
        }

        if (!isTokenLocked && priorityLockReason) {
            appendCooldownSimulatorInfoButton(
                container,
                priorityLockReason,
                "Show priority lock reason",
                getCooldownSimulatorStatusAccent("delayed"));
        }

        if (priorityLockSource === "manual") {
            appendCooldownSimulatorPolicyBadge(container, "LOCK", priorityLockReason || "Manual priority override is locked.");
        }

        if (hasWgncPriorityReset) {
            appendCooldownSimulatorPolicyBadge(container, "WGNC reset", "Priority 0 resets the WGNC cooldown chain.");
        }

        if (usesBothSharedPriority) {
            appendCooldownSimulatorPolicyBadge(container, "BOTH shared", "One effective priority is shared by MAU and NAU evaluation.");
        }

        cell.appendChild(container);
        row.appendChild(cell);
    }

    function appendCooldownSimulatorImportantLaunchCell(row, item, isEditable) {
        var cell = document.createElement("td");
        var sourceRowIndex = getCooldownSimulatorItemSourceRowIndex(item);
        var hasImportantLaunchValue = !!(item && (
            Object.prototype.hasOwnProperty.call(item, "isImportantLaunch") ||
            Object.prototype.hasOwnProperty.call(item, "IsImportantLaunch")
        ));
        var isImportantLaunch = !!(item && (item.isImportantLaunch || item.IsImportantLaunch));

        if (!hasImportantLaunchValue || !isEditable || sourceRowIndex < 0) {
            cell.textContent = hasImportantLaunchValue ? (isImportantLaunch ? "Yes" : "No") : "\u2014";
            row.appendChild(cell);
            return;
        }

        var checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = isImportantLaunch;
        checkbox.setAttribute("aria-label", "Mark launch as important");
        checkbox.addEventListener("change", function () {
            postCooldownSimulatorAction("set-important-launch", [], {
                sourceRowIndex: sourceRowIndex,
                isImportantLaunch: checkbox.checked
            });
        });

        cell.appendChild(checkbox);
        row.appendChild(cell);
    }

    function handleCooldownSimulatorResultsClick(panel, event) {
        if (!panel || !event) {
            return;
        }

        var button = event.target && typeof event.target.closest === "function"
            ? event.target.closest("button[data-action='severity-up'], button[data-action='severity-down']")
            : null;
        if (!button || button.disabled) {
            return;
        }

        var rowId = parseInt(button.getAttribute("data-row-id") || "", 10);
        var action = button.getAttribute("data-action") || "";
        var delta = action === "severity-up"
            ? -1
            : (action === "severity-down" ? 1 : 0);
        if (!isFinite(rowId) || delta === 0) {
            return;
        }

        console.log("[FORM3-COOLDOWN][JS] severity click detected rowId=" + rowId + " action=" + action);
        if (!applyCooldownSimulatorManualSeverityAdjustment(rowId, delta)) {
            return;
        }

        postCooldownSimulatorAction("adjust-effective-severity", [], {
            sourceRowIndex: rowId,
            delta: delta
        });
    }

    function applyCooldownSimulatorManualSeverityAdjustment(sourceRowIndex, delta) {
        var target = findCooldownSimulatorAnalysisItemBySourceRowIndex(sourceRowIndex);
        if (!target) {
            console.log("[FORM3-COOLDOWN][JS] severity row not found rowId=" + sourceRowIndex);
            return false;
        }

        if (isCooldownSimulatorItemTokenPriorityLocked(target.item)) {
            console.log("[FORM3-COOLDOWN][JS] severity edit blocked by token priority lock rowId=" + sourceRowIndex);
            setCooldownSimulatorItemSeverityValue(target.item, 0, false);
            updateCooldownSimulatorWorkspacePanels();
            return false;
        }

        var oldSeverity = getCooldownSimulatorItemEffectiveSeverityValue(target.item);
        if (oldSeverity === null) {
            console.log("[FORM3-COOLDOWN][JS] severity value missing rowId=" + sourceRowIndex);
            return false;
        }

        var newSeverity = clampCooldownSimulatorSeverity(oldSeverity + delta);
        console.log("[FORM3-COOLDOWN][JS] severity row resolved rowId=" + sourceRowIndex + " old=" + oldSeverity + " new=" + newSeverity);
        if (newSeverity === oldSeverity) {
            return false;
        }

        setCooldownSimulatorItemSeverityValue(target.item, newSeverity);
        console.log("[FORM3-COOLDOWN][JS] manual override stored rowId=" + sourceRowIndex + " effectiveSeverity=" + newSeverity);
        updateCooldownSimulatorWorkspacePanels();
        console.log("[FORM3-COOLDOWN][JS] rerender completed rowId=" + sourceRowIndex);
        return true;
    }

    function findCooldownSimulatorAnalysisItemBySourceRowIndex(sourceRowIndex) {
        if (!currentCooldownSimulatorState || !Array.isArray(currentCooldownSimulatorState.analysisResults) || !workspaceHost) {
            return null;
        }

        var panels = workspaceHost.querySelectorAll(".workspace-panel");
        for (var panelIndex = 0; panelIndex < panels.length; panelIndex += 1) {
            var panel = panels[panelIndex];
            if (!panel || !panel.querySelector(".workspace-cooldown-simulator")) {
                continue;
            }

            var analysisResults = currentCooldownSimulatorState.analysisResults;
            for (var resultIndex = 0; resultIndex < analysisResults.length; resultIndex += 1) {
                var result = analysisResults[resultIndex];
                var items = Array.isArray(result && result.items)
                    ? result.items
                    : (Array.isArray(result && result.Items) ? result.Items : []);
                for (var itemIndex = 0; itemIndex < items.length; itemIndex += 1) {
                    var item = items[itemIndex];
                    if (getCooldownSimulatorItemSourceRowIndex(item) === sourceRowIndex) {
                        return {
                            panel: panel,
                            item: item
                        };
                    }
                }
            }
        }

        return null;
    }

    function setCooldownSimulatorItemSeverityValue(item, severity, isManual) {
        var severityText = String(severity);
        var shouldMarkManual = isManual !== false;
        if (!item) {
            return;
        }

        item.effectiveSeverity = severityText;
        item.EffectiveSeverity = severityText;
        item.manualSeverityOverride = shouldMarkManual ? severityText : "";
        item.ManualSeverityOverride = shouldMarkManual ? severityText : "";
        item.isManualSeverityModified = shouldMarkManual;
        item.IsManualSeverityModified = shouldMarkManual;
    }

    function clampCooldownSimulatorSeverity(value) {
        if (value < 0) {
            return 0;
        }

        if (value > 4) {
            return 4;
        }

        return value;
    }

    function renderCooldownSimulatorOptimizationSummary(container, summary) {
        if (!container) {
            return;
        }

        container.innerHTML = "";
        container.style.display = "none";

        if (!summary) {
            return;
        }

        var heading = document.createElement("h4");
        var metricsList = document.createElement("div");
        var changes = Array.isArray(summary.changes)
            ? summary.changes
            : (Array.isArray(summary.Changes) ? summary.Changes : []);

        container.style.display = "block";
        heading.textContent = "Optimization summary";
        metricsList.className = "cooldown-simulator-optimization-metrics";

        appendCooldownSimulatorOptimizationMetric(
            metricsList,
            "Channels improved",
            formatCooldownSimulatorMetric(summary.channelsImproved, summary.ChannelsImproved));
        appendCooldownSimulatorOptimizationMetric(
            metricsList,
            "Severity changes made",
            formatCooldownSimulatorMetric(summary.severityChangesMade, summary.SeverityChangesMade));
        appendCooldownSimulatorOptimizationMetric(
            metricsList,
            "Expired",
            formatCooldownSimulatorTransitionMetric(summary.expiredBefore, summary.ExpiredBefore, summary.expiredAfter, summary.ExpiredAfter));
        appendCooldownSimulatorOptimizationMetric(
            metricsList,
            "Delayed 7+ days",
            formatCooldownSimulatorTransitionMetric(summary.delayedSevenPlusBefore, summary.DelayedSevenPlusBefore, summary.delayedSevenPlusAfter, summary.DelayedSevenPlusAfter));
        appendCooldownSimulatorOptimizationMetric(
            metricsList,
            "Delayed",
            formatCooldownSimulatorTransitionMetric(summary.delayedBefore, summary.DelayedBefore, summary.delayedAfter, summary.DelayedAfter));

        container.appendChild(heading);
        container.appendChild(metricsList);

        if (!changes.length) {
            return;
        }

        var changesHeading = document.createElement("div");
        var changesTable = document.createElement("table");
        var changesHead = document.createElement("thead");
        var changesHeadRow = document.createElement("tr");
        var changesBody = document.createElement("tbody");
        var detailsWrapper = document.createElement("div");

        changesHeading.className = "cooldown-simulator-optimization-changes-heading";
        changesHeading.textContent = "Severity changes";
        detailsWrapper.className = "cooldown-simulator-result-details cooldown-simulator-optimization-details";
        changesTable.className = "cooldown-simulator-optimization-table";

        ["Title", "Channel", "Region", "Original Effective Severity", "Optimized Severity", "Previous Status", "New Status", "Previous Delay Days", "New Delay Days"].forEach(function (label) {
            var headerCell = document.createElement("th");
            headerCell.textContent = label;
            changesHeadRow.appendChild(headerCell);
        });

        changesHead.appendChild(changesHeadRow);
        changesTable.appendChild(changesHead);

        changes.forEach(function (change) {
            var row = document.createElement("tr");
            appendCooldownSimulatorTitleCell(
                row,
                change.title || change.Title || "",
                change.issueKey || change.IssueKey || "",
                change.issueUrl || change.IssueUrl || "");
            appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorChannelName(change.channel || change.Channel || ""));
            appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorRegionGroup(change.regionGroup || change.RegionGroup || ""));
            appendCooldownSimulatorDetailCell(row, change.originalEffectiveSeverity || change.OriginalEffectiveSeverity || "");
            appendCooldownSimulatorDetailCell(row, change.optimizedSeverity || change.OptimizedSeverity || "");
            appendCooldownSimulatorDetailCell(row, change.previousStatus || change.PreviousStatus || "");
            appendCooldownSimulatorDetailCell(row, change.newStatus || change.NewStatus || "");
            appendCooldownSimulatorDetailCell(row, formatCooldownSimulatorOptionalMetric(change.previousDelayDays, change.PreviousDelayDays));
            appendCooldownSimulatorDetailCell(row, formatCooldownSimulatorOptionalMetric(change.newDelayDays, change.NewDelayDays));
            changesBody.appendChild(row);
        });

        changesTable.appendChild(changesBody);
        detailsWrapper.appendChild(changesTable);
        container.appendChild(changesHeading);
        container.appendChild(detailsWrapper);
    }

    function renderCooldownSimulatorValidation(
        summaryContainer,
        tableContainer,
        validationIssueCount,
        autoExcludedPrmMissingAudienceCount,
        invalidRows,
        hasBlockingImportIssues) {
        if (!summaryContainer || !tableContainer) {
            return;
        }

        summaryContainer.innerHTML = "";
        tableContainer.innerHTML = "";
        summaryContainer.style.display = "none";
        tableContainer.style.display = "none";

        if (!validationIssueCount && !autoExcludedPrmMissingAudienceCount) {
            return;
        }

        summaryContainer.style.display = "block";
        summaryContainer.style.marginTop = "12px";
        summaryContainer.style.padding = "12px";
        summaryContainer.style.border = validationIssueCount
            ? "1px solid rgba(255, 120, 120, 0.65)"
            : "1px solid rgba(138, 180, 248, 0.35)";
        summaryContainer.style.borderRadius = "10px";
        summaryContainer.style.background = validationIssueCount
            ? "rgba(120, 20, 20, 0.18)"
            : "rgba(138, 180, 248, 0.10)";

        var summaryHeading = document.createElement("div");
        var summaryText = document.createElement("div");
        summaryHeading.textContent = validationIssueCount
            ? "Import issues found: " + String(validationIssueCount)
            : "Import completed";
        summaryHeading.style.fontWeight = "700";
        summaryContainer.appendChild(summaryHeading);
        if (validationIssueCount) {
            summaryText.textContent = hasBlockingImportIssues
                ? "Blocking import issues must be corrected before analysis can run."
                : String(validationIssueCount) + " imported launch rows have validation errors or normalization warnings.";
            summaryText.style.marginTop = "6px";
            summaryContainer.appendChild(summaryText);
        }

        if (autoExcludedPrmMissingAudienceCount > 0) {
            var prmAutoText = document.createElement("div");
            prmAutoText.textContent = "PRM launches without audience auto-excluded: " +
                String(autoExcludedPrmMissingAudienceCount) +
                ". Priority set to 0.";
            prmAutoText.style.marginTop = "6px";
            prmAutoText.style.color = "#CDE3FF";
            summaryContainer.appendChild(prmAutoText);
        }

        if (!Array.isArray(invalidRows) || !invalidRows.length) {
            return;
        }

        tableContainer.style.display = "block";
        tableContainer.style.marginTop = "12px";
        tableContainer.style.padding = "12px";
        tableContainer.style.border = "1px solid rgba(255, 120, 120, 0.45)";
        tableContainer.style.borderRadius = "10px";

        var heading = document.createElement("h4");
        var wrapper = document.createElement("div");
        var table = document.createElement("table");
        var thead = document.createElement("thead");
        var headRow = document.createElement("tr");
        var tbody = document.createElement("tbody");

        heading.textContent = "Import issue rows";
        wrapper.className = "cooldown-simulator-result-details cooldown-simulator-validation-details";
        table.className = "cooldown-simulator-validation-table-grid";

        ["Issue", "Title", "Channel", "Region", "Raw Realm", "Audience", "Start Date", "End date", "Details"].forEach(function (label) {
            var headerCell = document.createElement("th");
            headerCell.textContent = label;
            headRow.appendChild(headerCell);
        });

        thead.appendChild(headRow);
        table.appendChild(thead);

        invalidRows.forEach(function (rowItem) {
            var row = document.createElement("tr");
            appendCooldownSimulatorIssueCell(row, rowItem.issueKey || "", rowItem.issueUrl || "");
            appendCooldownSimulatorTitleCell(row, rowItem.title || "", rowItem.issueKey || "", rowItem.issueUrl || "");
            appendCooldownSimulatorDetailCell(row, normalizeCooldownSimulatorChannelName(rowItem.normalizedChannel || rowItem.channel || ""));
            appendCooldownSimulatorRegionCorrectionCell(row, rowItem);
            appendCooldownSimulatorDetailCell(row, rowItem.rawRealm || "");
            appendCooldownSimulatorAudienceSelectionCell(row, rowItem, true);
            appendCooldownSimulatorDetailCell(row, rowItem.startDate || "");
            appendCooldownSimulatorDetailCell(row, rowItem.endDate || "");
            appendCooldownSimulatorDetailCell(row, formatCooldownSimulatorValidationDetails(rowItem));
            tbody.appendChild(row);
        });

        table.appendChild(tbody);
        wrapper.appendChild(table);
        tableContainer.appendChild(heading);
        tableContainer.appendChild(wrapper);
    }

    function formatCooldownSimulatorValidationDetails(rowItem) {
        var details = [];
        var validationError = rowItem && (rowItem.validationError || rowItem.ValidationError || "");
        var warnings = rowItem && Array.isArray(rowItem.normalizationWarnings)
            ? rowItem.normalizationWarnings
            : (rowItem && Array.isArray(rowItem.NormalizationWarnings) ? rowItem.NormalizationWarnings : []);
        if (validationError) {
            details.push(validationError);
        }

        warnings.forEach(function (warning) {
            if (warning) {
                details.push(warning);
            }
        });

        return details.join(" ");
    }

    function appendCooldownSimulatorOptimizationMetric(container, label, value) {
        var item = document.createElement("div");
        item.className = "cooldown-simulator-optimization-metric";
        item.textContent = label + ": " + value;
        container.appendChild(item);
    }

    function formatCooldownSimulatorTransitionMetric(beforePrimary, beforeFallback, afterPrimary, afterFallback) {
        return formatCooldownSimulatorMetric(beforePrimary, beforeFallback) + " -> " +
            formatCooldownSimulatorMetric(afterPrimary, afterFallback);
    }

    function formatCooldownSimulatorItemStatus(item) {
        var statusDisplay = item && (item.statusDisplay || item.StatusDisplay || "");
        if (statusDisplay) {
            return statusDisplay;
        }

        var status = item && (item.status || item.Status || "");
        var delayDisplay = item && (item.delayDisplay || item.DelayDisplay || "");
        if (status === "delayed" && delayDisplay) {
            return "Delayed (" + delayDisplay + ")";
        }

        if (status === "expired") {
            return "Expired";
        }

        if (status === "on_time") {
            return "On time";
        }

        return status;
    }

    function formatCooldownSimulatorProtectedTarget(item) {
        var isImportantLaunch = !!(item && (item.isImportantLaunch || item.IsImportantLaunch));
        if (!isImportantLaunch) {
            return "";
        }

        var targetState = item && (item.importantLaunchTargetState || item.ImportantLaunchTargetState || "");
        var usedLastResortSeverityZero = !!(item && (
            item.isLastResortSeverityZeroRescueApplied ||
            item.IsLastResortSeverityZeroRescueApplied
        ));
        if (targetState === "rescued_from_expiry") {
            return usedLastResortSeverityZero
                ? "rescued by forced severity 0"
                : "rescued from expiry";
        }

        if (targetState === "within_4_day_target") {
            return "within 4-day target";
        }

        if (targetState === "unrescued_expired") {
            return "expired, rescue pending";
        }

        if (targetState === "still_infeasible") {
            return "still infeasible";
        }

        if (targetState === "delay_over_target") {
            return "delay over target";
        }

        return item && (item.protectedTargetAchieved || item.ProtectedTargetAchieved)
            ? "met"
            : "missed";
    }

    function formatCooldownSimulatorItemChannel(item) {
        return normalizeCooldownSimulatorChannelName(item && (item.channel || item.Channel || "") || "");
    }

    function normalizeCooldownSimulatorRegionGroup(regionGroup) {
        var raw = String(regionGroup || "").trim().toUpperCase();
        if (raw === "EU" || raw === "NA" || raw === "SEA" || raw === "GLOBAL") {
            return "GLOBAL";
        }

        if (raw === "CN") {
            return "CN";
        }

        if (raw === "BOTH") {
            return "BOTH";
        }

        return String(regionGroup || "").trim();
    }

    function formatCooldownSimulatorChannelRegionLabel(channelName, regionGroup) {
        var normalizedChannelName = normalizeCooldownSimulatorChannelName(channelName);
        var normalizedRegionGroup = normalizeCooldownSimulatorRegionGroup(regionGroup);
        if (!normalizedRegionGroup) {
            return normalizedChannelName;
        }

        if (!normalizedChannelName) {
            return normalizedRegionGroup;
        }

        return normalizedChannelName + " | " + normalizedRegionGroup;
    }

    function isCooldownSimulatorSimulatedChannelName(channelName) {
        var normalized = normalizeCooldownSimulatorChannelName(channelName);
        return normalized !== "PRM";
    }

    function isCooldownSimulatorAnalysisItemSimulated(item) {
        if (!item) {
            return false;
        }

        if (item.isSimulatedChannel === false || item.IsSimulatedChannel === false) {
            return false;
        }

        return isCooldownSimulatorSimulatedChannelName(item.channel || item.Channel || "");
    }

    function normalizeCooldownSimulatorChannelName(channelName) {
        var raw = String(channelName || "").trim();
        var normalized = raw.toUpperCase();
        if (normalized === "WGC") {
            return "WGC";
        }

        if (normalized === "WGNC") {
            return "WGNC";
        }

        if (normalized === "EMAIL" || normalized === "E-MAIL" || normalized === "E MAIL" || normalized === "MAIL") {
            return "EMAIL";
        }

        if (normalized === "WP") {
            return "WP";
        }

        if (normalized === "PROMOSCREEN" || normalized === "PS") {
            return "PS";
        }

        if (normalized === "SMS") {
            return "SMS";
        }

        if (normalized === "PRM") {
            return "PRM";
        }

        return raw;
    }

    function formatCooldownSimulatorItemAudience(item) {
        var audienceSelectionMode = formatCooldownSimulatorAudienceSelectionMode(item);
        if (audienceSelectionMode === "EXCLUDE" ||
            audienceSelectionMode === "MAU" ||
            audienceSelectionMode === "NAU" ||
            audienceSelectionMode === "BOTH") {
            return audienceSelectionMode;
        }

        if (item && typeof item.audienceLabel === "string" && item.audienceLabel.length > 0) {
            return item.audienceLabel;
        }

        if (item && typeof item.AudienceLabel === "string" && item.AudienceLabel.length > 0) {
            return item.AudienceLabel;
        }

        var audienceState = getCooldownSimulatorAudienceState(item);
        if (audienceState.isMauAudience && !audienceState.isNauAudience) {
            return "MAU";
        }

        if (!audienceState.isMauAudience && audienceState.isNauAudience) {
            return "NAU";
        }

        return "BOTH";
    }

    function getCooldownSimulatorItemSourceRowIndex(item) {
        if (!item) {
            return -1;
        }

        if (typeof item.sourceRowIndex === "number") {
            return item.sourceRowIndex;
        }

        if (typeof item.SourceRowIndex === "number") {
            return item.SourceRowIndex;
        }

        return -1;
    }

    function getCooldownSimulatorAudienceState(item) {
        var isMauAudience = !!(item && (item.isMauAudience || item.IsMauAudience));
        var isNauAudience = !!(item && (item.isNauAudience || item.IsNauAudience));

        return {
            isMauAudience: isMauAudience,
            isNauAudience: isNauAudience
        };
    }

    function getCooldownSimulatorItemEffectiveSeverityValue(item) {
        var rawValue = item && (item.effectiveSeverity || item.EffectiveSeverity || "");
        if (typeof rawValue !== "string" && typeof rawValue !== "number") {
            return null;
        }

        var parsed = parseInt(String(rawValue), 10);
        return isNaN(parsed) ? null : parsed;
    }

    function isCooldownSimulatorItemManualSeverityModified(item) {
        return !!(item && (item.isManualSeverityModified || item.IsManualSeverityModified));
    }

    function collectSelectedCooldownSimulatorChannels(panel) {
        if (!panel) {
            return [];
        }

        var checkboxes = panel.querySelectorAll(".cooldown-simulator-channel-item input[type='checkbox']");
        var selectedChannels = [];
        checkboxes.forEach(function (checkbox) {
            if (checkbox.checked && typeof checkbox.value === "string" && checkbox.value.length > 0) {
                selectedChannels.push(checkbox.value);
            }
        });
        return selectedChannels;
    }

    function formatCooldownSimulatorMetric(primaryValue, fallbackValue) {
        if (typeof primaryValue === "number") {
            return String(primaryValue);
        }

        if (typeof fallbackValue === "number") {
            return String(fallbackValue);
        }

        return "0";
    }

    function formatCooldownSimulatorOptionalMetric(primaryValue, fallbackValue) {
        if (typeof primaryValue === "number") {
            return String(primaryValue);
        }

        if (typeof fallbackValue === "number") {
            return String(fallbackValue);
        }

        return "";
    }

    function formatCooldownSimulatorAudienceSelectionMode(item) {
        var audienceSelectionMode = item && (item.audienceSelectionMode || item.AudienceSelectionMode || "") || "";
        if (audienceSelectionMode === "MAU" ||
            audienceSelectionMode === "NAU" ||
            audienceSelectionMode === "BOTH" ||
            audienceSelectionMode === "EXCLUDE") {
            return audienceSelectionMode;
        }

        var audienceState = getCooldownSimulatorAudienceState(item);
        if (audienceState.isMauAudience && audienceState.isNauAudience) {
            return "BOTH";
        }

        if (audienceState.isMauAudience) {
            return "MAU";
        }

        if (audienceState.isNauAudience) {
            return "NAU";
        }

        return "";
    }

    function postBrowserWorkspaceState(action, tab, bounds, reason, requestedUrl, forceNavigation, outerBounds, toolbarBounds) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "browserWorkspaceState",
            action: action,
            reason: reason,
            tabId: tab ? tab.id : null,
            toolId: tab ? tab.toolId : null,
            url: action === "show"
                ? (requestedUrl || (!tab ? defaultBrowserUrl : null))
                : null,
            forceNavigation: !!forceNavigation,
            bounds: bounds,
            outerBounds: outerBounds || null,
            toolbarBounds: toolbarBounds || null
        });
    }

    function pushBrowserThemeState(reason) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "browserThemeState",
            reason: reason,
            themeName: root.getAttribute("data-theme") || "dark",
            palette: {
                toolbarBackground: getRootVariableValue("--color-bg-panel"),
                toolbarSurface: getRootVariableValue("--color-bg-card"),
                buttonRestBackground: getRootVariableValue("--color-button-secondary-bg"),
                buttonRestText: getRootVariableValue("--color-button-secondary-text"),
                buttonHoverStart: getRootVariableValue("--color-primary"),
                buttonHoverEnd: getRootVariableValue("--color-primary-hover"),
                buttonHoverText: getRootVariableValue("--color-button-primary-text"),
                inputBackground: getRootVariableValue("--color-bg-input"),
                inputText: getRootVariableValue("--color-text-main"),
                inputMutedText: getRootVariableValue("--color-text-muted"),
                inputBorder: getRootVariableValue("--color-border"),
                inputBorderSubtle: getRootVariableValue("--color-border-subtle"),
                inputBorderStrong: getRootVariableValue("--color-border-strong"),
                toolbarText: getRootVariableValue("--color-text-main"),
                toolbarSecondaryText: getRootVariableValue("--color-text-secondary"),
                toolbarDisabledText: getRootVariableValue("--color-text-disabled"),
                divider: getRootVariableValue("--color-divider")
            }
        });
    }

    function sanitizeLogValue(value) {
        return String(value).replace(/"/g, "'");
    }

    function logTabDrag(step, details) {
        var parts = [tabDragLogPrefix, step];
        var keys = Object.keys(details || {});

        keys.forEach(function (key) {
            parts.push(key + "=" + formatLogValue(details[key]));
        });

        var message = parts.join(" ");
        console.log(message);
        forwardTabDragLog(message);
    }

    function logBrowserWorkspace(step, details) {
        var parts = [browserLogPrefix, step];
        var keys = Object.keys(details || {});

        keys.forEach(function (key) {
            parts.push(key + "=" + formatLogValue(details[key]));
        });

        var message = parts.join(" ");
        console.log(message);
        forwardBrowserWorkspaceLog(message);
    }

    function logCopyCatDebug(step, details) {
        var parts = [copyCatDebugPrefix, step];
        var keys = Object.keys(details || {});

        keys.forEach(function (key) {
            parts.push(key + "=" + formatLogValue(details[key]));
        });

        var message = parts.join(" ");
        console.log(message);
        forwardCopyCatDebugLog(message);
    }

    function formatRectForCopyCatDebug(rect) {
        if (!rect) {
            return "null";
        }

        return "left=" + Math.round(rect.left) +
            ",top=" + Math.round(rect.top) +
            ",width=" + Math.round(rect.width) +
            ",height=" + Math.round(rect.height);
    }

    function formatElementForCopyCatDebug(label, element) {
        if (!element) {
            return label + "{missing}";
        }

        var rect = element.getBoundingClientRect();
        var parent = element.parentElement;
        return label +
            "{tag=" + element.tagName.toLowerCase() +
            ",class=\"" + sanitizeLogValue(element.className || "") +
            "\",parent=\"" + sanitizeLogValue(parent ? (parent.className || parent.id || parent.tagName.toLowerCase()) : "") +
            "\",visible=" + (element.getClientRects().length > 0) +
            ",bounds=" + formatRectForCopyCatDebug(rect) +
            "}";
    }

    function logCopyCatWorkspaceSnapshot(step, panel, extraDetails) {
        if (!panel) {
            logCopyCatDebug(step, {
                panel: "missing"
            });
            return;
        }

        var shell = panel.querySelector(".copycat-workspace-shell");
        var browserPane = panel.querySelector(".copycat-browser-pane");
        var browserLayout = panel.querySelector(".copycat-browser-pane > .browser-native-layout");
        var toolbarHost = panel.querySelector("[data-role='browser-toolbar-host']");
        var contentHost = panel.querySelector("[data-role='copycat-browser-anchor']");
        var presetPane = panel.querySelector(".copycat-preset-pane");
        var divider = panel.querySelector(".copycat-splitter");
        var details = {
            panelId: panel.id || "",
            panelVisible: panel.getClientRects().length > 0,
            splitPercent: panel.dataset.copycatSplitPercent || "",
            shell: formatElementForCopyCatDebug("shell", shell),
            browserPane: formatElementForCopyCatDebug("browserPane", browserPane),
            browserLayout: formatElementForCopyCatDebug("browserLayout", browserLayout),
            toolbarHost: formatElementForCopyCatDebug("toolbarHost", toolbarHost),
            contentHost: formatElementForCopyCatDebug("contentHost", contentHost),
            presetPane: formatElementForCopyCatDebug("presetPane", presetPane),
            divider: formatElementForCopyCatDebug("divider", divider)
        };

        Object.keys(extraDetails || {}).forEach(function (key) {
            details[key] = extraDetails[key];
        });

        logCopyCatDebug(step, details);
    }

    function logActiveCopyCatWorkspaceSnapshot(step) {
        var activeTab = getActiveTab();
        var panel = activeTab ? findWorkspacePanel(activeTab.panelId) : null;
        if (!activeTab || activeTab.toolId !== "copycat" || !panel) {
            return;
        }

        logCopyCatWorkspaceSnapshot(step, panel, {
            reason: step,
            activeTab: formatTabIdentity(activeTab.id)
        });
    }

    function formatLogValue(value) {
        if (value === null) {
            return "null";
        }

        if (value === undefined) {
            return "undefined";
        }

        if (typeof value === "string") {
            return "\"" + sanitizeLogValue(value) + "\"";
        }

        return String(value);
    }

    function logPointerInput(step, event) {
        var tab = event.target.closest ? event.target.closest(".tab-button") : null;

        logTabDrag(step, {
            tab: tab ? formatTabIdentity(tab.dataset.tabId) : "none",
            visualIndex: tab ? getVisualIndexById(tab.dataset.tabId) : -1,
            modelIndex: tab ? getModelIndexById(tab.dataset.tabId) : -1,
            x: event.clientX,
            y: event.clientY,
            scrollLeft: tabsBar ? tabsBar.scrollLeft : 0,
            targetRole: getEventTargetRole(event.target)
        });
    }

    function forwardTabDragLog(message) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "tabDragDiagnostic",
            message: message
        });
    }

    function forwardBrowserWorkspaceLog(message) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "browserDiagnostic",
            message: message
        });
    }

    function forwardCopyCatDebugLog(message) {
        if (!window.chrome || !window.chrome.webview) {
            return;
        }

        window.chrome.webview.postMessage({
            type: "copycatDiagnostic",
            message: message
        });
    }
});
